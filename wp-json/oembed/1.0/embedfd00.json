84\u4e94\u5e74\u7576\u4e2d\uff0c\u5fc5\u9808\u6709\u6240\u6709\u6b0a\u81f3\u5c11\u5169\u5e74\u4ee5\u4e0a\u3002\u7136\u800c\uff0c\u82e5\u662f\u592b\u59bb\u9078\u64c7\u5408\u4f75\u7533\u5831\uff0c\u5247\u5176\u4e2d\u7684\u4e00\u65b9\u6eff\u8db3\u5169\u5e74\u6240\u6709\u6b0a\u7684\u898f\u5b9a\u5373\u53ef\u3002\u6240\u4ee5\uff0c\u6709\u4e00\u4e9b\u592b\u5a66\u5728\u8ce3\u623f\u5b50\u7684\u90a3\u4e00\u5e74\u9078\u64c7\u4e86\u592b\u59bb\u5408\u4f75\u7533\u5831\u3002 \u7b2c\u4e8c\uff0c\u7b26\u5408\u5728\u8ce3\u623f\u5b50\u6642\u9ede\u7684\u524d\u4e94\u5e74\uff0c\u5c45\u4f4f\u6eff\u5169\u5e74\u7684\u8981\u6c42\u3002\u5169\u5e74\uff0c\u4e5f\u5c31\u662f\u4e03\u767e\u4e09\u5341\u5929\u3002\u53ea\u662f\u9019\u500b\u4e03\u767e\u4e09\u5341\u5929\uff0c\u662f\u4e0d\u9700\u8981\u9023\u8cab\u3002\u5982\u679c\u662f\u592b\u59bb\u5408\u4f75\u7533\u5831\u7684\u7d0d\u7a05\u4eba\uff0c\u82e5\u662f\u8981\u62ff\u5230\u5169\u4eba\u4e94\u5341\u842c\u7684\u514d\u7a05\u984d\uff0c\u96d6\u7136\u50c5\u9700\u5176\u4e2d\u7684\u4e00\u65b9\u6eff\u8db3\u6240\u6709\u6b0a\u7684\u8981\u6c42\uff0c\u4f46\u662f\u537b\u9700\u8981\u96d9\u65b9\u90fd\u6eff\u8db3\u5169\u5e74\u5c45\u4f4f\u7684\u8981\u6c42\u3002\u6709\u9451\u65bc\u6b64\uff0c\u8003\u616e\u4eab\u53d7\u4e00\u62b5\u6e1b\u9805\u7684\u7d0d\u7a05\u4eba\uff0c\u61c9\u8a72\u5728\u8ce3\u623f\u5b50\u7684\u524d\u5169,\u4e09\u5e74\u524d\u5c31\u9032\u884c\u59a5\u5584\u7684\u898f\u5283\u3002 \u800c\u82e5\u662f\u6709\u914d\u5076\u4e0d\u5e78\u53bb\u4e16\uff0c\u53ea\u8981\u80fd\u6eff\u8db3\u4e0a\u8ff0\u6e2c\u8a66\uff0c\u90a3\u5728\u914d\u5076\u53bb\u4e16\u7684\u5169\u5e74\u4e4b\u5167\uff0c\u4ecd\u7136\u80fd\u4eab\u53d7\u9019\u500b\u51fa\u552e\u81ea\u7528\u4f4f\u5b85\u5169\u4eba\u4e94\u5341\u842c\u7684\u514d\u7a05\u984d\u3002 \u5728\u5be6\u52d9\u7576\u4e2d\uff0c\u6211\u5011\u898b\u904e\u6709\u7d0d\u7a05\u4eba\u56e0\u70ba\u7b26\u5408\u4e94\u5341\u842c\u7684\u514d\u7a05\u984d\uff0c\u800c\u81ea\u5df1\u7684\u8cc7\u672c\u5229\u5f97\u4f4e\u65bc\u4e94\u5341\u842c\uff0c\u4ee5\u7232\u4e0d\u9700\u7533\u5831\uff0c\u800c\u6536\u5230\u570b\u7a05\u5c40\u7684\u901a\u77e5\u3002\u56e0\u6b64\uff0c\u9084\u662f\u8981\u8b39\u614e\u8655\u7406\u3002 \u6709\u8208\u8da3\u7684\u670b\u53cb\u53ef\u4ee5\u4e0a\u6211\u5011\u4e8b\u52d9\u6240\u7684\u5b98\u7db2www.agapecpa.com\u00a0\u7372\u5f97\u66f4\u591a\u7684\u7a05\u52d9\u8a0a\u606f\u3002\u6216\u662f\u81f4\u96fb\u6211\u5011Cupertino \u7684\u8fa6\u516c\u5ba4\uff0c408-725-1700. \u611f\u8b1d\u5927\u5bb6\u7684\u6536\u807d\uff0c\u6211\u5011\u4e0b\u671f\u518d\u6703\u3002 \u53c3\u8003\u8cc7\u6599\uff1aIRS publication 523"}