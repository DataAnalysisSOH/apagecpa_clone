64c7\u9019\u7a2e\u7a05\u52d9\u8655\u7406\uff0c\u8b93\u516c\u53f8\u66ff\u80a1\u6771\u652f\u4ed8\u4e00\u5b9a\u6bd4\u4f8b\u7684\u5dde\u7a05\uff0c\u800c\u7531\u516c\u53f8\u6240\u652f\u4ed8\u7684\u5dde\u7a05\uff0c\u5728\u7b97\u806f\u90a6\u7a05\u6642\uff0c\u53ef\u4ee5\u7576\u6210\u7576\u6210\u516c\u53f8\u7684\u8cbb\u7528\u9805\u5168\u984d\u62b5\u6e1b\uff0c\u800c\u4e0d\u53d7\u5230\u5217\u8209\u6263\u9664\u984d\u4e00\u842c\u5143\u62b5\u6e1b\u7684\u9650\u5236\u3002 \u800cPTE election \u7684\u898f\u5b9a\u5404\u5dde\u4e0d\u540c\uff0c\u800c\u672c\u6587\u8a0e\u8ad6\u7684\u7bc4\u570d\u50c5\u9650\u52a0\u5dde\u3002 PTE election \u5728\u52a0\u5dde\u6240\u9069\u7528\u7684\u4eba\u7fa4\u70ba\u5408\u5925\u4f01\u696d\u53caS \u578b\u516c\u53f8\u3002\u7531\u65bc\u6b64\u689d\u6587\u65e8\u5728\u512a\u60e0\u4e2d\u5c0f\u4f01\u696d\uff0c\u6240\u4ee5\u516c\u958b\u4ea4\u6613\u7684\u5408\u5925\u4f01\u696d\u4e26\u4e0d\u9069\u7528\u3002 \u82e5\u662f\u7d0d\u7a05\u4eba\u60f3\u57282023\u5e74\u7684\u516c\u53f8\u7a05\u7a05\u8868\u4e0a\u9ad4\u73fe\u9019\u9805\u7a05\u52d9\u9078\u64c7\uff0c\u5247\u5fc5\u9700\u5728\u516d\u6708\u5341\u4e94\u65e5\u524d\u5148\u4ea4\u7b2c\u4e00\u90e8\u5206\u8a02\u91d1\u7d66FTB. (\u91d1\u984d\u70ba\u4e00\u5343\u7f8e\u5143\u6216\u662f2022\u5e7450%\u7684elective tax, \u53d6\u5176\u5927\u8005\uff09\u800c\u572824\u5e74\u583123\u5e74\u7a05\u7684\u6642\u5019\u518d\u4ea4\u9918\u6b3e\u3002\u800c\u516c\u53f8\u66ff\u80a1\u6771\u6240\u652f\u7684\u7a05\u91d1\uff0c\u5247\u53ef\u4ee5\u7576\u6210\u52a0\u5dde\u7684 non refundable tax credit, \u4e00\u584a\u62b5\u4e00\u584a\u53bb\u6e1b\u5176\u500b\u4eba\u7684\u52a0\u5dde\u5dde\u7a05\u3002\u800c\u52a0\u5dde\u53d7\u51ac\u5b63\u98a8\u66b4\u6240\u5f71\u97ff\u7684\u4f01\u696d\uff0c\u4ed8\u6b3e\u53ef\u5ef6\u81f3\u5341\u6708\u5341\u516d\u65e5\u3002 \u5728\u52a0\u5dde\uff0c\u76ee\u524dPTE\u7684\u9019\u500b\u9078\u9805\u958b\u653e\u81f32025\u5e74\u6703\u8a08\u5e74\u5ea6\u3002 \u7576\u7136\uff0c\u4efb\u4f55\u7684\u9078\u64c7\u90fd\u6709\u5176\u76f8\u5c0d\u61c9\u7684\u5229\u5f0a\u5f97\u5931\u3002\u4f46\u662f\uff0c\u5408\u683c\u7684\u4f01\u696d\u4e3b\u4e0d\u59a8\u8003\u616e\u9019\u4e00\u9078\u9805\uff0c\u9054\u5230\u5408\u6cd5\u7701\u7a05\u7684\u76ee\u7684\u3002"}