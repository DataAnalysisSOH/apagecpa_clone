e0a\u6709\u5169\u9805\u6e2c\u8a66\uff0c\u53ea\u8981\u6eff\u8db3\u5176\u4e2d\u7684\u4e00\u9805\uff0c\u9664\u975e\u6709\u4f8b\u5916\uff0c\u5c31\u662f\u7f8e\u570b\u7684\u7a05\u52d9\u5c45\u6c11\u3002\u7b2c\u4e00\u9805\u6e2c\u8a66\u70ba\u7da0\u5361\u6e2c\u8a66\uff0c\u7b2c\u4e8c\u9805\u6e2c\u8a66\u70ba\u5929\u6578\u6e2c\u8a66\u3002\u95dc\u65bc\u7da0\u5361\u6e2c\u8a66\uff0c\u53ea\u8981\u662f\u7da0\u5361\u6301\u6709\u4eba\u6216\u662f\u7f8e\u570b\u516c\u6c11\uff0c\u5c31\u6eff\u8db3\u4e86\u9019\u4e00\u6e2c\u8a66\u3002\u7da0\u5361\u6301\u6709\u4eba\u82e5\u662f\u4e0d\u6eff\u8db3\u5929\u6578\u6e2c\u8a66\uff0c\u5176\u6210\u70ba\u7a05\u52d9\u5c45\u6c11\u662f\u65e5\u671f\u662f\u7531\u767b\u9678\u7f8e\u570b\u7684\u7b2c\u4e00\u5929\u958b\u59cb\u8d77\u7b97\u3002\u800c\u90a3\u4e00\u5e74\u5c31\u662f\u6240\u8b02\u7684\u96d9\u91cd\u8eab\u4efd\uff0cdual status. \u6211\u5011\u6703\u7528\u4e00\u671f\u7bc0\u76ee\u4f86\u8b1b\u89e3\u3002\u7b2c\u4e8c\u9805\u6e2c\u8a66\u70ba\u5929\u6578\u6e2c\u8a66(substantial presence test)\u8981\u6eff\u8db3\u5929\u6578\u6e2c\u8a66\uff0c\u8981\u540c\u6642\u6eff\u8db3\u7576\u5e74\u5728\u7f8e\u570b\u5883\u5167\u5f85\u4e8631\u5929\u800c\u4e14\u7576\u5e74\u7684\u5929\u6578\u52a0\u53bb\u5e74\u5929\u6578\u76841\/3\u518d\u52a0\u524d\u5e74\u76841\/6\u7e3d\u6578\u8d85\u904e183\u5929\uff0c\u5c31\u6eff\u8db3\u4e86\u5929\u6578\u6e2c\u8a66\u3002\u7576\u7136\uff0c\u51e1\u4e8b\u90fd\u6709\u4f8b\u5916\u3002\u6211\u5011\u5728\u4e0b\u671f\u7684\u7bc0\u76ee\u7576\u4e2d\u5c31\u4f86\u8a0e\u8ad6\u4f8b\u5916\u7684\u60c5\u6cc1\u3002 \u800c\u5728\u57f7\u884c\u696d\u52d9\u7684\u904e\u7a0b\u4e2d\uff0c\u6211\u5011\u5c31\u898b\u904e\u6709\u4eba\u65e9\u5728\u7f8e\u570b\u5b89\u5c45\u6a02\u696d\u591a\u5e74\uff0c\u4e5f\u4e0d\u6eff\u8db3\u5929\u6578\u6e2c\u8a66\u4e2d\u7684\u4f8b\u5916\uff0c\u800c\u4ee5\u81ea\u5df1\u975e\u7f8e\u570b\u516c\u6c11\u6216\u662f\u7da0\u5361\u6301\u6709\u4eba\u70ba\u7531\uff0c\u4e00\u76f4\u4f7f\u75281040NR\u7533\u5831\uff0c\u986f\u7136\u4e0d\u7b26\u5408\u570b\u7a05\u5c40\u7684\u5b9a\u7fa9\uff0c\u503c\u5f97\u5927\u5bb6\u7559\u610f\u3002 \u6709\u8208\u8da3\u7684\u670b\u53cb\u53ef\u4ee5\u4e0a\u6211\u5011\u4e8b\u52d9\u6240\u7684\u5b98\u7db2www.agapecpa.com\u7372\u5f97\u66f4\u591a\u7684\u7a05\u52d9\u8cc7\u8a0a.\u6216\u662f\u81f4\u96fb\u6211\u5011Cupertino \u7684\u8fa6\u516c\u5ba4408-725-1700. \u611f\u8b1d\u5927\u5bb6\u7684\u6536\u807d\uff0c\u6211\u5011\u4e0b\u671f\u518d\u6703\u3002"}