c\u768421%\u3002\u4f46\u662f\u62dc\u767b\u7684\u589e\u7a05\u8a08\u5283, \u63d0\u8b70\u5c0721%\u63d0\u9ad8\u81f328%\u3002 C \u578b\u516c\u53f8\u7684AMT. \u5728\u5ddd\u666e\u7a05\u6539\u524d\uff0cC\u578b\u516c\u53f8\u662f\u53ef\u80fd\u8981\u4ed8AMT\u7684\uff0c\u4f46\u662f\u57fa\u65bc\u548c\u4e0a\u8ff0\u4e00\u6a23\u7684\u7406\u7531\uff0c\u964d\u4f4e\u7a05\u7387\u4ee5\u589e\u52a0\u56de\u7f8e\u6295\u8cc7\u7684\u5438\u5f15\u529b\uff0c\u5728\u5ddd\u666e\u7a05\u6539\u4e2d\u7648\u9664\u4e86C\u578b\u516c\u53f8\u7684AMT. \u800c\u4e14\u5728\u672c\u5e74\uff082020\uff09\u7684CARES, \u7d13\u56f0\u689d\u6b3e\u4e0b\uff0c\u4e5f\u63d0\u5230\u4e86\u8981\u52a0\u901f\u516c\u53f8AMT credit\u7684\u9000\u56de\u3002\u4f46\u662f\u62dc\u767b\u4e3b\u5f35\u5c0d\u65bc\u6536\u5165\u8d85\u904e$100M\u7684\u516c\u53f8\u7e7c\u7e8c\u5f81\u6536AMT. \u4f46\u662f\u53ef\u4ee5\u7e7c\u7e8c\u5ef6\u7528foreign tax credit \u53caNOL(\u71df\u696d\u6de8\u640d\uff09 \u63a5\u8457\u8ac7\u5230\u7f8e\u570b\u4eba\u6216\u662f\u7f8e\u570b\u516c\u53f8\u5728\u6d77\u5916\u7684\u6295\u8cc7\uff0c\u5728\u9019\u4e00\u9ede\u4e0a\uff0c\u62dc\u767b\u6df1\u53d7\u5ddd\u666e\u4e3b\u7fa9\u7684\u5f71\u97ff\uff0c\u751a\u81f3\u6709\u904e\u4e4b\u800c\u7121\u4e0d\u53ca\u3002\u5176\u4e2d\u5f71\u97ff\u6700\u5927\u7684\u662f\u5f9e\u5ddd\u666e\u7a05\u6539\u958b\u59cb\u7684GILTI tax(Global Intangible Low Tax Income)\u56e0\u70ba\u5728\u5ddd\u666e\u558a\u51fa\u201d\u7f8e\u570b\u512a\u5148\u201d\u7684\u53e3\u865f\u53ca\u7a05\u6539\u4e4b\u524d\uff0c\u7f8e\u570b\u516c\u53f8\u5728\u6d77\u5916\u7684\u6295\u8cc7\u7372\u5229\uff0c\u4e26\u4e0d\u9700\u8981\u7e73\u4ea4\u7f8e\u570b\u7684\u6240\u5f97\u7a05\uff0c\u9664\u975e\u5c07\u7372\u5229\u56de\u6d41\u7f8e\u570b\u3002\u4f46\u662f\u5ddd\u666e\u8981\u63a8\u52d5\u6d77\u5916\u6295\u8cc7\u53ca\u8cc7\u91d1\u56de\u6d41\u7f8e\u570b\uff0c\u800c\u975e\u6eef\u7559\u5728\u4e00\u4e9b\u4f4e\u6240\u5f97\u7a05\u7387\u7684\u5730\u65b9\uff0c\u4f8b\u5982\u611b\u723e\u862d\u6216\u662f\u67d0\u4e9b\u79df\u7a05\u5929\u5802\uff0c\u6240\u4ee5\u63a8\u52d5\u6240\u8b02\u7684GILTI tax. \u800cGILTI tax \u7c21\u55ae\u8b1b\u7684\u610f\u601d\u662f, \u82e5\u662f\u9019\u500b\u7f8e\u570b\u4eba\u6216\u7f8e\u570b\u516c\u53f8\u6240\u6295\u8cc7\u7684\u6d77\u5916\u516c\u53f8\uff0c\u662f\u6240\u8b02\u7684CFC (controlled foreign Corp),(\u5176\u6307\u7684\u662f\u7f8e\u570b\u4eba\u6216\u662f\u7f8e\u570b\u516c\u53f8\u63a7\u80a1\u8d85\u904e\u767e\u5206\u4e4b\u4e94\u5341\uff09\u9019\u6a23\u7684\u8a71\uff0c\u5c31\u7b97\u7372\u5229\u6c92\u6709\u56de\u6d41\u7f8e\u570b\uff0c\u7f8e\u570b\u80a1\u6771\u4ecd\u8981\u6309\u81ea\u5df1\u7684\u6301\u80a1\u6bd4\u4f8b\u4e88\u4ee5\u8ab2\u7a05\u3002\u5176\u7a05\u7387\u70ba21%\uff0c \u4f46\u901a\u904e\u67d0\u4e9b\u62b5\u6e1b\u7a05\u7387\u53ef\u70ba10.5%. \u800c\u4e14\u6709\u6d77\u5916\u56fa\u5b9a\u8cc7\u7684\u62b5\u6e1bQBAI deduction. \u800c\u62dc\u767b\u8981\u7dad\u6301GILTI tax 21%\u7684\u7a05\u7387\uff0c\u800c\u975e\u73fe\u884c\u768410.5%\uff0c\u4e26\u4e14\u5206\u4e0d\u540c\u570b\u5bb6\u6e1b\u5c11QBAI\u7684\u62b5\u6e1b\u3002\u9664\u6b64\u4ee5\u5916\uff0c \u518d\u5c0d\u6d77\u5916\u88fd\u9020\u696d\u53ca\u670d\u52d9\u696d\u8ab2\u4e00\u7a2e\u65b0\u7684\uff0c10%\u7684surtax. \u6240\u4ee5\uff0c\u5c0d\u5916\u5e0c\u671b\u80fd\u7528\u52a0\u7a05\u7684\u65b9\u5f0f\u523a\u6fc0\u6295\u8cc7\u56de\u6d41\u3002 \u7a05\u52d9\u512a\u60e0-A. \u5c0d\u5167\u5247\u796d\u51fa\u7a05\u52d9\u512a\u60e0\uff0c\u52a0\u5f37\u5c0d\u65bc\u88fd\u9020\u696d\u7684\u5438\u5f15\u529b\u3002\u4f8b\u5982\uff0c \u63d0\u51famanufacturing community tax credit, \u88fd\u9020\u696d\u7684\u7a05\u52d9\u512a\u60e0\u3002\u53camade in America \u7f8e\u570b\u88fd\u9020\u7684\u7a05\u52d9\u512a\u60e0\u3002B. \u6b64\u5916\u9084\u8981\u589e\u5f37New market tax credit, [&hellip;]"}