e26\u4e14\u652f\u4ed8\u7684\u5730\u7522\u7a05\u3002\u4f46\u662f\u5ddd\u666e\u7a05\u6539\u62ff\u6389\u4e86\u6d77\u5916\u81ea \u4f4f\u5c4b\u5730\u7a05\u7684\u62b5\u6e1b\u3002\u6b64\u5916\uff0c\u5730\u7a05\u7576\u4e2d\uff0c\u82e5\u542b\u4e86\u7279\u5225\u9805\u76ee(special assessment), \u5982\u623f\u5b50\u4e4b\u7684\u589e\u5efa\uff08improvement\uff09\u4f86\u589e\u52a0\u623f\u5c4b\u50f9\u503c\u7684\uff0c\u57fa\u672c\u4e0a\u4e0d\u80fd\u5728\u9019\u88e1\u62b5\u6e1b\uff0c\u800c\u61c9\u8a72\u7576\u6210\u662f\u623f\u5c4b\u7684\u6210\u672c\u3002\u5982\u679c\u60a8\u652f\u4ed8\u7684\u6309\u63ed\u4e2d\uff0c\u542b\u6709\u5730\u7522\u7a05 \uff0c\u90a3\u60a8\u53ea\u80fd\u6e1b\u9280\u884c\u6216\u662f\u8cb8\u6b3e\u516c\u53f8\u5be6\u969b\u652f\u4ed8\u7684\u5730\u7522\u7a05\u3002\u82e5\u662f\u60a8\u5728\u7576\u5e74\u8ce3\u4e86\u623f\u7522\uff0c\u7531\u8cb7\u65b9\u652f\u4ed8\u7684\u5730\u7522\u7a05\u61c9\u8a72\u505a\u70ba\u8a72\u6b04\u76ee \u7684\u6e1b\u9805\u3002 \u9664\u4e86\u5730\u7522\u7a05\u4e4b\u5916\uff0c\u60a8\u9084\u53ef\u4ee5\u9078\u64c7\u5217\u8209\u52d5\u7522\u6240\u7522\u751f\u7684\u7a05\uff0c\u4f8b\u5982\u6c7d\u8eca\u7684 \u90e8\u5206\u7684\u724c\u7167\u7a05\u3002 \u5728\u5ddd\u666e\u7a05 \u6539\u540e\uff0c\u9019\u500b\u90e8\u5206\u6700\u9ad8\u62b5\u6e1b\u4e0a\u9650\u88ab\u58d3\u7e2e\u70ba\u4e00\u842c\u7f8e\u5143\uff0c\u88ab\u6279\u8a55\u662f\u61f2\u7f70\u6c11\u4e3b\u9ee8\u7684\u85cd\u5dde\uff0c\u56e0\u70ba\u5728\u6771\u897f\u5169\u5cb8\u4e0d\u50c5\u662f\u6240\u5f97\u7a05\u7387\u9ad8\uff0c\u800c\u4e14\u56e0\u70ba\u623f\u50f9\u9ad8\uff0c\u5730\u7522\u7a05\u4e5f\u662f\u4e00\u7b46\u4e0d\u5c0f\u7684\u958b\u92b7\u3002\u4f46\u662f\u6700\u8fd1\u7531\u773e\u8b70\u9662\u901a\u904e\u7684\u6c11\u4e3b\u9ee8\u7a05\u6539\u7248\u672c\uff0c\u8981\u5c07\u9019\u90e8 \u4efd\u63d0\u9ad8\u81f3\u516b\u842c\u7f8e\u5143\uff0c\u4f46\u9084\u6c92\u6709\u6700\u7d42\u7531\u7e3d\u7d71\u7c3d\u7f72\u6210\u70ba\u6cd5\u6848\u3002 \u6709\u8208\u8da3\u7684\u807d\u773e\u53ef\u4ee5\u4e0a\u6211\u5011\u4e8b\u52d9\u6240\u7684\u7db2\u7ad9www.agapecpa.com\u67e5\u770b\u66f4\u591a\u7684\u7a05\u52d9\u8cc7\u8a0a\uff0c\u6216\u662f\u81f4\u96fb\u6211\u5011Cupertino \u7684\u8fa6\u516c\u5ba4408-725-1700\u3002 \u611f\u8b1d\u60a8\u7684\u6536\u807d\uff0c\u4e5f\u5e0c\u671b\u60a8\u559c\u6b61\u6211\u5011\u9019\u671f\u7684\u7bc0\u76ee\uff0c\u6211\u5011\u4e0b\u671f\u518d\u6703\u3002"}