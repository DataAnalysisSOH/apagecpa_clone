u4eba\u52a0\u5169\u5206; \u6709 Schedule C \u505a\u751f\u610f\u7684\u4eba \u52a0\u4e09\u5206; \u6709 Schedule E \u51fa\u79df\u623f\u5c4b\u7684\u4eba\u518d\u52a0\u4e09\u5206\u2026.\u7b49\u7b49\u25e6 \u570b\u7a05\u5c40\u901a\u5e38\u90fd\u6703\u5c07\u7d0d\u7a05\u4eba\u4eca \u5e74\u7684\u7a05\u8868\u548c\u904e\u53bb\u5e7e\u5e74\u505a\u6bd4\u8f03, \u5982\u679c\u4eca\u5e74\u5229\u606f\u6536\u5165\u6bd4\u5f80\u5e74\u9ad8\u51fa\u5f88\u591a, \u5206\u6578\u6703\u518d\u52a0\u5341\u5206\u25e6 \u5982\u679c\u4eca\u5e74\u8ce3\u4e86\u4e00\u5927\u7b46\u516c\u53f8\u80a1\u7968\u537b\u53c8\u6709\u5f88\u591a\u8667\u640d\u76f8\u62b5, \u570b\u7a05\u5c40\u6703\u518d\u52a0\u4e8c\u5341\u5206\u25e6 \u5206\u6578\u8d8a \u9ad8\u7684\u4eba\u8d8a\u6709\u6a5f\u6703\u88ab\u67e5\u7a05\u25e6 (\u4e8c) \u7279\u5b9a\u884c\u696d\u6216 Research \u570b\u7a05\u5c40\u5e38\u5e38\u6703\u9396\u5b9a\u7279\u5b9a\u7684\u5e7e\u7a2e\u884c\u696d\u9032\u884c\u7a3d\u67e5, Research \u7d50\u679c\u505a\u70ba\u65e5\u5f8c\u67e5\u7a05\u7684\u53c3\u8003\u4f9d \u64da\u25e6 \u4f8b\u5982: \u570b\u7a05\u5c40\u6c7a\u5b9a\u7279\u5225\u67e5\u623f\u5730\u7522\u696d, \u4e86\u89e3\u623f\u5730\u7522\u7d93\u7d00\u5728\u5404\u9805\u652f\u51fa\u7684\u6bd4\u4f8b\u25e6 [&hellip;]"}