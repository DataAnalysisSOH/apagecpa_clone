u6cd5\u7684\u91d1\u878d\u6d3b\u52d5\u3002 \u7533\u5831\u7684\u622a\u6b62\u65e5\u5206\u6210\u65e2\u6709\u7684\u516c\u53f8\u8207\u65b0\u6210\u7acb\u7684\u516c\u53f8\u5169\u5927\u985e\u3002\u65e2\u6709\u7684\u516c\u53f8\u6307\u7684\u662f\u57281\/1\/2024\u5e74\u524d\u6210\u7acb\u7684\u516c\u53f8\uff0c\u5176\u7533\u5831\u622a\u6b62\u65e5\u70ba1\/1\/2025\u3002\u800c\u65b0\u6210\u7acb\u7684\u516c\u53f8\uff0c\u6307\u7684\u662f\u57282024\u5e74\u6210\u7acb\u7684\u516c\u53f8\uff0c\u5176\u7533\u5831\u622a\u6b62\u65e5\u70ba\u516c\u53f8\u6709\u6548\u6210\u7acb\u768490\u5929\u5167\u3002\u82e5\u662f\u6545\u610f\u9055\u53cdBOI\u7684\u7533\u5831\uff0c\u6c11\u4e8b\u4e0a\u7684\u7f70\u6b3e\u6700\u9ad8\u70ba\u6bcf\u5929\u4e94\u767e\u7f8e\u5143\u3002\u800c\u5211\u4e8b\u4e0a\u7684\u7f70\u5247\u53ef\u5224\u9ad8\u9054\u5169\u5e74\u7684\u76e3\u7981\uff0c\u53ca\/\u6216\u4e00\u842c\u7f8e\u5143\u7684\u7f70\u6b3e\u3002 \u9700\u8981\u7533\u5831\u516c\u53f8\u7684\u7bc4\u570d\u5305\u62ec\u4e86\u5728\u7f8e\u570b\u8a3b\u518a\u7684\u516c\u53f8(corporation)\u53ca\u6709\u9650\u8cac\u4efb\u516c\u53f8(LLC)\u53ca\u5728\u7f8e\u570b\u4efb\u4f55\u4e00\u5dde\u6216\u662f\u5370\u5730\u5b89\u4fdd\u7559\u5340\u8a3b\u518a\u767b\u8a18\u5728\u7f8e\u570b\u505a\u751f\u610f\u7684\u5916\u570b\u516c\u53f8\u3002\u4f46\u662f\u5728\u7533\u5831\u7684\u8aaa\u660e\u7576\u4e2d\uff0c\u5217\u51fa\u4e8623\u7a2e\u4f8b\u5916\u7684\u60c5\u6cc1\uff0c\u5305\u62ec\u4e86\u91d1\u878d\u4fdd\u96aa\u696d\uff0c\u516c\u958b\u767c\u884c\u516c\u53f8\u53ca\u975e\u725f\u5229\u7d44\u7e54\u7b49\u7b49\u3002\u7533\u5831\u7684\u65b9\u6cd5\u70ba\u96fb\u5b50\u7533\u5831\u3002\u8acb\u9020\u8a2awww.fincen.gov\/boi. \u7533\u5831\u6642\u4e5f\u8acb\u5148\u5099\u59a5\u7f8e\u570b\u99d5\u7167\u6216\u662f\u8b77\u7167\u7b49\u8eab\u4efd\u8b49\u660e\u6587\u4ef6\u3002 \u4ee5\u4e0a\u4fbf\u662f\u672c\u671f\u7bc0\u76ee\u7684\u5168\u90e8\u5167\u5bb9\uff0c\u611f\u8b1d\u5927\u5bb6\u7684\u6536\u807d\uff0c\u6211\u5011\u4e0b\u671f\u7bc0\u76ee\u518d\u6703\u3002"}