\u6d77\u5916\u91d1\u878d\u5e33\u6236\u7684\u7533\u5831\uff0c\u623f\u5730\u7522\u4e0d\u5728\u9019\u5f35\u8868\u683c\u7684\u7533\u5831\u7bc4\u570d\u3002\u800c\u6d77\u5916\u91d1\u878d\u5e33\u6236\u5305\u62ec\u4e86\u73fe\u91d1\uff0c\u6709\u50f9\u8b49\u5238\u53ca\u4eba\u58fd\u4fdd\u96aa\u3002\u6b64\u5916\uff0c\u82e5\u662f\u7d0d\u7a05\u4eba\u6709\u6d77\u5916\u516c\u53f8\u9280\u884c\u7684\u7684\u7c3d\u5b57\u6b0a\uff0c\u5c31\u7b97\u6c92\u6709\u9280\u884c\u7684\u6240\u6709\u6b0a\uff0c\u9019\u4e9b\u8a0a\u606f\u4e5f\u8981\u63ed\u9732\u5728\u8868\u683c114\u4e2d\u3002\u82e5\u662f\u800c\u5f88\u591a\u4eba\u7684\u7406\u89e3\uff0c\u50c5\u50c5\u662f\u505c\u7559\u5728\u73fe\u91d1\u8d85\u904e\u4e00\u842c\u7f8e\u91d1\u624d\u8981\u7533\u5831\u3002\u800c\u7533\u5831\u4e00\u842c\u7f8e\u5143\u7684\u9580\u6abb\uff0c\u6307\u7684\u4e0d\u662f\u55ae\u4e00\u9280\u884c\u5e33\u6236\u8d85\u904e\u4e00\u842c\u7f8e\u5143\u624d\u8981\u7533\u5831\uff0c\u5176\u6307\u7684\u662faggregate amount, \u5373\u5404\u91d1\u878d\u5e33\u6236\u8a72\u5e74\u6700\u9ad8\u9ede\u7684\u52a0\u7e3d\u6578\u8d85\u904e\u4e00\u842c\u7f8e\u5143\u8005\uff0c\u5247\u6bcf\u4e00\u500b\u5e33\u6236\u90fd\u7533\u5831\u3002\u4f8b\u5982\uff0c\u6211\u5728\u53f0\u7063\u6709\u4e09\u500b\u9280\u884c\u5e33\u6236\uff0c\u5176\u8a72\u5e74\u6700\u9ad8\u9ede\u9918\u984d\u5206\u5225\u70ba$3000\uff0c $4000\u53ca$5000\uff0c \u96d6\u7136\u500b\u5225\u5e33\u6236\u90fd\u4e0d\u8d85\u904e\u4e00\u842c\u7f8e\u5143\uff0c\u4f46\u662f\u52a0\u7e3d\u6578\u5b57\u8d85\u904e\u4e86\u4e00\u842c\u7f8e\u5143\uff0c\u65bc\u662f\u9019\u4e09\u500b \u5e33\u6236\u90fd\u9700\u8981\u7533\u5831\u3002 \u6709\u7684\u4eba\u6703\u64d4\u5fc3\u570b\u7a05\u5c40\u6703\u7528\u9019\u5f35\u8868\u683c\u4f86\u8a08\u7b97\u7a05\uff0c\u4f46\u662f\u9019\u5f35\u8868\u662finformation return, \u4e0d\u662f\u6240\u5f97\u7a05\u7684\u8a08\u7b97\uff0c\u4f46\u662f\u9019\u5f35\u8868\u53ef\u4ee5\u63d0\u4f9b\u4e00\u500b\u4ea4\u4e92\u7a3d\u6838\u7684\u57fa\u790e\u3002 \u6c92\u6709\u7533\u5831\u6216\u662f\u6f0f\u5831\u9019\u5f35\u8868\uff0c\u6709\u53ef\u80fd\u5f15\u8d77\u56b4\u91cd\u7684\u5f8c\u679c\u3002\u5c31\u6c11\u4e8b\u65b9\u9762\uff0c\u570b\u7a05\u5c40\u53ef\u4ee5\u6bcf\u4e00\u5e74\u7f70\u6f0f\u5831\u7684\u5e33\u6236\u4e00\u5e74\u4e00\u842c\u5143\u6216\u5176\u6700\u9ad8\u9ede\u7684\u767e\u5206\u4e4b\u4e94\u5341\u3002\u8981\u7559\u610f\u6c92\u6709\u7533\u5831\u904e\u7684\u6771\u897f\u6c92\u6709\u8ffd\u6eaf\u671f\u7684\u9650\u5236\u3002\u5927\u5bb6\u8981\u8b39\u614e\u8655\u7406\u3002 \u6709\u8208\u8da3\u7684\u807d\u773e\uff0c\u53ef\u4e0a\u6211\u5011\u4e8b\u52d9\u6240\u7684\u7db2\u7ad9\u7372\u5f97\u66f4\u591a\u7684\u7a05\u52d9\u8cc7\u8a0a\u3002www.agapecpa.com \u6216\u81f4\u96fb\u6211\u5011Cupertino \u7684\u8fa6\u516c\u5ba4\uff0c 408-725-1700\u3002 \u611f\u8b1d\u5927\u5bb6\u7684\u6536\u807d\u3002\u6211\u5011\u4e0b\u671f\u518d\u6703\u3002"}