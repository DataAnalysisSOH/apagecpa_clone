\u5b63\u5ea6\u964d\u4f4e\u81f3\u5c11\u767e\u5206\u4e4b\u4e8c\u5341\u4e94\u4ee5\u4e0a\u3002\uff08\u57282021\u5e74\u958b\u59cb\u7533\u8acb\u7684\u7533\u8acb\u8005\uff0c\u53ef\u4ee5\u75282020\u7684\u7b2c\u56db\u5b63\u5ea6\u505a\u70ba\u8a55\u4f30\u7684\u57fa\u790e\uff09\u3002 \u975e\u71df\u5229\u7d44\u7e54\u4e5f\u53ef\u53c3\u52a0\u7533\u8acb\u3002 \u800c\u7533\u8acbPPP loan\u7684\u984d\u5ea6\u53ef\u7528 \u7533\u8acb\u8cb8\u6b3e\u7684\u524d\u4e00\u5e74\u5ea6\uff082020\uff09\u5e74\uff0c\u6216\u662f 2019\u5e74\u7684\u5e73\u5747\u6708\u85aa\u8cc7\u76842.5\u500d\u3002\u4f46\u82e5\u662f\u7533\u8acb\u8005\u70ba\u65c5\u9928\u6216\u9910\u98f2\u696d\uff0c\u5247\u662f\u5e73\u5747\u6708\u85aa\u8cc7\u7684\u4e09\u9ede\u4e94\u500d\u3002\u800c\u8207\u7b2c\u4e00\u8f2a\u4e0d\u540c\u7684\u662f\uff0c\u6700\u9ad8\u7684\u8cb8\u6b3e\u91d1\u984d\u7531\u539f\u5148\u7684\u4e00\u5343\u842c\u7f8e\u5143\uff0c\u964d\u4f4e\u81f3\u4e8c\u767e\u842c\u7f8e\u5143\u3002 \u800c\u76ee\u524dSBA\u9084\u6c92\u6709\u767c\u4f48\u7b2c\u4e8c\u8f2aPPP\u7684\u5be6\u884c\u7d30\u5247\uff0c\u7406\u8ad6\u4e0aSBA\u61c9\u8a72\u5728\u6cd5\u6848\u516c\u4f48\u7684\u5341\u5929\u5167\u767c\u8868\uff0c\u6211\u5011\u5c07\u6703\u8ddf\u9032\uff0c\u5e36\u7d66\u8b80\u8005\u9032\u4e00\u6b65\u7684\u8a0a\u606f\u3002 \u6797\u61ff\u6703\u8a08\u5e2b 12\/28\/20 Cupertino"}