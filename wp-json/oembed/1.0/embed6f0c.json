3d6\u5f97\u7684\uff0c\u61c9\u8a72\u548c\u7f8e\u570b\u6c92\u6709\u95dc\u4fc2\u561b\u3002\u4f46\u662f\u7f8e\u570b\u570b\u7a05\u5c40\u7684\u898f\u5b9a\u537b\u662f\uff0c\u53ea\u8981\u5728\u6210\u70ba\u7a05\u52d9\u5c45\u6c11\u4e4b\u5f8c\u6240\u8655\u5206\u7684\u8cc7\u7522\uff0c\u90fd\u53ef\u80fd\u7522\u751f\u8cc7\u672c\u5229\u5f97\u7a05\u3002\u4f8b\u5982\uff0c\u6211\u8ce3\u4e86\u4e00\u68df\u4e0a\u6d77\u7684\u623f\u5b50\uff0c\u56e0\u70ba\u6211\u662f\u7f8e\u570b\u516c\u6c11\uff0c\u5373\u6240\u8b02\u7684\u7a05\u52d9\u5c45\u6c11\uff0c\u5247\u5176\u7522\u751f\u7684\u8cc7\u672c\u5229\u5f97\uff0c\u8981\u7533\u5831\u5728\u6211\u500b\u4eba\u7a05\u8868\u7684schedule D\u4e0a\u3002 2\uff0c\u6d77\u5916\u91d1\u878d\u5e33\u6236\u7684\u7533\u5831\u3002\u6211\u5011\u5728\u524d\u671f\u7684\u7bc0\u76ee\u7576\u4e2d\uff0c\u66fe\u7d93\u4ecb\u7d39\u904e\u4e00\u4e9b\u6d77\u5916\u91d1\u878d\u5e33\u6236\u7684\u7533\u5831\u8981\u9ede\u3002\u6d77\u5916\u91d1\u878d\u5e33\u6236\u7684\u7533\u5831\u5c0d\u65bc\u65b0\u79fb\u6c11\u4e5f\u975e\u5e38\u91cd\u8981\u3002\u56e0\u70ba\u6709\u4e00\u4e9b\u4eba\u6703\u51fa\u552e\u5883\u5916\u7684\u8cc7\u7522\uff0c\u518d\u6ed9\u56de\u7f8e\u570b\u8cb7\u623f\u5b50\u3002\u5982\u679c\u4e4b\u524d\u4e26\u6c92\u6709\u63ed\u9732\u904e\u6d77\u5916\u91d1\u878d\u5e33\u6236\uff0c\u53c8\u7a81\u7136\u5929\u5916\u98db\u4f86\u4e00\u7b46\u9245\u6b3e\uff0c\u6703\u986f\u5f97\u7121\u6cd5\u81ea\u5713\u5176\u8aaa\u3002 3\uff0c \u89aa\u5c6c\u4e4b\u9593\u7684\u623f\u5730\u7522\u4ea4\u6613\u3002\u56e0\u70ba\u6df1\u53d7\u5230\u6709\u571f\u65af\u6709\u8ca1\u7684\u89c0\u5ff5\u6240\u5f71\u97ff\uff0c\u623f\u5730\u7522\u4e00\u76f4\u662f\u6211\u5011\u83ef\u4eba\u7684\u5fc3\u982d\u597d\u3002\u518d\u52a0\u4e0a\u6211\u5011\u83ef\u4eba\u5bb6\u5ead\u6210\u54e1\u4e4b\u9593\u7684\u95dc\u4fc2\u7dca\u5bc6\uff0c\u6240\u4ee5\u6709\u5f88\u591a\u89aa\u5c6c\u4e4b\u9593\u7684\u5730\u7522\u4ea4\u6613\u3002\u4f46\u662f\u503c\u5f97\u6ce8\u610f\u7684\u662f\uff0c\u56e0\u70ba\u89aa\u5c6c\u4e4b\u9593\u7684\u79fb\u6c11\u8eab\u5206\u5404\u6709\u4e0d\u540c\uff0c\u6240\u4ee5\u8868\u683c3520\u6216\u662f\u73fe\u884c\u7684\u4e00\u5343\u5169\u767e\u4e5d\u5341\u4e8c\u842c\u7684\u7d42\u8eab\u514d\u7a05\u984d\uff0c\u5176\u5be6\u4e26\u4e0d\u662f\u9069\u7528\u65bc\u6bcf\u500b\u4eba\u6216\u662f\u6bcf\u7a2e\u60c5\u5f62\u3002\u6240\u4ee5\u4f7f\u7528\u6642\u8981\u614e\u91cd\u3002 4\uff0c\u77ad\u89e3\u591a\u7a2e\u7684\u91d1\u878d\u5de5\u5177\u53ca\u5176\u76f8\u95dc\u7684\u79df\u7a05\u5f71\u97ff\u3002\u56e0\u70ba\u6211\u5011\u83ef\u4eba\u5728\u9032\u884c\u6295\u8cc7\u7684\u6642\u5019\uff0c\u4e00\u822c\u6703\u8457\u91cd\u5728\u80a1\u7968\u53ca\u623f\u5730\u7522\u4e0a\u3002\u800c\u80a1\u5e02\u6ce2\u6fe4\u6d36\u6e67\uff0c\u6563\u6236\u78ba\u5be6\u6bd4\u8f03\u96e3\u6bba\u51fa\u91cd\u570d\u3002\u5411\u89aa\u53cb\u501f\u9322\u7092\u80a1\u90fd\u8ce0\u5149\u7684\u4e5f\u5c62\u898b\u4e0d\u9bae\u3002\u5012\u4e0d\u662f\u6295\u8cc7\u80a1\u5e02\u4e0d\u5c0d\uff0c\u800c\u662f\u53ef\u4ee5\u591a\u77ad\u89e3\u4e00\u4e9b\u91d1\u878d\u5de5\u5177\uff0c\u5305\u62ec\u6709\u90a3\u4e00\u4e9b\u514d\u7a05\u7684\u6295\u8cc7\uff0c\u4f8b\u5982Roth IRA\u53ca529\u6559\u80b2\u57fa\u91d1\u7b49\uff0c\u9054\u5230\u5206\u6563\u6295\u8cc7\u98a8\u96aa\u7684\u76ee\u7684\u3002 5, \u7a4d\u6975\u7684\u6eb6\u5165\u7f8e\u570b\u793e\u6703\uff0c\u8cfa\u53d6\u52de\u52d9\u6240\u5f97\uff0c\u7a4d\u7d2f\u793e\u6703\u5b89\u5168\u91d1\u53ca\u5065\u5eb7\u4fdd\u96aa\u7684\u3e03\u6578\u3002\u9019\ud855\ude83\u6709\u4e00\u500b\u7406\u89e3\u4e0a\u7684\u8aa4\u5340\uff0c\u5c31\u662f\u4e0d\u662f\u6240\u6709\u7684\u6240\u5f97\u90fd\u662f\u52de\u52d9\u6240\u5f97\uff0c\u800c\u53ea\u6709\u52de\u52d9\u6240\u5f97\u53ef\u4ee5\u7d2f\u7a4d\u793e\u6703\u5b89\u5168\u91d1\u7684\u9ede\u6578\u3002\u57282023\u5e74\uff0c\u4e00\u9ede\u70ba$1,640, \u56db\u9ede\u70ba$6,560\u3002\u800c\u8cfa\u53d6\u52de\u52d9\u6240\u5f97\u53ef\u4ee5\u901a\u904e\u5916\u51fa\u6253\u5de5\uff0c\u81ea\u50f1\u4eba\u58eb\u6216\u662f\u958b\u8a2d\u516c\u53f8\u7b49\u8fa6\u6cd5\u53d6\u5f97\u3002\u5728\u5be6\u52d9\u64cd\u4f5c\u4e0a\u56e0\u70ba\u770b\u5230\u6709\u8a31\u591a\u7684\u65b0\u79fb\u6c11\u56e0\u70ba\u4e0d\u7406\u89e3\u9019\u9805\u898f\u5b9a\u800c\u767d\u767d\u6d6a\u8cbb\u4e86\u8a31\u591a\u6642\u9593\u3002 \u4ee5\u4e0a\u5c31\u662f\u672c\u671f\u7bc0\u76ee\u7684\u5168\u90e8\u5167\u5bb9\u3002\u5e0c\u671b\u80fd\u5c0d\u60a8\u6709\u5e6b\u52a9\u3002\u6211\u5011\u4e0b\u671f\u7bc0\u76ee\u518d\u898b\u3002"}