c0d\u6240\u8b02\u7684pass through entities\u7d66\u51fa\u5408\u683c\u6240\u5f97\u768420%\u505a\u70ba\u5176\u8ab2\u7a05\u6240\u5f97\u7684\u62b5\u6e1b\u9805\u3002\u4f46\u662f\u5927\u9ad4\u4e0a\u5176&#8221;\u8abf\u6574\u6240\u5f97&#8221;AGI, \u5728\u592b\u59bb\u5408\u5831\u7684\u72c0\u6cc1\u4e0b\uff0c\u5118\u91cf\u4e0d\u8981\u8d85\u904e$315,000\u3002\u6240\u4ee5\uff0c\u505a\u751f\u610f\u7684\u670b\u53cb\uff0c\u82e5\u662f\u60f3\u8981\u5f97\u5230\u6b64\u9805\u6263\u9664\u984d\uff0c\u8981\u63a7\u5236\u6240\u5f97\u5118\u91cf\u4e0d\u8981\u8d85\u904e\u9019\u500b\u6578\u5b57\u3002\u800c\u8981\u5982\u4f55\u9054\u6210\u9019\u500b\u76ee\u6a19\uff1f\u7c21\u800c\u8a00\u4e4b\u5728\u65bc\u4e8c\u65b9\u9762\uff1b\u4e00\u65b9\u9762\u662f\u905e\u5ef6\u6240\u5f97\uff0c\u53e6\u4e00\u65b9\u9762\u662f\u64f4\u5927\u6216\u662f\u52a0\u901f\u652f\u51fa\u3002 \u5728\u905e\u5ef6\u6240\u5f97\u65b9\u9762\uff0c\u53ef\u4ee5\u8003\u616e\u6700\u5927\u5316\u9000\u4f11\u91d1\u7684\u6295\u5165(\u4f8b\u5982401k\u53caSEP IRA \u7b49\u7b49\uff09\u3002\u5c0d\u65bc\u6703\u8a08\u57fa\u790e\u9078\u7528\u73fe\u91d1\u57fa\u790e\u7684\u670b\u53cb\u5011\uff0c\u53ef\u4ee5\u8003\u616e\u63a8\u9072\u6240\u5f97\u5230\u660e\u5e74\u3002\u4f46\u662f\u82e5\u662f\u652f\u7968\u4e0a\u7684\u65e5\u671f\u662f\u572812\/31\/2018\u5e74\u4e4b\u524d\uff0c\u5373\u4f7f\u662f\u57282019\u5e74\u5b58\u5165\uff0c\u4ecd\u7136\u7b97\u70ba\u662f2018\u7684\u6240\u5f97\u3002 \u5728\u64f4\u5927\u652f\u51fa\u65b9\u9762\uff0c\u53ef\u4ee5\u8003\u616e\u8d81\u5e74\u5e95\u4e4b\u524d\u8cfc\u5165\u65b0\u7684\u56fa\u5b9a\u8cc7\u7522\uff0c\u5728\u672c\u6b21\u7684\u7a05\u6539\u4e4b\u4e0b\uff0c\u4e0d\u4f46section 179\u7684\u7bc4\u570d\u653e\u5bdb\uff0c\u7b2c\u4e00\u5e74\u7684\u7d05\u5229\u6298\u820a(bonus depreciation)\u4e5f\u5728\u7a05\u6539\u4e0b\u7531\u5148\u524d\u768450%\u5230100%\u3002 \u8003\u616e2018\u5e74\u7684\u9810\u7e73\u7a05\u662f\u5426\u8db3\u5920\uff1f \u8003\u616e\u662f\u5426\u57282018\u5e74\u5e74\u5e95\u524d\u505a\u4e00\u4e9b\u6148\u5584\u6350\u6b3e\u3002\u56e0\u70ba\u57282018\u81f32025\u5e74\uff0c\u6350\u6b3e\u7d66\u516c\u773e\u6148\u5584\u6a5f\u69cb\uff08public charity) \u7684\u62b5\u6e1b\u91d1\u984d\u7531\u539f\u5148\u768450%AGI\u63d0\u9ad8\u81f360%AGI\u3002 \u67fb\u770b\u80a1\u7968\u7684portfolio \u3002\u770b\u6709\u591a\u5c11\u5df2\u7d93\u5be6\u73fe\u7684\u8cc7\u672c\u5229\u5f97\uff0c\u5728\u770b\u770b\u6709\u6c92\u6709\u4e00\u4e9b\u4e0d\u559c\u6b61\u800c\u4e14\u6b63\u5728\u8667\u640d\u7684\u80a1\u7968\u5728\u5e74\u5e95\u4e4b\u524d\u8655\u4efd\u6389,\u56e0\u70ba\u552e\u80a1\u7968\u7684\u8cc7\u672c\u640d\u5931\uff0c\u53ef\u8207\u5176\u5b83\u7684\u8cc7\u672c\u5229\u5f97\u4e92\u76f8\u7684\u51b2\u92b7\u6389\u3002 \u800c\u5728\u9019\u4e00\u6b21\u7684\u7a05\u6539\u4e2d\uff0c\u9664\u4e86\u4e0a\u8ff0\u7684\u65b9\u6cd5\u4ee5\u53ca\u6d41\u884c\u76841031\u4ea4\u63db\u4e4b\u5916\uff0c\u9084\u63d0\u51fa\u4f86\u4e00\u500b\u905e\u5ef6\u8cc7\u672c\u5229\u5f97\u7684\u65b9\u6cd5: \u5c31\u662f\u5728\u8ce3\u6389\u7522\u751f\u8cc7\u672c\u5229\u5f97\u7684\u516d\u500b\u6708\u5167\u8f49\u6295\u8cc7\u4e00\u4e9b\u8981\u88ab\u767c\u5c55\u7684\u5730\u5340(opportunity zone), \u9019\u6a23\u53ef\u4ee5\u905e\u5ef6\u6b64\u8cc7\u672c\u5229\u5f97\u76f4\u5230\u51fa\u552e\u6b64\u4e00\u6295\u8cc7\u6216\u662f\u76f4\u523012\/31\/2026\u3002\u6211\u5011\u5c07\u6703\u6709\u5c08\u6587\u8a0e\u8ad6\u6295\u8cc7\u65bc&#8221;\u6a5f\u6703\u5730\u5340&#8221;(opportunity zones)\u7684\u7a05\u52d9\u8655\u7406\u3002 \u2013 \u611b\u52a0\u500d\u6703\u8a08\u5e2b\u4e8b\u52d9\u6240 \u7248\u6b0a\u6240\u6709\uff0c\u7981\u6b62\u8f49\u8f09 \u2013"}