\u8b77\u4ed6\u5011\u514d\u53d7\u5e38\u898b\u7a05\u52d9\u9a19\u5c40\u548c\u9670\u8b00\u7684\u4fb5\u5bb3\u3002\u800c\u6211\u4e5f\u5e0c\u671b\u672c\u7bc0\u76ee\u7684\u807d\u773e\uff0c\u901a\u904e\u672c\u7bc0\u76ee,\u53ef\u4ee5\u610f\u8b58\u5230\u6700\u8fd1\u5e38\u898b\u7684\u7a05\u52d9\u9a19\u5c40\uff0c\u5118\u53ef\u80fd\u7684\u907f\u514d\u6210\u70ba\u4e0b\u4e00\u500b\u53d7\u5bb3\u8005\u3002 \u5728\u4eca\u5e74\uff0c2024\u5e74\u7684\u4e09\u6708\u570b\u7a05\u5c40\u555f\u52d5\u4e86\u5e74\u5ea6\uff08\u9aaf\u9ad2\u7684\u5341\u4e8c\u689d\u9a19\u8853\uff09\u9ed1\u540d\u55ae\u3002\u5176\u4e2d\u7684\u4e00\u689d\u662f\u95dc\u65bc\u7db2\u8def\u91e3\u9b5a\u6216\u7c21\u8a0a\u8a50\u9a19\u3002\u9019\u4e9b\u9a19\u5c40\u901a\u5e38\u5728\u5831\u7a05\u5b63\u5230\u9054\u9ad8\u5cf0\uff0c\u4f46\u5168\u5e74\u90fd\u6703\u6301\u7e8c\u3002 \u7db2\u8def\u91e3\u9b5a\u6307\u7684\u662f\u8a50\u9a19\u8005\u767c\u9001\u7684\u96fb\u5b50\u90f5\u4ef6\u8072\u7a31\u662f\u4f86\u81ea\u570b\u7a05\u5c40\u3002\u96fb\u5b50\u90f5\u4ef6\u4ee5\u5404\u7a2e\u8a6d\u8a08\u5f15\u8a98\u53d7\u5bb3\u8005\u4e0a\u7576\uff0c\u4f8b\u5982\u4ee5\u865b\u5047\u9000\u7a05\u8a98\u9a19\u53d7\u5bb3\u8005\uff0c\u6216\u4ee5\u865b\u5047\u7684\u7a05\u52d9\u6b3a\u8a50\u6cd5\u5f8b\u6216\u5211\u4e8b\u6307\u63a7\u4f86\u52a0\u4ee5\u5a01\u8105\u3002 \u800c\u7c21\u8a0a\u8a50\u9a19\u6307\u7684\u662f\u5728\u7c21\u8a0a\u6216\u667a\u6167\u578b\u624b\u6a5f\u7c21\u8a0a\u4e2d\uff0c\u9a19\u5b50\u901a\u5e38\u6703\u4f7f\u7528\u201c\u60a8\u7684\u5e33\u6236\u5df2\u88ab\u66ab\u505c\u201d\u6216\u201c\u7570\u5e38\u6d3b\u52d5\u5831\u544a\u201d\u7b49\u5687\u552c\u4eba\u7684\u5b57\u773c\uff0c\u4e26\u4e14\u9644\u4e0a\u4e00\u500b\u865b\u5047\u7684\u89e3\u6c7a\u65b9\u6848\u93c8\u63a5\u4f86\u5e6b\u6536\u4ef6\u4eba\u6062\u5fa9\u5e33\u6236\u3002\u610f\u5916\u9000\u7a05\u662f\u9a19\u5b50\u5011\u4f7f\u7528\u7684\u53e6\u4e00\u500b\u6ff3\u5728\u7684\u8a98\u60d1\u3002 \u56e0\u70ba\u570b\u7a05\u5c40\u5927\u591a\u900f\u904e\u666e\u901a\u4fe1\u4ef6\u8207\u7d0d\u7a05\u4eba\u53d6\u5f97\u806f\u7e6b\uff0c\u7d55\u4e0d\u6703\u900f\u904e\u96fb\u5b50\u90f5\u4ef6\u3001\u7c21\u8a0a\u6216\u793e\u7fa4\u5a92\u9ad4\u8207\u7d0d\u7a05\u4eba\u5c31\u5e33\u55ae\u6216\u9000\u7a05\u4e8b\u5b9c\u9032\u884c\u806f\u7e6b\u3002 \u6240\u4ee5\uff0c\u5982\u679c\u7d0d\u7a05\u4eba\u6536\u5230\u81ea\u7a31\u4f86\u81ea\u570b\u7a05\u5c40\u7684\u96fb\u5b50\u90f5\u4ef6\uff0c\u5176\u4e2d\u8981\u6c42\u63d0\u4f9b\u500b\u4eba\u8cc7\u8a0a\u8207\u5927\u984d\u6295\u8cc7, \u907a\u7522\u7d99\u627f\u6216\u5f69\u7968\u76f8\u95dc\u7684\u7a05\u6b3e\uff0c\u8acb\u4e0d\u8981\u56de\u8986\uff0c\u4e0d\u8981\u6253\u958b\u4efb\u4f55\u9644\u4ef6\u3002\u5b83\u5011\u53ef\u80fd\u5305\u542b\u60e1\u610f\u7a0b\u5f0f\u78bc\uff0c\u53ef\u80fd\u6703\u611f\u67d3\u96fb\u8166\u6216\u624b\u6a5f\u3002\u4e0d\u8981\u9ede\u64ca\u4efb\u4f55\u9023\u7d50\u3002\u5982\u679c\u7d0d\u7a05\u4eba\u9ede\u64ca\u53ef\u7591\u77ed\u4fe1\u4e2d\u7684\u9023\u7d50\u4e26\u8f38\u5165\u4e86\u6a5f\u5bc6\u4fe1\u606f\uff0c\u8acb\u8a2a\u554f\u570b\u7a05\u5c40\u7684\u8eab\u4efd\u4fdd\u8b77\u7db2\u9801\u3002\u4e26\u8acb\u5c07\u5b8c\u6574\u7684\u96fb\u5b50\u90f5\u4ef6\u539f\u5c01\u4e0d\u52d5\u7684\u8f49\u767c\u81f3phishing@irs.gov \u4ee5\u4e0a\u4fbf\u662f\u672c\u671f\u7bc0\u76ee\u7684\u5168\u90e8\u5167\u5bb9\u3002\u5e0c\u671b\u5927\u5bb6\u90fd\u80fd\u63d0\u9ad8\u8b66\u89ba\uff0c\u4e0d\u6703\u6210\u70ba\u4e0b\u4e00\u500b\u53d7\u5bb3\u8005\u3002\u611f\u8b1d\u5927\u5bb6\u7684\u6536\u807d\uff0c\u6211\u5011\u4e0b\u671f\u7bc0\u76ee\u518d\u6703\u3002"}