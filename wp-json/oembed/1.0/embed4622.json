c7\u7522\u6301\u6709\u5728\u4e00\u5e74\u4e4b\u5167\uff0c\u5176\u7a05\u7387\u8207\u4e00\u822c\u6b63\u5e38\u6240\u5f97\u76f8\u540c\uff0c\u6307\u7684\u662f\u7528\u4e00\u822c\u7684\u7d2f\u9032\u7a05\u7387\u4e88\u4ee5\u8ab2\u7a05\u3002\u800c\u9577\u671f\u8cc7\u672c\u5229\u5f97\uff0c\u6307\u7684\u662f\u8cc7\u7522\u6301\u6709\u8d85\u904e\u4e00\u5e74\u4ee5\u4e0a\u7684\uff0c\u9069\u7528\u65bc\u512a\u60e0\u7684\u7a05\u7387\u3002\u57fa\u672c\u4e0a\u5206\u62100%\uff0c15%\u820720%\u4e09\u500b\u7a05\u7d1a\u3002\u4ee52020\u5e74\u4f86\u8aac\uff0c\u592b\u59bb\u5408\u4f75\u7533\u5831\u7684\u8ab2\u7a05\u6240\u5f97\u5728$80\uff0c000\u4ee5\u4e0b\u7684\uff0c\u9069\u75280%\uff0c \u5728$80\uff0c000\u81f3$496\uff0c600\u9069\u752815%\u7684\u7a05\u7d1a\uff0c\u800c\u8d85\u904e\u7684\u90e8\u4efd\uff0c\u5247\u70ba20%\u7684\u7a05\u7d1a\u3002\u9664\u6b64\u4e4b\u5916\uff0c\u592b\u59bb\u5408\u4f75\u7533\u5831\u82e5\u662f\u8abf\u6574\u6240\u5f97\u5728$250\uff0c000\u4ee5\u4e0a\uff0c\u5247\u53e6\u5916\u6703\u67093.8%\u7684\u6295\u8cc7\u7a05\uff08investment tax)\u6240\u4ee5\uff0c\u91dd\u5c0d\u9019\u500b\u90e8\u5206\uff0c\u57fa\u790e\u7684\u7a05\u52d9\u898f\u5283\u7684\u6982\u5ff5\u662f\u6536\u76ca\u5118\u5728\u7a05\u7387\u4f4e\u7684\u6642\u5019\u5be6\u73fe\uff0c\u6216\u662f\u7a05\u7387\u5118\u53ef\u80fd\u7531\u9ad8\u5f80\u4f4e\u79fb\u52d5\u3002\u800c\u5177\u9ad4\u7684\u5be6\u884c\u662f\u5728\u5e74\u672b\u7684\u6642\u5019\uff0c\u62ff\u51fa\u81ea\u5df1\u7684\u6295\u8cc7\u8cc7\u6599, \u5be9\u8996\u4e00\u4e0b\u662f\u5426\u8ce3\u51fa\u67d0\u4e9b\u8cc7\u7522\uff0c\u4f86\u7372\u5f97\u6700\u4f73\u7684\u7a05\u52d9\u5229\u76ca\u3002\u7576\u7136\u6211\u5011\u5fc5\u9808\u8981\u63d0\u9192\u5927\u5bb6\uff0c\u7701\u7a05\u4e0d\u662f\u552f\u4e00\u7684\u8003\u91cf\uff0c\u6295\u8cc7\u6536\u76ca\u7684\u90e8\u5206\uff0c\u53ef\u80fd\u66f4\u70ba\u91cd\u8981\u3002 \u6211\u5011\u4e0b\u9762\u5c31\u8209\u4f8b\u5b50\u4f9b\u5927\u5bb6\u53c3\u8003\uff1a \u592b\u5a66\u4e8c\u4eba\u57282020\u5e74\u6709\u516d\u842c\u5143\u7684\u8ab2\u7a05\u6240\u5f97\u53ca\u9577\u671f\u8cc7\u672c\u5229\u5f97\u4e00\u842c\u7f8e\u5143\u3002\u7531\u65bc\u4f4e\u65bc\u516b\u842c\u7f8e\u5143\uff0c\u6240\u4ee5\u9577\u671f\u8cc7\u672c\u5229\u5f97\u7a05\u7387\u70ba\u96f6\uff0c\u6240\u4ee5\u4e0d\u9700\u8981\u51fa\u552e\u5176\u4ed6\u6709\u640d\u5931\u7684\u8cc7\u7522\uff0c\u4f86\u5c0d\u51b2\u6b64\u4e00\u9577\u671f\u8cc7\u672c\u5229\u5f97\u3002 \u6211\u5011\u6539\u4e00\u4e0b\u4e0a\u4e00\u984c\u7684\u4f8b\u5b50\uff0c\u7531\u65bc2020\u5e74\uff0cCovid 19\u7684\u5f71\u97ff\uff0c\u5c0d\u9019\u4e00\u5c0d\u592b\u59bb \u7684\u6240\u5f97\u9020\u6210\u5de8\u5927\u7684\u885d\u64ca\uff0c\u672c\u4f86\u5728\u75ab\u60c5\u524d\u6240\u5f97\u61c9\u5728\u5341\u4e94\u842c\u7f8e\u91d1\u5de6\u53f3\uff0c\u4f46\u662f\u56e0\u70ba\u75ab\u60c5\u7684\u95dc\u4fc2\uff0c\u8ab2\u7a05\u6240\u5f97\u6389\u4e86\u4e00\u534a\u591a\u3002\u4f46\u662f\u75ab\u82d7\u5df2\u7d93\u554f\u4e16\uff0c\u4f30\u8a08\u660e\u5e74\u6703\u56de\u5fa9\u5230\u75ab\u60c5\u524d\u7684\u6c34\u6e96\uff0c\u6240\u4ee5\uff0c\u9019\u5c0d\u592b\u59bb\u5c31\u53ef\u4ee5\u8003\u616e\u9577\u671f\u8cc7\u672c\u5229\u5f97\u7a05\u7387\u70ba\u96f6\u7684\u512a\u52e2\uff0c\u8655\u7406\u4e00\u4e9b\u7372\u5229\u7684\u9577\u671f\u8cc7\u7522\uff0c\u9054\u5230\u5371\u6a5f\u5c31\u662f\u8f49\u6a5f\u7684\u76ee\u7684\u3002 \u5c0d\u65bc\u5df2\u7d93\u7372\u5229\u7684\u7d0d\u7a05\u4eba\uff0c\u82e5\u662f\u5c0b\u6c42\u88fd\u9020\u53ef\u7528\u65bc\u5c0d\u51b2\u7684\u6295\u8cc7\u640d\u5931\uff0c\u5728\u7a05\u52d9\u7684\u89c0\u9ede\u61c9\u8a72\u5148\u62cb\u552e\u77ed\u671f\u6301\u6709\u80a1\u7968\uff0c\u56e0\u70ba\u5982\u4e0a\u6240\u8ff0\u77ed\u671f\u8cc7\u672c\u5229\u5f97\u7a05\u7387\u8f03\u9ad8\uff0c\u6240\u4ee5\u88fd\u9020\u77ed\u671f\u8cc7\u672c\u640d\u5931\u6703\u7701\u5230\u66f4\u591a\u7a05\u3002 \u8003\u616e\u6148\u5584\u6350\u6b3e\u3002\u6240\u8b02\u65bd\u6bd4\u53d7\u66f4\u6709\u798f\u3002\u800c\u4e14\u6148\u5584\u6350\u6b3e\u4e5f\u80fd\u9054\u5230\u7701\u7a05\u7684\u76ee\u7684\uff0c\u5229\u4eba\u5229\u5df1\u3002\u4ee5\u5f80\u7684\u6148\u5584\u6350\u6b3e\uff0c\u53ea\u80fd\u7576\u4f5c\u5217\u8209\u6263\u9664\u984d\u7684\u4e00\u90e8\u4efd\uff0c\u4f46\u662f\u56e0\u70baCARES,\u7d13\u56f0\u689d\u6b3e\u7576\u4e2d\u7684\u4e00\u689d\uff0c\u662f\u91dd\u5c0d\u4f7f\u7528\u6a19\u6e96\u6263\u9664\u984d\u7684\u7d0d\u7a05\u4eba\uff0c\u5176\u6148\u5584\u6350\u6b3e\u53ef\u4ee5\u505a\u70ba\u6240\u5f97\u7684\u62b5\u6e1b\u9805\uff0c\u4e0a\u9650\u70ba\u4e09\u767e\u7f8e\u5143\u3002\u800c\u4e14\u82e5\u662f\u8d85\u904e\u4e03\u5341\u6b72\u534a\u7684\u8006\u82f1\uff0c\u82e5\u662f\u5f9e\u81ea\u5df1\u7684IRA\u5e33\u6236\u76f4\u63a5\u6350\u6b3e\u7d66\u6148\u5584\u6a5f\u69cb\uff0c\u5247\u9019\u90e8\u4efd\u53d6\u51fa\u7684\u9322\u4e0d\u7b97\u662f\u6240\u5f97\u3002\u4f46\u662f\u6bcf\u5e74\u9650\u984d\u70ba\u5341\u842c\u7f8e\u5143\u3002 \u8003\u616e\u4f4f\u5b85\u7684\u80fd\u6e90\u512a\u60e0\uff08residential energy property crest)\u6216\u8003\u616e\u6709\u7a05\u52d9\u88dc\u52a9\u7684\u7bc0\u80fd\u8eca\u6b3e\u3002 \u5c0d\u65bc\u6709\u53ef\u80fd\u6709AMT\u7684\u7d0d\u7a05\u4eba\uff0c\u8981\u63a7\u5236AMT\u7684\u8abf\u6574\u9805\uff0c\u95dc\u65bcAMT, \u6211\u5011\u6709\u6a5f\u6703\u6642\u518d\u8ac7\u3002 \u8003\u616e\u589e\u52a0\u85aa\u6c34\u5c0d\u65bc\u7a05\u91d1\u7684\u63d0\u64a5\uff0c\u4ee5\u907f\u514d\u9810\u7e73\u7a05\u4e0d\u8db3\u6240\u9020\u6210\u7684\u7f70\u6b3e\u3002 \u6b64\u5916\u9084\u6709\u4e00\u4e9b\u95dc\u65bc\u5c0d\u65bc\u4e2d\u5c0f\u4f01\u696d\u7684\u5efa\u8b70\uff0c\u4e5f\u662f\u4e00\u6a23\uff0c\u9650\u65bc\u7bc7\u5e45\uff0c\u6211\u5011\u6709\u6a5f\u6703\u518d\u8a0e\u8ad6\u3002 \u6797\u61ff\u00a0 \u6703\u8a08\u5e2b 12\/12\/20 Cupertino"}