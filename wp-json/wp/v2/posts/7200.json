\u8acbchapter 11\u7684\u7834\u7522\u4fdd\u8b77\u3002\u9019\u628a\u706b\u4e5f\u5ef6\u5230\u5176\u4ed6\u7684\u865b\u64ec\u8ca8\u5e63\uff0c\u4f8b\u5982\u6bd4\u7279\u5e63\u7684\u50f9\u503c\u4e5f\u5927\u5e45\u4e0b\u964d\u3002\u7136\u800c\u6709\u8a31\u591a\u6295\u8cc7\u4eba\u95dc\u5fc3\u7684\u8a71\u984c\uff0c\u9664\u4e86\u5230\u5e95\u53ef\u4ee5\u56de\u672c\u591a\u5c11\u5916\uff0c\u5c31\u662f\u640d\u5931\u53ef\u4ee5\u51b2\u62b5\u55ce\uff1f\u5982\u679c\u53ef\u4ee5\uff0c\u662f\u4ec0\u9ebc\u6027\u8cea\uff0c\u4ee5\u53ca\u51b2\u92b7\u7684\u6642\u9593\u9ede\u70ba\u4f55? \u6211\u57282019\u5e74\u7684\u516b\u6708\uff0c\u66fe\u7d93\u5beb\u904e\u4e00\u7bc7\u6587\u7ae0\uff0c\u8b1b\u7684\u662f\u865b\u64ec\u8ca8\u5e63\u7684\u7a05\u52d9\u8655\u7406\uff0c\u5f15\u7528\u7684\u662f\u570b\u7a05\u5c40\u7684\u6587\u544a\uff0cnotice 2014-21. \u7c21\u55ae\u4f86\u8aaa\uff0c\u865b\u64ec\u8ca8\u5e63\u5728\u4ea4\u6613\u6642\u4e0d\u662f\u7576\u6210\u662f\u5916\u5e63\u4ea4\u6613\uff0c\u800c\u662f\u7576\u6210\u662f\u4e00\u7a2e\u8cc7\u672c\u985e\u8cc7\u7522(capital assets)\u6240\u4ee5\u5728\u7522\u751f\u4ea4\u6613\u884c\u70ba\u6642\uff0c\u5c07\u985e\u4f3c\u65bc\u80a1\u7968\u7684\u65b9\u5f0f\uff0c\u8a8d\u5217\u8cc7\u672c\u5229\u5f97\u6216\u662f\u8cc7\u672c\u640d\u5931\u3002\u4f46\u662f\u82e5\u662f\u4ea4\u6613\u91cf\u5927\u7684\u6642\u5019\uff0c\u53ef\u80fd\u88ab\u7576\u6210\u662f\u5b58\u8ca8\uff0c\u5247\u4ea4\u6613\u6642\u6703\u88ab\u8a8d\u5217\u70ba\u4e00\u822c\u7684\u6536\u5165\u53ca\u640d\u5931\u3002\u82e5\u662f\u6316\u7926\u6216\u662f\u63a5\u53d7\u865a\u64ec\u8ca8\u5e63\u4f86\u4ea4\u63db\u8ca8\u7269\u6216\u662f\u670d\u52d9\uff0c\u5247\u6536\u53d7\u8005\u4e5f\u8981\u5c07\u5176\u8a8d\u5217\u70ba\u6b63\u5e38\u6240\u5f97\u3002 \u518d\u56de\u4f86\u8ac7FTX\u7684\u4f8b\u5b50\uff0c\u82e5\u662f\u5176\u6295\u8cc7\u640d\u5931\u78ba\u5b9a\u6642\uff0c\u7d0d\u7a05\u4eba\u61c9\u8a72\u53ef\u4ee5\u8a8d\u5217\u6295\u8cc7\u640d\u5931\u3002\u7136\u800c\uff0c\u5728\u73fe\u884c\u7684\u72c0\u6cc1\u4e0b\uff0c\u96d6\u7136FTX\