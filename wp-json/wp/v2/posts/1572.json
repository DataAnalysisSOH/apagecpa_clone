eta property=\"og:type\" content=\"article\" \/>\n<meta property=\"og:title\" content=\"\u5f35\u797f\u751f\u6703\u8a08\u5e2b\uff0d\u5982\u4f55\u6e1b\u4f4e\u570b\u7a05\u5c40\u67e5\u7a05\u98a8\u96aa - \u611b\u52a0\u500d\u6703\u8a08\u5e2b\u4e8b\u52d9\u6240 - AGAPE CPA FIRM\" \/>\n<meta property=\"og:description\" content=\"\u88ab\u570b\u7a05\u5c40\u67e5\u7a05\u7684\u6a5f\u7387\u5e7e\u4e4e\u662f\u4eba\u4eba\u90fd\u6709 \u6709\u4e9b\u4eba\u88ab\u62bd\u67e5\u5b8c\u5168\u662f\u56e0\u70ba\u904b\u6c23 \u5927\u90e8\u4efd\u7684 \u4eba\u88ab\u62bd\u67e5\u9084\u662f\u56e0\u70ba\u7533\u5831\u5167\u5bb9\u4e0d\u6b63\u78ba\u6216\u4e0d\u5408\u5e38\u7406\u25e6 \u7576\u7136 \u8cc7\u7522\u8d8a\u5927\u3001\u4ea4\u6613\u8d8a\u591a\u6216\u662f Self- Employed \u81ea\u96c7\u7684\u4eba\u8981\u6bd4\u55ae\u7d14\u62ff\u85aa\u6c34\u7684\u4e0a\u73ed\u65cf\u66f4\u53ef\u80fd\u88ab\u67e5\u7a05\u25e6 \u4f46\u5927\u5bb6\u4e00\u5b9a\u5f88\u597d\u5947, \u5230\u5e95\u570b\u7a05 \u5c40\u662f\u5982\u4f55\u7be9\u9078\u7684\u5462? \u570b\u7a05\u5c40\u5167\u6709\u4e00\u500b Service Center \u90e8\u9580\u5c08\u9580\u8ca0\u8cac\u7be9\u9078\u7a3d\u67e5\u5c0d\u8c61, \u7be9\u9078\u65b9\u5f0f\u5927\u81f4\u6b78\u985e\u70ba\u4ee5 \u4e0b\u56db\u7a2e: (\u4e00) \u5206\u6578 \u570b\u7a05\u5c40\u6709\u4e00\u5957\u79d8\u5bc6\u8a08\u5206\u65b9\u5f0f, \u5c07\u6bcf\u4e00\u500b\u7d0d\u7a05\u4eba\u7684\u7a05\u8868\u90fd\u6253\u5206\u6578\u25e6 \u4f8b\u5982: \u7d14\u9818\u85aa\u8cc7\u7684\u4eba \u7d66\u4e00\u5206; Self-Employed \u7684\u4eba\u7d66\u5169\u5206; \u6709\u8cb7\u80a1\u7968\u7684\u4eba\u52a0\u5169\u5206; \u6709 Schedule C \u505a\u751f\u610f\u7684\u4eba \u52a0\u4e09\u5206; \u6709 Schedule E \u51fa\u79df\u623f\u5c4b\u7684\u4eba\u518d\u52a0\u4e09\u5206\u2026.\u7b49\u7b49\u25e6 \u570b\u7a05\u5c40\u901a\u5e38\u90fd\u6703\u5c07\u7d0d\u7a05\u4eba\u4eca \u5e74\u7684\u7a05\u8868\u548c\u904e\u53bb\u5e7e\u5e74\u505a\u6bd4\u8f03, \u5982\u679c\u4eca\u5e74\u5229\u606f\u6536\u5165\u6bd4\u5f80\u5e74\u9ad8\u51fa\u5f88\u591a, \u5206\u6578\u6703\u518d\u52a0\u5341\u5206\u25e6 \u5982\u679c\u4eca\u5e74\u8ce3\u4e86\u4e00\u5927\u7b46\u516c\u53f8\u80a1\u7968\u537b\u53c8\u6709\u5f88\u591a\u8667\u640d\u76f8\u62b5, \u570b\u7a05\u5c40\u6703\u518d\u52a0\u4e8c\u5341\u5206\u25e6 \u5206\u6578\u8d8a \u9ad8\u7684\u4eba\u8d8a\u6709\u6a5f\u6703\u88ab\u67e5\u7a05\u25e6 (\u4e8c) \u7279\u5b9a\u884c\u696d\u6216 Research \u570b\u7a05\u5c40\u5e38\u5e38\u6703\u9396\u5b9a\u7279\u5b9a\u7684\u5e7e\u7a2e\u884c\u696d\u9032\u884c\u7a3d\u67e5, Research \u7d50\u679c\u505a\u70ba\u65e5\u5f8c\u67e5\u7a05\u7684\u53c3\u8003\u4f9d \u64da\u25e6 \u4f8b\u5982: \u570b\u7a05\u5c40\u6c7a\u5b9a\u7279\u5225\u67e5\u623f\u5730\u7522\u696d, \u4e86\u89e3\u623f\u5730\u7522\u7d93\u7d00\u5728\u5404\u9805\u652f\u51fa\u7684\u6bd4\u4f8b\u25e6 [&hellip;]\" \/>\n<meta property=\"og:url\" content=\"https:\/\/agapecpa.com\/1572.html\" \/>\n<meta property=\"og:site_name\" content=\"\u611b\u52a0\u500d\u6703\u8a08\u5e2b\u4e8b\u52d9\u6240 - AGAPE CPA FIRM\" \/>\n<meta property=\"article:published_time\" content=\"2019-10-01T17:41:04+00:00\" \/>\n<meta property=\"article:modified_time\" content=\"2022-12-24T02:49:33+00:00\" \/>\n<meta property=\"og:image\" content=\"https:\/\/agapecpa.com\/wp-content\/uploads\/sites\/10\/2019\/10\/tax-info2.jpg\" \/>\n\t<meta property=\"og:image:width\" content=\"640\" \/>\n\t<meta property=\"og:image:height\" content=\"354\" \/>\n\t<meta property=\"og:image:type\" content=\"image\/jpeg\" \/>\n<meta name=\"author\" content=\"corey.lee\" \/>\n<meta name=\"twitter:card\" content=\"summary_large_image\" \/>\n<meta name=\"twitter:label1\" content=\"Written by\" \/>\n\t<meta name=\"twitter:data1\" content=\"corey.lee\" \/>\n<script type=\"application\/ld+json\" class=\"yoast-schema-graph\">{\"@context\":\"https:\/\/schema.org\",\"@graph\":[{\"@type\":\"Article\",\"@id\":\"https:\/\/agapecpa.com\/1572.html#article\",\"isPartOf\":{\"@id\":\"https:\/\/agapecpa.com\/1572.html\"},\"author\":{\"name\":\"corey.lee\",\"@id\":\"https:\/\/agapecp