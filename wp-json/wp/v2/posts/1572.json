{"id":1572,"date":"2019-10-01T10:41:04","date_gmt":"2019-10-01T17:41:04","guid":{"rendered":"https:\/\/agapecpa.com\/?p=1572"},"modified":"2022-12-23T18:49:33","modified_gmt":"2022-12-24T02:49:33","slug":"avoid-audit","status":"publish","type":"post","link":"https:\/\/agapecpa.com\/1572.html","title":{"rendered":"\u5f35\u797f\u751f\u6703\u8a08\u5e2b\uff0d\u5982\u4f55\u6e1b\u4f4e\u570b\u7a05\u5c40\u67e5\u7a05\u98a8\u96aa"},"content":{"rendered":"<div class=\"page\" title=\"Page 1\">\n<div class=\"layoutArea\">\n<div class=\"column\">\n<p>\u88ab\u570b\u7a05\u5c40\u67e5\u7a05\u7684\u6a5f\u7387\u5e7e\u4e4e\u662f\u4eba\u4eba\u90fd\u6709 \u6709\u4e9b\u4eba\u88ab\u62bd\u67e5\u5b8c\u5168\u662f\u56e0\u70ba\u904b\u6c23 \u5927\u90e8\u4efd\u7684 \u4eba\u88ab\u62bd\u67e5\u9084\u662f\u56e0\u70ba\u7533\u5831\u5167\u5bb9\u4e0d\u6b63\u78ba\u6216\u4e0d\u5408\u5e38\u7406\u25e6 \u7576\u7136 \u8cc7\u7522\u8d8a\u5927\u3001\u4ea4\u6613\u8d8a\u591a\u6216\u662f Self- Employed \u81ea\u96c7\u7684\u4eba\u8981\u6bd4\u55ae\u7d14\u62ff\u85aa\u6c34\u7684\u4e0a\u73ed\u65cf\u66f4\u53ef\u80fd\u88ab\u67e5\u7a05\u25e6 \u4f46\u5927\u5bb6\u4e00\u5b9a\u5f88\u597d\u5947, \u5230\u5e95\u570b\u7a05 \u5c40\u662f\u5982\u4f55\u7be9\u9078\u7684\u5462?<\/p>\n<\/div>\n<\/div>\n<div class=\"layoutArea\">\n<div class=\"column\">\n<p>\u570b\u7a05\u5c40\u5167\u6709\u4e00\u500b Service Center \u90e8\u9580\u5c08\u9580\u8ca0\u8cac\u7be9\u9078\u7a3d\u67e5\u5c0d\u8c61, \u7be9\u9078\u65b9\u5f0f\u5927\u81f4\u6b78\u985e\u70ba\u4ee5 \u4e0b\u56db\u7a2e:<\/p>\n<p>(\u4e00) \u5206\u6578<\/p>\n<p>\u570b\u7a05\u5c40\u6709\u4e00\u5957\u79d8\u5bc6\u8a08\u5206\u65b9\u5f0f, \u5c07\u6bcf\u4e00\u500b\u7d0d\u7a05\u4eba\u7684\u7a05\u8868\u90fd\u6253\u5206\u6578\u25e6 \u4f8b\u5982: \u7d14\u9818\u85aa\u8cc7\u7684\u4eba \u7d66\u4e00\u5206; Self-Employed \u7684\u4eba\u7d66\u5169\u5206; \u6709\u8cb7\u80a1\u7968\u7684\u4eba\u52a0\u5169\u5206; \u6709 Schedule C \u505a\u751f\u610f\u7684\u4eba \u52a0\u4e09\u5206; \u6709 Schedule E \u51fa\u79df\u623f\u5c4b\u7684\u4eba\u518d\u52a0\u4e09\u5206\u2026.\u7b49\u7b49\u25e6 \u570b\u7a05\u5c40\u901a\u5e38\u90fd\u6703\u5c07\u7d0d\u7a05\u4eba\u4eca \u5e74\u7684\u7a05\u8868\u548c\u904e\u53bb\u5e7e\u5e74\u505a\u6bd4\u8f03, \u5982\u679c\u4eca\u5e74\u5229\u606f\u6536\u5165\u6bd4\u5f80\u5e74\u9ad8\u51fa\u5f88\u591a, \u5206\u6578\u6703\u518d\u52a0\u5341\u5206\u25e6 \u5982\u679c\u4eca\u5e74\u8ce3\u4e86\u4e00\u5927\u7b46\u516c\u53f8\u80a1\u7968\u537b\u53c8\u6709\u5f88\u591a\u8667\u640d\u76f8\u62b5, \u570b\u7a05\u5c40\u6703\u518d\u52a0\u4e8c\u5341\u5206\u25e6 \u5206\u6578\u8d8a \u9ad8\u7684\u4eba\u8d8a\u6709\u6a5f\u6703\u88ab\u67e5\u7a05\u25e6<\/p>\n<p>(\u4e8c) \u7279\u5b9a\u884c\u696d\u6216 Research<\/p>\n<p>\u570b\u7a05\u5c40\u5e38\u5e38\u6703\u9396\u5b9a\u7279\u5b9a\u7684\u5e7e\u7a2e\u884c\u696d\u9032\u884c\u7a3d\u67e5, Research \u7d50\u679c\u505a\u70ba\u65e5\u5f8c\u67e5\u7a05\u7684\u53c3\u8003\u4f9d \u64da\u25e6 \u4f8b\u5982: \u570b\u7a05\u5c40\u6c7a\u5b9a\u7279\u5225\u67e5\u623f\u5730\u7522\u696d, \u4e86\u89e3\u623f\u5730\u7522\u7d93\u7d00\u5728\u5404\u9805\u652f\u51fa\u7684\u6bd4\u4f8b\u25e6 \u5982\u679c\u5ee3 \u544a\u652f\u51fa\u4e00\u822c\u5360 Gross Revenue \u7684 10%, Net Profit \u70ba 20%; \u800c\u67d0\u7d93\u7d00\u7533\u5831\u5ee3\u544a\u652f\u51fa\u6bd4 \u4f8b\u662f 45% , Net Profit \u53ea\u6709 5%, \u9019\u6a23\u7684\u6bd4\u4f8b\u8207\u540c\u884c\u5dee\u7570\u76f8\u8ddd\u751a\u9060\u5c31\u5f88\u5bb9\u6613\u88ab\u67e5\u25e6<\/p>\n<p>(\u4e09) \u7a3d\u67e5\u57f9\u8a13<\/p>\n<p>\u570b\u7a05\u5c40\u6709\u6642\u4e5f\u6703\u6311\u9078\u4e00\u4e9b\u7c21\u55ae\u7684\u6848\u5b50\u505a\u70ba\u65b0\u9032\u7a3d\u67e5\u54e1\u57f9\u8a13\u7684\u6559\u6750\u25e6 \u6240\u4ee5\u5982\u679c\u60a8\u4e00\u5411 \u90fd\u8aa0\u5be6\u7533\u5831, \u5373\u4f7f\u63a5\u5230\u67e5\u7a05\u901a\u77e5\u4e5f\u4e0d\u9700\u8981\u5bb3\u6015, \u53ea\u8981\u5411\u570b\u7a05\u5c40\u63d0\u51fa\u55ae\u64da\u8a3c\u660e\u5f9e\u5bb9\u4ee5\u5c0d \u901a\u5e38\u5f88\u5feb\u5c31\u53ef\u4ee5\u7d50\u6848\u25e6<\/p>\n<p>(\u56db) \u76f8\u95dc\u4eba\u58eb<\/p>\n<p>\u570b\u7a05\u5c40\u5982\u679c\u5728\u8abf\u67e5\u67d0\u4e00\u500b\u6848\u4ef6\u767c\u73fe\u7591\u9ede, \u53ef\u80fd\u9032\u4e00\u6b65\u7a3d\u67e5\u5176\u4ed6\u76f8\u95dc\u4eba\u25e6 \u4f8b\u5982: \u67d0\u4e00\u68df \u5408\u8cc7\u7684\u8fa6\u516c\u5927\u6a13\u5728\u8ce3\u51fa\u90a3\u5e74\u6298\u820a\u7533\u5831\u4e0d\u5be6, \u7a3d\u67e5\u54e1\u53ef\u80fd\u6703\u5c0d\u6240\u6709\u80a1\u6771\u9032\u884c\u67e5\u7a05, \u6216\u8005 \u67d0\u7d0d\u7a05\u4eba\u9280\u884c\u6236\u982d\u6709\u4e00\u7b46\u5b58\u6b3e, \u7d0d\u7a05\u4eba\u8aaa\u662f\u5411\u670b\u53cb\u501f\u4f86\u7684, \u9664\u975e\u4ed6\u80fd\u63d0\u51fa\u8a3c\u660e, \u7a3d\u67e5 \u54e1\u53ef\u80fd\u5c31\u6703\u5c0d\u4ed6\u7684\u670b\u53cb\u9032\u884c\u67e5\u7a05\u25e6<\/p>\n<\/div>\n<\/div>\n<\/div>\n<div class=\"page\" title=\"Page 2\">\n<div class=\"layoutArea\">\n<div class=\"column\">\n<p>\u907f\u514d\u88ab\u67e5\u7a05\u7684\u65b9\u6cd5<\/p>\n<p>\u907f\u514d\u88ab\u67e5\u7a05\u7684\u6700\u9ad8\u6307\u5c0e\u539f\u5247\u5c31\u662f\u8aa0\u5be6\u7533\u5831\u25e6 \u570b\u7a05\u5c40\u95b1\u5377\u7121\u6578, \u8db3\u4ee5\u5206\u8fa8\u7533\u5831\u4e0d\u5be6\u662f \u7121\u5fc3\u4e4b\u5931\u9084\u662f\u6545\u610f\u96b1\u779e\u25e6 \u5982\u679c\u662f\u8a08\u7b97\u932f\u8aa4, \u570b\u7a05\u5c40\u901a\u5e38\u6703\u5bc4\u901a\u77e5\u7d66\u7d0d\u7a05\u4eba,\u8a73\u5217\u570b\u7a05\u5c40\u8a8d\u70ba \u6b63\u78ba\u7684\u91d1\u984d ,\u591a\u9000\u5c11\u88dc\u25e6 \u5982\u679c\u8981\u7701\u6642\u7701\u4e8b, \u6700\u597d\u662f\u7528\u5e02\u9762\u4e0a\u7684\u5831\u7a05\u96fb\u8166\u8edf\u9ad4\u7533\u5831, \u8a08\u7b97\u932f\u8aa4 \u7684\u6a5f\u7387\u5c31\u53ef\u4ee5\u6e1b\u4f4e\u5f88\u591a\u25e6<\/p>\n<p>\u518d\u8005, \u586b\u5beb\u8cc7\u6599\u6642\u8981\u6ce8\u610f\u548c\u524d\u5e7e\u5e74\u8981\u6709\u4e00\u8cab\u6027\u25e6 \u4f8b\u5982: Schedule C \u8cbb\u7528\u652f\u51fa \u6bcf\u5e74\u6b78\u7d0d \u51fa\u7684\u9805\u76ee\u8981\u4e00\u81f4, \u800c\u4e14\u586b\u5728\u540c\u4e00\u6b04, \u76e1\u91cf\u8a73\u5217\u5404\u9805\u652f\u51fa ,\u4e0d\u8981\u901a\u901a\u653e\u5728 Other Expenses\u25e6 \u9019\u7a2e \u60c5\u5f62\u5e38\u5e38\u6703\u767c\u751f\u5728\u7a05\u8868\u6bcf\u5e74\u7531\u4e0d\u540c\u7684\u4eba\u7533\u5831, \u6b78\u985e\u540d\u7a31\u4e0d\u540c\u9020\u6210\u67d0\u4e9b\u652f\u51fa\u8b8a\u5316\u5f88\u5927\u25e6 \u4f8b\u5982: \u92b7\u8ca8\u6210\u672c (Cost of Goods Sold)\u6bd4\u4f8b\u4e0a\u4e0b\u6ce2\u52d5\u5f88\u5927, \u570b\u7a05\u5c40\u5c31\u7d66\u5f88\u9ad8\u7684\u5206\u6578, \u5bb9\u6613\u88ab\u7a3d\u67e5\u25e6<\/p>\n<p>\u570b\u7a05\u5c40\u5c0d\u73fe\u91d1\u4ea4\u6613\u983b\u7e41\u7684\u7d0d\u7a05\u4eba\u4e5f\u7279\u5225\u95dc\u6ce8\u25e6 \u9280\u884c\u6709\u8cac\u4efb\u5c07$10,000\u4ee5\u4e0a\u5927\u7b46\u73fe\u91d1 \u51fa\u5165\u4ea4\u6613\u901a\u77e5\u570b\u7a05\u5c40, \u5982\u679c\u9280\u884c\u8a8d\u70ba\u67d0\u4eba\u70ba\u898f\u907f\u7a3d\u67e5\u800c\u5206\u597d\u5e7e\u6b21\u5b58\u63d0, \u9280\u884c\u9084\u662f\u53ef\u4ee5\u5411\u570b\u7a05 \u5c40\u5831\u5099\u25e6<\/p>\n<p>\u570b\u7a05\u5c40\u5c0d\u65bc\u6709\u6c92\u6709\u8cc7\u683c\u4eab\u53d7\u7a05\u60e0(Tax Credit)\u7684\u5be9\u6838\u7279\u5225\u56b4\u8b39, \u4efb\u4f55\u7a05\u8868\u4e0a\u6709\u7533\u5831\u7a05 \u60e0\u7684\u7d0d\u7a05\u4eba\u90fd\u6bd4\u8f03\u6709\u6a5f\u6703\u88ab\u67e5\u7a3d, \u5c24\u5176\u662f Earned Income Credit\u25e6 \u5982\u679c\u88ab\u8a8d\u70ba\u6c92\u8cc7\u683c\u537b\u84c4\u610f \u7533\u5831\u6703\u53d7\u5230\u76f8\u7576\u56b4\u53b2\u7684\u7f70\u6b3e, \u7d0d\u7a05\u4eba\u4e0d\u80fd\u5fc3\u5b58\u50e5\u5016\u25e6<\/p>\n<p>\u5e38\u5e38\u6709\u96e2\u5a5a\u914d\u5076\u6216\u96e2\u8077\u54e1\u5de5\u5411\u570b\u7a05\u5c40\u544a\u5bc6, \u4f8b\u5982:\u77ed\u5831\u71df\u5229\u3001 \u73fe\u91d1\u652f\u4ed8\u85aa\u6c34\u6216\u6d77\u5916 \u6536\u5165\u672a\u7533\u5831\u7b49, \u570b\u7a05\u5c40\u5c31\u6703\u53bb\u67e5\u7a05\u25e6 \u6700\u597d\u7684\u65b9\u6cd5\u9084\u662f\u8aa0\u5be6\u7533\u5831, \u5584\u5f85\u4f60\u7684\u5bb6\u4eba\u53ca\u54e1\u5de5, \u597d\u805a \u597d\u6563\u25e6<\/p>\n<p>\u7576\u4f60\u63a5\u5230\u570b\u7a05\u5c40\u67e5\u7a05\u901a\u77e5\u6642\u600e\u9ebc\u8fa6?<br \/>\n\u9996\u5148, \u4f60\u8981\u5148\u8861\u91cf\u4e00\u4e0b\u6709\u6c92\u6709\u8fa6\u6cd5\u5411\u7a3d\u67e5\u4eba\u54e1\u89e3\u91cb\u6e05\u695a, \u63d0\u51fa\u5177\u9ad4\u8b49\u660e\u25e6 \u5982\u679c\u53ea\u662f\u5c0f<\/p>\n<p>\u932f\u8aa4, \u5411\u6703\u8a08\u5e2b\u8aee\u8a62\u5f8c, \u4e00\u822c\u81ea\u5df1\u5c31\u53ef\u4ee5\u548c\u570b\u7a05\u5c40\u89e3\u6c7a \u25e6<\/p>\n<p>\u5982\u679c\u4f60\u7a05\u8868\u7684\u932f\u8aa4\u5f88\u5927, \u5728\u548c\u570b\u7a05\u5c40\u4ea4\u6d89\u4e4b\u524d\u4f60\u5c31\u9700\u8981\u8acb\u4e00\u4f4d\u6709\u7d93\u9a57\u53c8\u5c08\u696d\u7684\u5f8b\u5e2b \u6216\u6703\u8a08\u5e2b\u4ee3\u8868\u4f60, \u56e0\u70ba\u4f60\u56de\u7b54\u6216\u4e0d\u56de\u7b54\u7684\u53cd\u61c9\u570b\u7a05\u5c40\u90fd\u6703\u4e00\u4e00\u8a18\u9304\u4e0b\u4f86, \u56de\u7b54\u4e0d\u614e\u6703\u5e36\u7d66\u4f60 \u66f4\u5927\u7684\u9ebb\u7169, \u4e00\u5b9a\u4e0d\u8981\u7b49\u5230\u81ea\u5df1\u61c9\u4ed8\u4e0d\u4f86\u624d\u6c42\u52a9\u5c08\u696d, \u9020\u6210\u907a\u61be\u25e6<\/p>\n<\/div>\n<\/div>\n<\/div>\n","protected":false},"excerpt":{"rendered":"\u88ab\u570b\u7a05\u5c40\u67e5\u7a05\u7684\u6a5f\u7387\u5e7e\u4e4e\u662f\u4eba\u4eba\u90fd\u6709 \u6709\u4e9b\u4eba\u88ab\u62bd\u67e5\u5b8c\u5168\u662f\u56e0\u70ba\u904b\u6c23 \u5927\u90e8\u4efd\u7684 \u4eba\u88ab\u62bd\u67e5\u9084\u662f\u56e0\u70ba\u7533\u5831\u5167\u5bb9\u4e0d\u6b63\u78ba\u6216\u4e0d\u5408\u5e38\u7406\u25e6 \u7576\u7136 \u8cc7\u7522\u8d8a\u5927\u3001\u4ea4\u6613\u8d8a\u591a\u6216\u662f Self- Employed \u81ea\u96c7\u7684\u4eba\u8981\u6bd4\u55ae\u7d14\u62ff\u85aa\u6c34\u7684\u4e0a\u73ed\u65cf\u66f4\u53ef\u80fd\u88ab\u67e5\u7a05\u25e6 \u4f46\u5927\u5bb6\u4e00\u5b9a\u5f88\u597d\u5947, \u5230\u5e95\u570b\u7a05 \u5c40\u662f\u5982\u4f55\u7be9\u9078\u7684\u5462? \u570b\u7a05\u5c40\u5167\u6709\u4e00\u500b Service Center \u90e8\u9580\u5c08\u9580\u8ca0\u8cac\u7be9\u9078\u7a3d\u67e5\u5c0d\u8c61, \u7be9\u9078\u65b9\u5f0f\u5927\u81f4\u6b78\u985e\u70ba\u4ee5 \u4e0b\u56db\u7a2e: (\u4e00) \u5206\u6578 \u570b\u7a05\u5c40\u6709\u4e00\u5957\u79d8\u5bc6\u8a08\u5206\u65b9\u5f0f, \u5c07\u6bcf\u4e00\u500b\u7d0d\u7a05\u4eba\u7684\u7a05\u8868\u90fd\u6253\u5206\u6578\u25e6 \u4f8b\u5982: \u7d14\u9818\u85aa\u8cc7\u7684\u4eba \u7d66\u4e00\u5206; Self-Employed \u7684\u4eba\u7d66\u5169\u5206; \u6709\u8cb7\u80a1\u7968\u7684\u4eba\u52a0\u5169\u5206; \u6709 Schedule C \u505a\u751f\u610f\u7684\u4eba \u52a0\u4e09\u5206; \u6709 Schedule E \u51fa\u79df\u623f\u5c4b\u7684\u4eba\u518d\u52a0\u4e09\u5206\u2026.\u7b49\u7b49\u25e6 \u570b\u7a05\u5c40\u901a\u5e38\u90fd\u6703\u5c07\u7d0d\u7a05\u4eba\u4eca \u5e74\u7684\u7a05\u8868\u548c\u904e\u53bb\u5e7e\u5e74\u505a\u6bd4\u8f03, \u5982\u679c\u4eca\u5e74\u5229\u606f\u6536\u5165\u6bd4\u5f80\u5e74\u9ad8\u51fa\u5f88\u591a, \u5206\u6578\u6703\u518d\u52a0\u5341\u5206\u25e6 \u5982\u679c\u4eca\u5e74\u8ce3\u4e86\u4e00\u5927\u7b46\u516c\u53f8\u80a1\u7968\u537b\u53c8\u6709\u5f88\u591a\u8667\u640d\u76f8\u62b5, \u570b\u7a05\u5c40\u6703\u518d\u52a0\u4e8c\u5341\u5206\u25e6 \u5206\u6578\u8d8a \u9ad8\u7684\u4eba\u8d8a\u6709\u6a5f\u6703\u88ab\u67e5\u7a05\u25e6 (\u4e8c) \u7279\u5b9a\u884c\u696d\u6216 Research \u570b\u7a05\u5c40\u5e38\u5e38\u6703\u9396\u5b9a\u7279\u5b9a\u7684\u5e7e\u7a2e\u884c\u696d\u9032\u884c\u7a3d\u67e5, Research \u7d50\u679c\u505a\u70ba\u65e5\u5f8c\u67e5\u7a05\u7684\u53c3\u8003\u4f9d \u64da\u25e6 \u4f8b\u5982: \u570b\u7a05\u5c40\u6c7a\u5b9a\u7279\u5225\u67e5\u623f\u5730\u7522\u696d, \u4e86\u89e3\u623f\u5730\u7522\u7d93\u7d00\u5728\u5404\u9805\u652f\u51fa\u7684\u6bd4\u4f8b\u25e6 [&hellip;]","protected":false},"author":2,"featured_media":1780,"comment_status":"closed","ping_status":"closed","sticky":false,"template":"","format":"standard","meta":{"episode_type":"audio","audio_file":"","cover_image":"","cover_image_id":"","duration":"","filesize":"","filesize_raw":"","date_recorded":"2019-10-01","explicit":"","block":"","ocean_post_lay