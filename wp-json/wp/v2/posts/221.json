5dde\u4e0d\u540c\u3002\u52a0\u5dde\u662f\u4e0d\u80fd\u7528529\u8a08\u5283\u7684\u6295\u5165\u62b5\u6e1b\u5dde\u7a05\u3002\u5728\u7a05\u6539\u4e4b\u524d\uff0c\u6240\u8b02\u7684\u5408\u683c\u7684\u7528\u9014\uff0c\u6307\u7684\u662f\u652f\u4ed8\u9ad8\u7b49\u6559\u80b2\u7684\u5b78\u8cbb\u4ee5\u53ca\u66f8\u7c4d\u8cbb\u7b49\u7b49\u3002\u56e0\u70ba\u5176\u5177\u6709\u6295\u8cc7\u589e\u9577\u7684\u90e8\u5206\u5728\u7528\u65bc\u5927\u5b78\u6559\u80b2\u6642\u4e0d\u7528\u8ab2\u7a05\u7684\u7279\u8cea\uff0c\u65bc\u662f\u5e38\u8207Coverdell ESA \u540c\u70ba\u70ba\u5b69\u5b50\u6e96\u5099\u6559\u80b2\u57fa\u91d1\u7684\u5de5\u5177\u3002\u5be6\u969b\u4e0a\u7684\u64cd\u4f5c\u662f\uff0c\u82e5\u662f\u5f9e529\u6559\u80b2\u57fa\u91d1\u4e2d\u62ff\u9322\u51fa\u4f86\uff0c\u6703\u6536\u52301099Q\u7684\u8868\u683c\u3002\u7d0d\u7a05\u4eba\u8981\u81ea\u884c\u8a08\u7b97\u53ca\u7533\u5831\u8ab2\u7a05\u91d1\u984d\u3002<\/p>\n<p>\u800c\u7a05\u6539\u5728\u5e33\u6236\u4e2d\u7684\u9322\u514d\u7a0e\u50c5\u80fd\u7528\u65bc\u9ad8\u7b49\u6559\u80b2\u9019\u4e00\u689d\u4e88\u4ee5\u653e\u5bdb\u3002\u7a05\u6539\u5f8c\u5408\u683c\u7684\u8cbb\u7528\u5305\u62ec\u4e86\u82b1\u5728\u5c0f\u5b78\u3001\u4e2d\u5b78\u3001\u516c\u7acb\u5b78\u6821\u3001\u79c1\u7acb\u5b78\u6821\u6216\u662f\u6559\u6703\u5b78\u6821\u7684\u8cbb\u7528\u3002Code Sec. 529(c)(7)\u4f46\u5728\u4e2d\u5c0f\u5b78\u8cbb\u7528\u7684\u90e8\u5206\u52a0\u4e86\u4e00\u689d\u4f46\u66f8- \u514d\u7a05\u7684\u7bc4\u570d\u50c5\u9650\u65bc\u6bcf\u4e00\u540d\u5b78\u751f\u4e00\u5e74\u4e00\u842c\u7f8e\u5143\u4e4b\u5167\u3002\u8d85\u904e\u7684\u90e8\u5206\u5c07\u6703\u670910%\u7684\u7f70\u6b3e\u3002<\/p>\n<p>\u7531\u65bc\u7a05\u6539\u4e0b\u653e\u5bdb\u4e86\u4e0d\u50c5\u9650\u65bc\u9ad8\u7b49\u6559\u80b2\u9019\u4e00\u689d\uff0c\u6240\u4ee5\u9084\u883b\u9069\u5408\u91cd\u8996\u5b69\u7ae5\u6559\u80b2\u7684\u5bb6\u9577\u5011\u8003\u616e\u3002<\/p>\n<p>\u800c529\u8a08\u5283\u6709\u6c92\u6709\u6295\u5165\u7684\u9650\u5236\uff1f\u57fa\u65bc\u8d08\u8207\u7a05\u7684\u8003\u91cf