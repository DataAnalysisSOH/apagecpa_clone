5dde\u90fd\u6709\u81ea\u5df1\u7684529\u8a08\u5283\uff0c\u800c\u4e14\u901a\u5e38\u6295\u5165\u4e5f\u4e0d\u9650\u81ea\u5df1\u672c\u5dde\u7684\u5c45\u6c11\u3002\u7b2c\u4e00\u500b529\u8a08\u5283\u662f\u7531 Michigan Education Trust \u5bc6\u897f\u6839\u6559\u80b2\u4fe1\u8a17\u57281986\u5e74\u6210\u7acb\u3002\u7a31\u70ba529\u7684\u539f\u56e0\u662f\u7531\u570b\u7a05\u5c40\u7684code 529\u800c\u4f86\u3002 \u5728\u806f\u90a6\u7a05\u4e0a\u7684\u8655\u7406\u662f\uff0c\u6295\u5165529\u6559\u80b2\u8a08\u5283\u7684\u9322\uff0c\u4e26\u4e0d\u80fd\u62b5\u6e1b\u7576\u5e74\u7684\u6240\u5f97\u7a05\u3002\u4f46\u662f\u5728\u5e33\u6236\u7576\u4e2d\u7684\u6295\u8cc7\u589e\u9577\u82e5\u63d0\u9818\u6642\u7528\u65bc\u5408\u683c\u7684\u7528\u9014\u6642\uff0c\u4e5f\u4e0d\u9700\u8ab2\u5fb5\u8cc7\u672c\u5229\u5f97\u7a05\u3002\u5728\u5dde\u7a05\u65b9\u9762\u7684\u8655\u7406\u5404\u5dde\u4e0d\u540c\u3002\u52a0\u5dde\u662f\u4e0d\u80fd\u7528529\u8a08\u5283\u7684\u6295\u5165\u62b5\u6e1b\u5dde\u7a05\u3002\u5728\u7a05\u6539\u4e4b\u524d\uff0c\u6240\u8b02\u7684\u5408\u683c\u7684\u7528\u9014\uff0c\u6307\u7684\u662f\u652f\u4ed8\u9ad8\u7b49\u6559\u80b2\u7684\u5b78\u8cbb\u4ee5\u53ca\u66f8\u7c4d\u8cbb\u7b49\u7b49\u3002\u56e0\u70ba\u5176\u5177\u6709\u6295\u8cc7\u589e\u9577\u7684\u90e8\u5206\u5728\u7528\u65bc\u5927\u5b78\u6559\u80b2\u6642\u4e0d\u7528\u8ab2\u7a05\u7684\u7279\u8cea\uff0c\u65bc\u662f\u5e38\u8207Coverdell ESA \u540c\u70ba\u70ba\u5b69\u5b50\u6e96\u5099\u6559\u80b2\u57fa\u91d1\u7684\u5de5\u5177\u3002\u5be6\u969b\u4e0a\u7684\u64cd\u4f5c\u662f\uff0c\u82e5\u662f\u5f9e529\u6559\u80b2\u57fa\u91d1\u4e2d\u62ff\u9322\u51fa\u4f86\uff0c\u6703\u6536\u52301099Q\u7684\u8868\u683c\u3002\u7d0d\u7a05\u4eba\u8981\u81ea\u884c\u8a08\u7b97\u53ca\u7533\u5831\u8ab2\u7a05\u91d1\u984d\u3002 \u800c\u7a05\u6539\u5728\u5e33\u6236\u4e2d\u7684\u9322\u514d\u7a0e\u50c5\u80fd\u7528\u65bc\u9ad8\u7b49\u6559\u80b2\u9019\u4e00\u689d\u4e88\u4ee5\u653e\u5bdb\u3002\u7a05\u6539\u5f8c\u5408\u683c\u7684\u8cbb\u7528\u5305\u62ec\u4e86\u82b1\u572