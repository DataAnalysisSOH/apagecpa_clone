u984c\u5c31\u662f\u6d77\u5916\u52de\u52d9\u6240\u5f97\u514d\u7a05\u3002(foreign income exclusion)\u800c\u6240\u8b02\u7684\u6d77\u5916\u52de\u52d9\u6240\u5f97\u514d\u7a05\u7684\u610f\u601d\u662f\uff0c\u82e5\u662f\u6eff\u8db3\u4e0b\u5217\u7684\u5169\u500b\u689d\u4ef6\u4e4b\u4e00\uff0c\u57282023\u5e74\u7684\u500b\u4eba\u7a05\u7a05\u8868\u4e0a\u81f3\u591a\u5c31\u6709\u5341\u4e8c\u842c\u7f8e\u5143\u7684\u514d\u7a05\u984d\u3002 \u800c\u9019\u5169\u500b\u8981\u4ef6\uff0c\u7b2c\u4e00\u662fBona Fide Residence test. \u8981\u6eff\u8db3\u9019\u9805\u6e2c\u8a66\uff0c\u7d0d\u7a05\u4eba\u5fc5\u9808\u662f\u4e0b\u5217\u4e4b\u4e00\uff1a1, \u7d0d\u7a05\u4eba\u70ba\u7f8e\u570b\u516c\u6c11\uff0c\u4f46\u662f\u662f\u5916\u570b\u7684Bona Fide resident(\u610f\u601d\u50cf\u662f\u9577\u5c45\u5883\u5916\u7684\u5916\u570b\u4eba\uff09\u800c\u4e14\u81f3\u5c11\u7b2c\u4e00\u5e74\u8981\u5728\u5883\u5916\u4f4f\u4e00\u6574\u5e74\uff0c \u6216\u662f\u7f8e\u570b\u7684\u7a05\u52d9\u5c45\u6c11\u4f46\u662f\u662f\u8207\u7f8e\u570b\u6709\u79df\u7a05\u604a\u8b70\u570b\u5bb6\u7684\u516c\u6c11\u6216\u662f\u5c45\u6c11\uff0c\u540c\u6642\u4e5f\u6eff\u8db3\u4e86Bona Fide residents, \u5373\u81f3\u5c11\u7b2c\u4e00\u5e74\u5728\u5883\u5916\u4f4f\u4e00\u6574\u5e74\u3002 \u81f3\u65bc\u662f\u5426\u70baBona Fide residents, \u8981\u770b\u7d0d\u7a05\u4eba\u7684\u610f\u5716\u3002\u5982\u679c\u7d0d\u7a05\u4eba\u53ea\u662f\u5728\u6d77\u5916\u77ed\u66ab\u7684\u9017\u7559\uff0c\u5c31\u4e0d\u662fBona Fide residents, \u4f46\u662f\u82e5\u662f\u7121\u9650\u671f\u7684\u5c45\u7559\uff0c\u4e26\u4e14\u5728\u5883\u5916\u4fdd\u6709tax home(\u7a05\u52d9\u623f\u5c4b\uff09\u90a3\u9ebd\u5c31\u6bd4\u8f03\u7b26\u5408Bona Fide residents \u7684\u5b9a\u7fa9 2, \u5be6\u969b\u51fa\u5e2d\u6e2c\u8a66\uff0c \u8981\u6eff\u8db3\u9019\u4e00\u6e2c\u8a66\uff0c\u7f8e\u570b\u516c\u6c11\u6216\u662f\u7a05\u52d9\u5c45\u6c11\u5fc5\u9808\u5728\u5341\u4e8c\u500b\u6708\u7576\u4e2d\u81f3\u5c11\u4e09\u767e\u4e09\u5341\u5929\u5728\u5883\u5916\u5c45\u7559\u3002 \u800c\u7406\u89e3\u4e0a\u7684\u8aa4\u5340\u662f\uff0c\u6709\u4eba\u4ee5\u70ba\u6240\u6709\u7684\u5883\u5916\u6240\u5f97\u53ea\u8981\u6eff\u8db3\u4e09\u767e\u4e09\u5341\u5929\u5c45\u7559\u5728\u5883\u5916\u7684\u689d\u4ef6\u90fd\u53ef\u4ee5\u7372\u5f97\u6e1b\u514d\u3002\u4f46\u662f\u9019\u4e00\u689d\u662f\u53ea\u9650\u7528\u65bc\u52de\u52d9\u6240\u5f97\uff0c\u800c\u4e14\u6709\u91d1\u984d\u4e0a\u7684\u9650\u5236\u3002\u800c\u8981\u4f7f\u7528\u6d77\u5916\u52de\u52d9\u6240\u5f97\u6e1b\u514d\uff0c\u8981\u4f7f\u7528\u8868\u683c2555\u3002 \u611f\u8b1d\u5927\u5bb6\u7684\u6536\u807d\u3002\u6211\u5011\u4e0b\u671f\u518d\u6703\u3002\" \/>\n<meta property=\"og:url\" content=\"https:\/\/agapecpa.com\/7461.html\" \/>\n<meta property=\"og:site_name\" content=\"\u611b\u52a0\u500d\u6703\u8a08\u5e2b\u4e8b\u52d9\u6240 - AGAPE CPA FIRM\" \/>\n<meta property=\"article:published_time\" content=\"2024-01-12T22:10:22+00:00\" \/>\n<meta property=\"article:modified_time\" content=\"2025-01-10T18:02:55+00:00\" \/>\n<meta property=\"og:image\" content=\"https:\/\/agapecpa.com\/wp-content\/uploads\/sites\/10\/2024\/01\/overseas.jpg\" \/>\n\t<meta property=\"og:image:width\" content=\"800\" \/>\n\t<meta property=\"og:image:height\" content=\"533\" \/>\n\t<meta property=\"og:image:type\" content=\"image\/jpeg\" \/>\n<meta name=\"author\" content=\"jeel\" \/>\n<meta name=\"twitter:card\" content=\"summary_large_image\" \/>\n<meta name=\"twitter:label1\" content=\"Written by\" \/>\n\t<meta name=\"twitter:data1\" content=\"jeel\" \/>\n\t<meta name=\"twitter:label2\" content=\"Est. reading time\" \/>\n\t<meta name=\"twitter:data2\" content=\"1 minute\" \/>\n<script type=\"application\/ld+json\" class=\"yoast-schema-graph\">{\"@context\":\"https:\/\/schema.org\",\"@graph\":[{\"@type\":\"Article\",\"@id\":\"https:\/\/agapecpa.com\/7461.html#article\",\"isPartOf\":{\"@id\":\"https:\/\/agapecpa.com\/7461.html\"},\"author\":{\"name\":\"jeel\",\"@id\":\"https:\/\/agapecpa.com\/#\/schema\/person\/1eb0574c9dfb60616209