6\u5225\u8ad6\u3002\u82e5\u662f\u56e0\u70ba\u4ea4\u6613\u8cc7\u672c\u8ca1\u7684\u640d\u5931\u6216\u5229\u5f97\uff0c\u5247\u7533\u5831\u65bcschedule D\u4e0a\u3002\u800cschedule D\u4e0a\u57fa\u672c\u4e0a\u5206\u70ba\u5169\u500b\u90e8\u5206\u3002\u4e0a\u534a\u6bb5\u70ba\u77ed\u671f\u8cc7\u672c\u5229\u5f97\u8207\u640d\u5931\u3002\u800c\u4e0b\u534a\u6bb5\u70ba\u9577\u671f\u8cc7\u672c\u5229\u5f97\u8207\u640d\u5931\u3002\u800c\u9577\u671f\u8207\u77ed\u671f\u7684\u5206\u754c\u5728\u65bc\u6301\u6709\u7684\u6642\u9593\u3002\u82e5\u662f\u6301\u6709\u7684\u6642\u9593\u77ed\u65bc\u4e00\u5e74\uff0c\u5247\u8996\u70ba\u77ed\u671f\u3002\u82e5\u6301\u6709\u7684\u6642\u9593\u5927\u65bc\u4e00\u5e74\uff0c\u5247\u8996\u70ba\u9577\u671f\u3002\u8981\u7559\u610f\u7684\u662f\uff0c\u96d6\u7136\u90fd\u5728schedule D\u7684\u4e0a\u9762\uff0c\u4f46\u662f\u9577\u77ed\u671f\u7684\u7a05\u7387\u4e26\u4e0d\u76f8\u540c\u3002\u77ed\u671f\u8cc7\u672c\u5229\u5f97\u7684\u7a05\u7387\u8207\u6240\u8b02\u7684\u6b63\u5e38\u6240\u5f97\u76f8\u540c\uff0c\u70ba\u7d2f\u9032\u7a05\u7387\uff0c\u6700\u9ad8\u7a05\u7d1a\u70ba37%\u3002\u800c\u9577\u671f\u8cc7\u672c\u5229\u5f97\u7684\u7a05\u7387\uff0c\u5728\u806f\u90a6\u7684\u7a05\u8868\u4e0a\u4eab\u6709\u512a\u60e0\u7a05\u7387\uff0c\u6839\u64da\u7d0d\u7a05\u4eba\u8ab2\u7a05\u6240\u5f97\u7684\u4e0d\u540c\u4f86\u5206\u5225\u8a08\u7b97\u9577\u671f\u8cc7\u672c\u5229\u5f97\u7a05\u3002\u7576\u4e2d\u5206\u5225\u70ba0%\uff0c 15%\uff0c 20%\uff0c\u4e09\u500b\u7a05\u7d1a\u3002\u7531\u65bc\u9577\u77ed\u671f\u8cc7\u672c\u5229\u5f97\u7684\u7a05\u7387\u76f8\u5dee\u5f88\u5927\uff0c\u6709\u9f13\u52f5\u9577\u671f\u6301\u6709\u6295\u8cc7\u7684\u610f\u5716\u5728\u5167\u3002\u8981\u7559\u610f\u7684\u662f\uff0c\u52a0\u5dde\u5c0d\u65bc\u9577\u671f\u8cc7\u672c\u5229\u5f97\u4e26\u6c92\u6709\u6240\u8b02\u7684\u512a\u60e0\u7a05\u7387\u3002<\/p>\n<p>\u5728\u8868\u683c\u7684\u7d50\u69cb\u65b9\u9762\uff0c\u77ed\u671f\u7684\u8cc7\u672c\u5229\u5f97\u53ef\u8207\u77ed\u671f\u7684\u8cc7\u672c\u640d\u5931\u