cd5\u6848\u4e2d\u5c0d\u500b\u4eba\u548c\u4f01\u696d\u6240\u5f71\u97ff\u7684\u7a05\u52d9\u5167\u5bb9\u3002 \u91dd\u5c0d\u500b\u4eba\u7684\u90e8\u5206\u6709\u5982\u4e0b\u65b9\u6848\uff1a \u5728\u9019\u4e00\u6ce2\u7684\u75ab\u60c5\u7576\u4e2d\uff0c\u6709\u7684\u4eba\u662f\u56e0\u70ba\u9813\u6642\u6c92\u6709\u6536\u5165\uff0c\u6216\u662f\u6709\u7684\u4eba\u56e0\u70ba\u5728\u80a1\u5e02\u5927\u8dcc\u800c\u8981\u5c07401k \u88e1\u7684\u9322\u79fb\u81f3\u5176\u4ed6\u98a8\u96aa\u66f4\u5c0f\u7684\u91d1\u878d\u5de5\u5177\u3002\u800c\u5728\u9019\u500b\u7d13\u56f0\u689d\u6b3e\u4e4b\u524d\uff0c\u6240\u6709\u9054\u9000\u4f11\u5e74\u9f61\u7684\u63d0\u65e9\u81f3\u9000\u4f11\u8a08\u5283\uff08IRA \u53ca401k)\u4e2d\u53d6\u51fa\u7684\u91d1\u984d\uff0c\u6703\u6709\u767e\u5206\u4e4b\u5341\u63d0\u65e9\u53d6\u51fa\u7684\u7f70\u6b3e\u3002\u4f46\u662f\u5728\u9019\u500b\u7d13\u56f0\u8a08\u5283\u4e4b\u4e0b\uff0c\u82e5\u662f\u56e0\u70ba\u65b0\u51a0\u75c5\u6bd2\u7684\u5f71\u97ff\u800c\u4e14\u63d0\u65e9\u53d6\u51fa\u7684\u91d1\u984d\u82e5\u662f\u5728\u5341\u842c\u7f8e\u5143\u4e4b\u5167\u514d\u7f70\u3002\u4e26\u4e14\u65e5\u5f8c\u53ef\u4ee5\u518d\u6839\u64da\u6307\u793a\u91cd\u65b0\u5b58\u5165\u9000\u4f11\u91d1\u8a08\u5283\u4e4b\u4e2d\u3002\u4e0d\u50c5\u5982\u6b64\uff0c\u56e0\u70ba\u63d0\u524d\u53d6\u51fa\u6240\u9020\u6210\u7684\u6536\u5165\uff0c\u53ef\u4ee5\u5206\u6210\u4e09\u5e74\u4f86\u8ab2\u7a05\uff0c\u4f46\u662f\u7d0d\u7a05\u4eba\u4e5f\u53ef\u4ee5\u9078\u64c7\u4e00\u6b21\u6027\u8ab2\u7a05\u3002 \u540c\u6642\uff0c\u57282020\u5e74\u7684RMD\u6700\u4f4e\u8981\u7531\u9000\u4f11\u5e33\u6236\u6240\u53d6\u51fa\u7684\u9322\uff0c\u66ab\u505c\u3002 \u5728\u9019\u500b\u7d13\u56f0\u8a08\u5283\u4e2d\uff0c\u4e5f\u5927\u5e45\u653e\u5bec\u4e86\u5c0d\u65bc\u6148\u5584\u6350\u6b3e\u6263\u62b5\u7684\u9650\u5236\u3002\u4ee5\u5f80\uff0c\u6148\u5584\u6350\u6b3e\u7684\u6263\u62b5\u662f\u5728\u5217\u8209\u6263\u9664\u984d\u4e4b\u4e0b\uff0c\u4e26\u4e14\u670960%MAGI\u7684\u9650\u5236\u3002\u4f46\u662f\u5728\u6b64\u7d13\u56f0\u689d\u6b3e\u4e0b\uff0c\u5c31\u662f\u5e73\u5e38\u4f7f\u7528\u5217\u8209\u6263\u9664\u7684\u7d0d\u7a05\u4eba\u7684\u73fe\u91d1\u6350\u8d08\uff0c\u90fd\u53ef\u4ee5\u4eab\u53d7\u4e09\u767e\u7f8e\u5143\u7684\u6536\u5165\u8abf\u6574above the line deduction.\u800c\u57282020\u7684\u516c\u773e\u6148\u5584\u6350\u6b3e\uff0c\u4e26\u4e0d\u53d7\u9019\u767e\u5206\u4e4b\u516d\u5341\u7684MAGI\u7684\u9650\u5236\u3002\u800c\u6148\u5584\u6350\u6b3e\u672c\u8eab\u4e5f\u4e0d\u4e00\u5b9a\u8981\u8207\u65b0\u51a0\u75c5\u6bd2\u76f8\u95dc\u3002\u53ea\u662f\u8981\u7279\u5225\u7559\u610f\u7684\u662f\uff0c\u7d0d\u7a05\u4eba\u5982\u679c\u8981\u7372\u5f97\u6240\u5f97\u7a05\u7684\u62b5\u6e1b\uff0c\u4e00\u5b9a\u8981\u6350\u7d66\u5728\u7f8e\u570b\u570b\u7a05\u5c40\u8a3b\u518a\u6709\u6848\u7684\u975e\u71df\u5229\u7d44\u7e54\u3002 \u5728\u73fe\u884c\u689d\u6b3e\u4e0b\uff0c\u50f1\u4e3b\u53ef\u4ee5\u66ff\u54e1\u5de5\u4ed8\u6559\u80b2\u8cbb\u7528\uff0c\u5728$5,250\u4ee5\u4e0b\uff0c\u4e0d\u5217\u5165\u54e1\u5de5\u7684\u6240\u5f97\u3002\u5728\u6b64\u7d13\u56f0\u4e4b\u4e0b\uff0c\u653e\u5bec\u4e86\u5408\u683c\u8cbb\u7528\u7684\u5b9a\u7fa9\u3002 \u63d0\u4f9b\u500b\u4eba\u88dc\u52a9\u91d1\u8a08\u5283\u3002\u7b26\u5408\u8cc7\u683c\u7684\u7d0d\u7a05\u4eba\uff0c\u6700\u591a\u53ef\u4ee5\u5f97\u5230\u4e00\u5343\u5169\u767e\u7f8e\u5143\u7684\u88dc\u52a9\u3002\u82e5\u662f\u592b\u59bb\u5408\u4f75\u7533\u5831\u5247\u53ef\u4ee5\u5f97\u5230\u81f3\u591a\u5169\u5343\u56db\u767e\u7f8e\u5143\u7684\u88dc\u52a9\u3002\u82e5\u662f\u6709\u5341\u4e03\u6b72\u4ee5\u4e0b\u7684\u5408\u683c\u5b69\u7ae5\uff0c\u6bcf\u4e00\u500b\u5b69\u5b50\u53ef\u4ee5\u518d\u8ffd\u52a0\u4e94\u767e\u7f8e\u5143\u7684\u88dc\u52a9\u3002\u80fd\u5920\u5f97\u5230\u88dc\u52a9\u7684\u91d1\u984d\uff0c\u8996\u7d0d\u7a05\u4eba\u7684\u6240\u5f97\u800c\u5b9a\u3002\u500b\u4eba\u8abf\u6574\u6240\u5f97\uff08AGI\uff09\u7531\u4e03\u842c\u4e94\u5343\u7f8e\u5143\u958b\u59cb\u905e\u6e1b\uff0c \u592b\u59bb\u5408\u4f75\u7533\u5831\u91d1\u984d\u5247\u70ba\u7531\u5341\u4e94\u842c\u7f8e\u5143\u958b\u59cb\u905e\u6e1b\u3002\u8981\u7559\u610f\u9019\u9805\u88dc\u52a9\u4e26\u4e0d\u9069\u7528\u975e\u7a05\u52d9\u5c45\u6c11\uff08nonresident aliens\uff09\u4fe1\u8a17\uff0c\u53ca\u5df2\u7d93\u5217\u70ba\u5176\u4ed6\u4eba\u7684\u64ab\u990a\u89aa\u5c6c\u4e4b\u500b\u4eba\u3002 \u9019\u9805\u500b\u4eba\u88dc\u52a9\u8a08\u5283\u6703\u4ee5\u652f\u7968\u6216\u662f\u76f4\u63a5\u6ed9\u6b3e\u7684\u5f62\u5f0f\u9001\u51fa\u3002\u4e00\u822c\u7684\u7d0d\u7a05\u4eba\u4e0d\u9700\u8981\u6709\u7279\u5225\u7684\u7533\u8acb\u7a0b\u5e8f\u3002\u570b\u7a05\u5c40\u6703\u6839\u64da2018\u6216\u662f2019\u7684\u7a05\u8868\u4f86\u6c7a\u5b9a\u767c\u653e\u7684\u91d1\u984d\u3002\u6240\u4ee5\uff0c\u570b\u7a05\u5c40\u547c\u7c72\u82e5\u662f\u9084\u6c92\u6709\u7533\u58312018\u6216\u662f2019\u7a05\u8868\u7684\u7d0d\u7a05\u4eba\u61c9\u8a72\u5118\u5feb\u7684\u7533\u5831\u3002\u4f46\u662f\u5df2\u7d93\u5728\u9818\u793e\u6703\u5b89\u5168\u91d1\u7684\u8006\u82f1\u5247\u4e0d\u9700\u8981\u901a\u904e\u5831\u7a05\u4f86\u62ff\u5230\u6b64\u9805\u88dc\u52a9\u3002 \u5e0c\u671b\u4e0a\u8ff0\u7684\u8a0a\u606f\u80fd\u5c0d\u60a8\u6709\u6240\u52a9\u76ca\u3002\u4e26\u4e14\u795d\u9858\u5927\u5bb6\u5168\u5bb6\u5e73\u5b89\u5065\u5eb7\u3002 \u6797\u61ff\u00a0 \u6703\u8a08\u5e2b 4\/13\/20 Cupertino\" \/>\n<meta property=\"og:url\" content=\"https:\/\/agapecpa.com\/2073.html\" \/>\n<meta property=\"og:site_name\" content=\"\u611b\u52a0\u500d\u6703\u8a08\u5e2b\u4e8b\u52d9\u6240 - AGAPE CPA FIRM\" \/>\n<meta property=\"article:published_time\" content=\"2020-04-14T03:01:53+00:00\" \/>\n<meta property=\"article:modified_time\" content=\"2022-12-24T02:49:30+00:00\" \/>\n<meta property=\"og:image\" content=\"https:\/\/agapecpa.com\/wp-content\/uploads\/sites\/10\/2020\/04\/finance-2D4THV5.jpg\" \/>\n\t<meta property=\"og:image:width\" content=\"600\" \/>\n\t<meta property=\"og:image:height\" content=\"400\" \/>\n\t<meta property=\"og:image:type\" content=\"image\/jpeg\" \/>\n<meta name=\"author\" content=\"corey.lee