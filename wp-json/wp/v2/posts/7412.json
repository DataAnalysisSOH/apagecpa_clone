\u6c11\u5728\u7a05\u52d9\u4e0a\u7684\u5b9a\u7fa9\u3002\u56e0\u70ba\u4e0d\u8ad6\u662f\u5728\u4eba\u6587\uff0c\u81ea\u7136\u666f\u89c0\uff0c\u5929\u6c23\u4e43\u81f3\u6211\u5011\u83ef\u4eba\u6700\u91cd\u8996\u7684\u7f8e\u98df\uff0c\u52a0\u5dde\u90fd\u7336\u5982\u7f8e\u570b\u9019\u9802\u7687\u51a0\u4e0a\u7684\u5bf6\u77f3\uff0c\u7121\u6127\u65bc\u9ec3\u91d1\u5dde\u7684\u7a31\u865f\u3002\u7136\u800c\uff0c\u4eab\u53d7\u52a0\u5dde\u7684\u967d\u5149\u5c0d\u65bc\u9ad8\u6240\u5f97\u7684\u65cf\u7fa4\u8981\u50f9\u4e0d\u6590\u3002\u52a0\u5dde\u7684\u6700\u9ad8\u6240\u5f97\u7a05\u7a05\u7d1a\u70ba12.3%, \u82e5\u662f\u6240\u5f97\u8d85\u904e\u4e00\u767e\u842c\u7f8e\u5143\u7684\u7d0d\u7a05\u4eba\uff0c\u9084\u8981\u7e73\u4ea41%\u7684\u7cbe\u795e\u5065\u5eb7\u670d\u52d9\u7a05(mental health service tax)\u6240\u4ee5\uff0c\u52a0\u5dde\u7684\u6700\u9ad8\u6240\u5f97\u7a05\u7a05\u738713.3%\u76ee\u524d\u70ba\u5168\u7f8e\u4e4b\u51a0,\u6bd4\u5c48\u5c45\u4e9e\u8ecd\u7684\u590f\u5a01\u5937\u768411%\u9ad8\u51fa\u4e862.3%, \u53c8\u6bd4\u540c\u70ba\u85cd\u5dde,\u6392\u540d\u7b2c\u4e03\u7d10\u7d04\u5dde\u76848.82%\u591a\u51fa\u4e864.48%. \u82e5\u662f\u60a8\u662f\u5168\u5e74\u5ea6\u7684\u52a0\u5dde\u5c45\u6c11\uff0c\u5247\u4f7f\u7528\u8868\u683c540, \u5168\u7403\u6240\u5f97\u90fd\u5c07\u4f75\u5165\u52a0\u5dde\u7684\u7a05\u8868\u4e2d\u8a08\u7b97\u3002\u800c\u4e14\u52a0\u5dde\u5c0d\u65bc\u5883\u5916\u6240\u5f97\u4e26\u6c92\u6709\u50cf\u806f\u90a6\u4e00\u6a23\u6709\u6240\u7684\u5883\u5916\u85aa\u8cc7\u6e1b\u514d(foreign income exclusion)\u53ca\u5883\u5916\u7684\u6240\u5f97\u7a05\u88dc\u52a9\uff08foreign tax credit), \u5982\u679c\u6709\u5b69\u5b50\u8981\u4e0a\u52a0\u5dde\u7684\u516c\u7acb\u5927\u5b78\uff0c\u52a0\u5dde\u5c45\u6c11\u7684\u8eab\u5206\u53ef\u4ee5\u53d6\u5f97\u512a\u60e0\u7684\u5b78\u8cbb\u3002\u5982\u679c\u60a8\u662f\u975e\u52a0\u5dde\u5c45\u6c11\u6216\u662f\u90e8\u5206\u6642\u9593\u7684\u52a0\u5dde\u5c45\u6c11(part year resident)\u4f7f\u7528\u8868\u683c540NR, \u50c5\u5c31\u52a0\u5dde\u7684\u4f86\u6e90\u6240\u5f97\u4f86\u8ab2\u7a05\u3002 \u81f3\u65bc\u5982\u4f55\u5224\u65b7\u7d0d\u7a05\u4eba\u662f\u5426\u70ba\u52a0\u5dde\u5c45\u6c11\uff0c\u5efa\u8b70\u95b2\u8b80FTB\u76841031\u865f\u51fa\u7248\u7269\uff08publication 1031)\u88e1\u9762\u6709\u5217\u51fa\u5f88\u591a\u9805\u7684\u5224\u65b7\u6a19\u6e96\uff0c\u6211\u5011\u5728\u4e0b\u671f\u7684\u7bc0\u76ee\u7576\u4e2d\u6703\u70ba\u5404\u4f4d\u8a73\u7d30\u8aaa\u660e\u3002 \u6709\u8208\u8da3\u7684\u670b\u53cb\u53ef\u4ee5\u4e0a\u6211\u5011\u4e8b\u52d9\u6240\u7684\u5b98\u7db2www.agapecpa.com\u7372\u53d6\u66f4\u591a\u7684\u7a05\u52d9\u8cc7\u8a0a,\u6216\u81f4\u96fb\u6211\u5011Cupertino \u7684\u8fa6\u516c\u5ba4408-725-1700\u3002 \u611f\u8b1d\u5927\u5bb6\u7684\u6536\u807d\uff0c\u6211\u5011\u4e0b\u671f\u518d\u6703\u3002","og_url":"https:\/\/agapecpa.com\/7412.html","og_site_name":"\u611b\u52a0\u500d\u6703\u8a08\u5e2b\u4e8b\u52d9\u6240 - AGAPE CPA FIRM","article_published_time":"2023-01-08T20:10:08+00:00","article_modified_time":"2025-01-10T18:02:55+00:00","og_image":[{"width":600,"height":400,"url":"https:\/\/agapecpa.com\/wp-content\/uploads\/sites\/10\/2023\/01\/CA-tax.jpg","type":"image\/jpeg"}],"author":"jeel","twitter_card":"summary_large_image","twitter_misc":{"Written by":"jeel","Est. reading time":"1 minute"},"schema":{"@context":"https:\/\/schema.org","@graph":[{"@type":"Article","@id":"https:\/\/agapecpa.com\/7412.html#article","isPartOf":{"@id":"https:\/\/agapecpa.com\/7412.html"},"author":{"name":"jeel","@id":"https:\/\/agapecpa.com\/#\/schema\/person\/1eb0574c9dfb6061620972a4b4069934"},"headline":"\u6211\u662f\u8ab0\u7cfb\u5217\u4e4b\uff1a\u6211\u662f\u52a0\u5dde\u5c45\u6c11\u55ce\uff1fI","datePublished":"2023-01-08T20:10:08+00:00","dateModified":"2025-01-10T18:02:55+00:00","mainEntityOfPage":{"@id":"https:\/\/agapecpa.com\/7412.html"},"wordCount":23,"publisher":{"@id":"https:\/\/agapecpa.com\/#organization"},"image":{"@id":"https:\/\/agapecpa.com\/7412.html#primaryimage"},"thumbnailUrl":"https:\/\/agapecp