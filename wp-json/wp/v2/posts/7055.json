{"id":7055,"date":"2021-06-22T18:53:08","date_gmt":"2021-06-23T01:53:08","guid":{"rendered":"https:\/\/agapecpa.com\/?p=7055"},"modified":"2022-12-22T18:56:58","modified_gmt":"2022-12-23T02:56:58","slug":"%e8%a7%a3%e8%ae%80%e7%be%8e%e5%9c%8b%e5%89%8d%e4%ba%8c%e5%8d%81%e4%ba%94%e5%a4%a7%e5%af%8c%e8%b1%aa%e7%9a%84%e3%80%8d%e7%9c%9f%e5%af%a6%e7%a8%85%e7%8e%87","status":"publish","type":"post","link":"https:\/\/agapecpa.com\/7055.html","title":{"rendered":"\u89e3\u8b80\u7f8e\u570b\u524d\u4e8c\u5341\u4e94\u5927\u5bcc\u8c6a\u7684\u300d\u771f\u5be6\u7a05\u7387"},"content":{"rendered":"<h3><\/h3>\n<h3>\u7bc0\u76ee\u6642\u9577\uff1a6\u520639\u79d2\u00a0 \u00a0 <strong>\u4e3b\u6301\u4eba\uff1a\u5343\u745e\uff0f\u5609\u8cd3\uff1a\u6797\u61ff\u6703\u8a08\u5e2b<\/strong><\/h3>\n<p>\u25c7 \u7bc0\u76ee\u63d0\u8981<\/p>\n<p>\u5728\u4ee5\u5f80\u7684\u6587\u7ae0\u4e2d\uff0c\u6211\u5011\u90fd\u975e\u5e38\u6b63\u7d93\u516b\u767e\u7684\u548c\u5927\u5bb6\u804a\u5f88\u56b4\u8085\u7684\u7a05\u6cd5\u898f\u5b9a\u3002\u4f46\u662f\u4eca\u5929\u5c31\u548c\u5927\u5bb6\u804a\u4e00\u804a\u7a05\u52d9\u516b\u5366\u3002<\/p>\n<p>\u6700\u8fd1\u5e7e\u5929\u71b1\u9580\u7684\u7a05\u52d9\u516b\u5366\u4e4b\u4e00\uff0c\u61c9\u8a72\u5c31\u662fProPublica \u6240\u6d29\u9732\u7684\u7f8e\u570b\u524d\u4e8c\u5341\u4e94\u5927\u5bcc\u8c6a\u7684\u300d\u771f\u5be6\u7a05\u7387\u300d\u7adf\u7136\u90fd\u53ea\u6709\u500b\u4f4d\u6578\u5b57\uff01\u5687\u5f97\u6211\u8d95\u7dca\u53bb\u7ffb\u770b\u5176\u4e2d\u7684\u7d30\u7bc0\uff0c\u514d\u5f97\u5ba2\u6236\u4e0a\u9580\u8e3c\u9928\u8aaa- \u6797\u6703\u8a08\u5e2b\uff0c\u4f60\u80fd\u4e0d\u80fd\u60f3\u60f3\u8fa6\u6cd5\u8b93\u6211\u7684\u7a05\u7387\u4e5f\u8b8a\u6210\u500b\u4f4d\u6578\u5b57\uff1f<\/p>\n<p>\u8981\u77ad\u89e3\u9019\u4ef6\u4e8b\uff0c\u9996\u5148\u8981\u5148\u77ad\u89e3\u7f8e\u570b\u7684\u500b\u4eba\u7a05\u662f\u4e00\u7a2e\u6240\u5f97\u7a05\u3002\u9867\u540d\u601d\u7fa9\uff0c\u662f\u91dd\u5c0d\u6240\u5f97\u800c\u8ab2\u5fb5\u7684\u7a05\u3002\u4f8b\u5982\u8aaa\u662f\u85aa\u8cc7\u6240\u5f97\uff0c\u500b\u4eba\u57f7\u884c\u696d\u52d9\u6240\u5f97\uff0c\u51fa\u552e\u80a1\u7968\u53ca\u623f\u5c4b\u7684\u8cc7\u672c\u5229\u5f97\u53ca\u5229\u606f\u8207\u80a1\u5229\u6240\u5f97\u7b49\u7b49\u3002\u800c\u4e00\u822c\u5728\u7a05\u52d9\u4e0a\u6703\u63d0\u5230\u7684\u540d\u8a5e\u662f\u908a\u969b\u7a05\u7387\u53ca\u6709\u6548\u7a05\u7387\u3002\u6240\u8b02\u7684\u908a\u969b\u7a05\u7387\uff0c\u6307\u7684\u662f\u6240\u5f97\u9054\u5230\u7684\u7a05\u7d1a\u3002\u800c\u6709\u6548\u7a05\u7387\u6307\u7684\u662f\u6240\u5f97\u7a05\u9664\u4ee5\u7a05\u524d\u6240\u5f97\u3002\u7136\u800c\u5728ProPublica\u6240\u63d0\u51fa\u7684\u6982\u5ff5\u8207\u4e0a\u8ff0\u6982\u5ff5\u622a\u7136\u4e0d\u540c\u3002\u4ed6\u5011\u7a31\u5176\u70ba\u300d\u771f\u5be6\u7a05\u7387\u300d \u5176\u8a08\u7b97\u65b9\u5f0f\u662f\u5176\u6240\u652f\u4ed8\u7684\u6240\u5f97\u7a05\u9664\u4ee5\u8a72\u5e74\u5ea6\u4f30\u8a08\u7684\u8ca1\u5bcc\u589e\u9577\u3002\u9019\u7a2e\u6bd4\u8f03\u65b9\u5f0f\uff0c\u6709\u4e00\u9ede\u4e0d\u7576\u985e\u6bd4\uff0c\u56e0\u70ba\u4e0d\u662f\u4ee5\u6240\u5f97\u8207\u6240\u5f97\u7a05\u76f8\u6bd4\uff0c\u800c\u662f\u4ee5\u6240\u5f97\u7a05\u8207\u8cc7\u7522\u589e\u52a0\u76f8\u6bd4\u3002\u4ee5\u4e9e\u99ac\u905c\u7684\u8ca1\u52d9\u9577\u8c9d\u4f50\u65af\u70ba\u4f8b\uff0c\u57282006\u81f32018\u5e74\u5176\u9593\uff0c\u4ed6\u652f\u4ed8\u4e86$1.4B\u7684\u806f\u90a6\u500b\u4eba\u6240\u5f97\u7a05\uff0c\u5176\u7533\u5831\u6240\u5f97\u70ba$6.5B, \u4f30\u8a08\u9019\u6bb5\u5176\u9593\u7684\u8ca1\u5bcc\u589e\u9577\u70ba$127B\uff0c\u6240\u4ee5\u6839\u64daProPublica\u7684\u8a08\u7b97\uff0c\u5176\u300d\u771f\u5be6\u7a05\u7387\u300d\u70ba1.1%\uff08$1.4B\/$127B) \u4f46\u5c31\u4e00\u822c\u8a08\u7b97\u6709\u6548\u7a05\u7387\u7684\u65b9\u5f0f\uff0c\u8c9d\u4f50\u65af\u7684\u6709\u6548\u7a05\u7387\uff0c\u61c9\u8a72\u70ba21.54%($1.4B\/$6.5B)\u3002\u518d\u4ee5\u5716\u5217\u7684\u53e6\u4e00\u540d\u4eba\uff0c\u80a1\u795e\u5df4\u83f2\u7279\u70ba\u4f8b\uff0c\u6839\u64daProPublica\u7684\u8a08\u7b97\uff0c\u5176\u300d\u771f\u5be6\u7a05\u7387\u300d\u70ba0.1%\uff0c\u4f46\u662f\u82e5\u662f\u53bb\u8a08\u7b97\u5176\u6709\u6548\u7a05\u7387\u5247\u70ba18.96%\uff08$23.7M\/$125M). \u9019\u500b\u8a08\u7b97\u7d50\u679c\u8207Zucman, \u4f0a\u8389\u838e\u767d\u83ef\u502b\uff08Elizabeth Warren\u300fs)\u7684\u5e55\u5f8c\u7d93\u6fdf\u5b78\u5bb6\u63d0\u51fa\u7684\u6578\u64da\u76f8\u4f3c\u3002\u6839\u64da\u4ed6\u7684\u5206\u6790\uff0c\u7f8e\u570b\u524d\u56db\u767e\u540d\u7684\u5bcc\u8c6a\uff0c\u5176\u5e73\u5747\u7684\u6240\u5f97\u7a05\u7a05\u7387\u70ba23%.<\/p>\n<p>\u800c\u70ba\u4ec0\u9ebc\u96d6\u7136\u7f8e\u570b\u73fe\u884c\u7684\u6700\u9ad8\u7a05\u7d1a\u70ba37%\uff0c\u9019\u4e9b\u5bcc\u8c6a\u5011\u7684\u7a05\u7387\u537b\u9060\u4f4e\u65bc\u6700\u9ad8\u7a05\u7d1a\u5462\uff1f\u539f\u56e0\u61c9\u8a72\u662f\u9019\u4e9b\u5927\u5bcc\u8c6a\u7684\u6536\u5165\u7d50\u69cb\u61c9\u8a72\u6c92\u6709\u5927\u91cf\u7684\u52de\u52d9\u6240\u5f97\uff0c\u800c\u53ef\u80fd\u5074\u91cd\u65bc\u6295\u8cc7\u6536\u76ca\uff0c\u800c\u5728\u73fe\u884c\u7684\u7a05\u6cd5\u4e0b\uff0c\u806f\u90a6\u7684\u9577\u671f\u8cc7\u672c\u5229\u5f97\u7684\u6700\u9ad8\u7a05\u7387\u70ba20%\uff0c \u518d\u52a0\u4e0a3.8%\u7684\u6295\u8cc7\u6536\u76ca\u7a05\u3002\uff08investment tax), \u518d\u52a0\u4e0a\u623f\u5730\u7522\u4e0a\u4f7f\u75281031\u4ea4\u63db\u4f86\u905e\u5ef6\u6240\u5f97\u7a05\uff0c\u6240\u4ee5\u5373\u4fbf\u6709\u9ad8\u984d\u7684\u6240\u5f97\u4f46\u4ecd\u7136\u53ef\u4ee5\u5c07\u5176\u7684\u6709\u6548\u7a05\u7387\u62c9\u4f4e\u3002\u9019\u4e5f\u662f\u5df4\u83f2\u7279\u5728\u6578\u5e74\u524d\u63d0\u5230\u4ed6\u7684\u6240\u5f97\u7a05\u7a05\u7387\u4f4e\u65bc\u4ed6\u7684\u79d8\u66f8\u7684\u539f\u56e0\u3002\u4ee5\u53ca\u5728\u73fe\u4efb\u7e3d\u7d71\u62dc\u767b\u7684\u7a05\u6539\u63d0\u6848\u4e2d\uff0c\u5e0c\u671b\u80fd\u5c0d\u65bc\u6240\u5f97\u8d85\u904e\u4e00\u767e\u842c\u7f8e\u5143\u4ee5\u4e0a\u7684\u7d0d\u7a05\u4eba\uff0c\u5c07\u5176\u9577\u671f\u8cc7\u672c\u5229\u5f97\u7684\u7a05\u7387\u63d0\u9ad8\u81f339.6%, \u56e0\u70ba\u62dc\u767b\u8a8d\u70ba\u5982\u6b64\u4e00\u4f86\uff0c\u624d\u80fd\u8b93\u9245\u5bcc\u5011\u652f\u4ed8\u4ed6\u5011\u61c9\u4ed8\u7684\u7a05\u6b3e\uff08fair share).<\/p>\n<p>\u4e3b\u6301\u4eba\uff1a\u5343\u745e<\/p>\n<p>\u5609\u8cd3\uff1a\u6797\u61ff\u6703\u8a08\u5e2b<\/p>\n<p>\u5609\u8cd3\u96fb\u8a71\uff1a408-725-1700<\/p>\n","protected":false},"excerpt":{"rendered":"6\u520639\u79d2\u00a0 \u00a0 \u4e3b\u6301\u4eba\uff1a\u5343\u745e\uff0f\u5609\u8cd3\uff1a\u6797\u61ff\u6703\u8a08\u5e2b\r\n\r\n\u89e3\u8b80\u7f8e\u570b\u524d\u4e8c\u5341\u4e94\u5927\u5bcc\u8c6a\u7684\u300d\u771f\u5be6\u7a05\u7387\u300d","protected":false},"author":1,"featured_media":7034,"comment_status":"closed","ping_status":"closed","sticky":false,"template":"","format":"audio","meta":{"episode_type":"audio","audio_file":"http:\/\/media.soundofhope.org\/audio04\/2021-06\/1624373412636.mp3","cover_image":"","cover_image_id":"","duration":"00:06:39","filesize":"5.91M","filesize_raw":"6201140","date_recorded":"2021-06-22 18:53:08","explicit":"","block":"","ocean_post_layout":"","ocean_both_sidebars_style":"","ocean_both_sidebars_content_width":0,"ocean_both_sidebars_sidebars_width":0,"ocean_sidebar":"0","ocean_second_sidebar":"0","ocean_disable_margins":"enable","ocean_add_body_class":"","ocean_shortcode_before_top_bar":"","ocean_shortcode_after_top_bar":"","ocean_shortcode_before_header":"","ocean_shortcode_after_header":"","ocean_has_shortcode":"","ocean_shortcode_after_title":"","ocean_shortcode_before_footer_widgets":"","ocean_shortcode_after_footer_widgets":"","ocean_shortcode_before_footer_bottom":"","ocean_shortcode_after_footer_bottom":"","ocean_display_top_bar":"default","ocean_display_header":"default","ocean_header_style":"","ocean_center_header_left_menu":"0","ocean_custom_header_template":"0","ocean_custom_logo":0,"ocean_custom_retina_logo":0,"ocean_custom_logo_max_width":0,"ocean_custom_logo_tablet_max_width":0,"ocean_custom_logo_mobile_max_width":0,"ocean_custom_logo_max_height":0,"ocean_custom_logo