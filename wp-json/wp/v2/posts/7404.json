zed with the Yoast SEO plugin v27.0 - https:\/\/yoast.com\/product\/yoast-seo-wordpress\/ -->\n<title>\u7f8e\u570b\u4f01\u696d\u7d44\u7e54\u578b\u614b\u4e4bS\u578b\u516c\u53f8 II \u767c\u653e\u5408\u7406\u85aa\u6c34 - \u611b\u52a0\u500d\u6703\u8a08\u5e2b\u4e8b\u52d9\u6240 - AGAPE CPA FIRM<\/title>\n<meta name=\"robots\" content=\"index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1\" \/>\n<link rel=\"canonical\" href=\"https:\/\/agapecpa.com\/7404.html\" \/>\n<meta property=\"og:locale\" content=\"en_US\" \/>\n<meta property=\"og:type\" content=\"article\" \/>\n<meta property=\"og:title\" content=\"\u7f8e\u570b\u4f01\u696d\u7d44\u7e54\u578b\u614b\u4e4bS\u578b\u516c\u53f8 II \u767c\u653e\u5408\u7406\u85aa\u6c34 - \u611b\u52a0\u500d\u6703\u8a08\u5e2b\u4e8b\u52d9\u6240 - AGAPE CPA FIRM\" \/>\n<meta property=\"og:description\" content=\"\u3010\u5e0c\u671b\u4e4b\u80722023\u5e741\u67088\u65e5\u3011\uff08\u4e3b\u6301\u4eba\uff1a\u6797\u61ff\u6703\u8a08\u5e2b\uff09\u7bc0\u76ee\u6642\u9577\uff1a2\u520634\u79d2 \u25c7 \u7bc0\u76ee\u63d0\u8981 \u6b61\u8fce\u4f86\u5230\u6797\u61ff\u7a05\u52d9\u8b1b\u5802\uff0c\u6211\u662f\u6703\u8a08\u5e2b\u6797\u61ff\u3002\u4eca\u5929\u8981\u548c\u5927\u5bb6\u804a\u4e00\u4e0bS\u578b\u516c\u53f8\u516c\u53f8\u7684\u5408\u7406\u85aa\u6c34\u7684\u554f\u984c\u3002 S \u578b\u516c\u53f8\u662f\u4e00\u7a2e\u5f88\u666e\u904d\u7684\u516c\u53f8\u7d50\u69cb\uff0c\u4e00\u822c\u9069\u7528\u65bc\u80a1\u6771\u4eba\u6578\u5c11\u7684\u5c0f\u578b\u516c\u53f8\uff0c\u5728\u7845\u8c37\u61c9\u8a72\u6709\u5f88\u591a\u7684\u500b\u4eba\u670d\u696d\u90fd\u63a1\u7528\u9019\u7a2e\u7d44\u7e54\u5f62\u5f0f\u3002\u5b83\u6700\u5927\u7684\u597d\u8655\u662f\u6c92\u6709\u96d9\u91cd\u8ab2\u7a05\u7684\u554f\u984c\u3002\u800c\u4e14\u76f8\u8f03\u65bc\u76f4\u63a5\u5831\u5728\u500b\u4eba\u7a05schedule C\u7684\u81ea\u50f1\u4eba\u58eb\uff0cschedule C\u4e0a\u7684\u6de8\u5229\u540c\u8981\u4ea4\u6240\u5f97\u7a05\u53caSE tax, S\u578b\u516c\u53f8\u7684\u6de8\u5229\u50c5\u9700\u8981\u7e73\u4ea4\u6240\u5f97\u7a05\uff0c\u6240\u4ee5\u4e2d\u9593\u5c31\u5dee\u4e86\u4e00\u500b\u85aa\u8cc7\u7a05\u6216\u662fSE tax. \u65bc\u662f\u4e4e\uff0c\u570b\u7a05\u5c40\u5c31\u8981\u6c42S\u578b\u516c\u53f8\u7684\u80a1\u6771\u8981\u767c\u653e\u5408\u7406\u7684\u85aa\u6c34\uff0creasonable compensation. \u800c\u4e14\u4e0d\u55ae\u662f\u570b\u7a05\u5c40\uff0c\u52a0\u5dde\u4e5f\u662f\u6709\u540c\u6a23\u7684\u8981\u6c42\u3002\u6211\u4eca\u5e74\u5c31\u66fe\u4ee3\u7406\u4e00\u500bS\u578b\u516c\u53f8\u88abEDD(\u52a0\u5dde\u4e3b\u7ba1\u85aa\u8cc7\u7a05\u7684\u6a5f\u95dc\uff09\u85aa\u8cc7\u67e5\u6838\u7684\u4141\u4ef6\u3002\u5728\u9019\u500b\u4141\u4ef6\u4e2d\uff0cEDD\u4e5f\u5f88\u95dc\u6ce8\u80a1\u6771\u662f\u4e0d\u662f\u6709\u767c\u653e\u5408\u7406\u7684\u85aa\u6c34\u3002 \u7136\u800c\uff0c\u5408\u7406\u7684\u85aa\u6c34\u4e26\u4e0d\u662f\u4e00\u500b\u7d55\u5c0d\u7684\u6578\u5b57\uff0c\u9019\u540c\u6642\u8981\u53c3\u7167\u540c\u696d\u6a19\u6e96\u53ca\u516c\u53f8\u5167\u90e8\u7684\u767c\u85aa\u3002\u4f8b\u5982\uff0c\u82e5\u662f\u4e00\u822c\u8a3b\u518a\u6703\u8a08\u5e2b\u5e2b\u7684\u5e73\u5747\u5e74\u85aa\u6709\u5341\u591a\u842c\uff0c\u6211\u767c\u4e8b\u52d9\u6240\u8cc7\u6df1\u4eba\u54e1\u5e74\u85aa\u4e5d\u842c\uff0c\u800c\u6211\u5728\u4e8b\u52d9\u6240\u91d1\u6d41\u7a69\u5b9a\u7684\u524d\u63d0\u4e0b\u767c\u81ea\u5df1\u85aa\u6c34\u4e94\u842c\uff0c\u9019\u5c31\u4e0d\u662f\u5408\u7406\u85aa\u6c34\u3002\u82e5\u662f\u6c92\u6709\u767c\u5408\u7406\u85aa\u6c34\uff0c\u5247\u80a1\u6771\u901a\u904etax free distribution \u7684\u9818\u6b3e\uff0c\u53ef\u80fd\u81f3\u5c11\u6703\u6709\u4e00\u90e8\u5206\u88ab\u91cd\u5206\u985e\u6210\u85aa\u6c34\uff0c\u4e26\u4e14\u7e73\u4ea4\u9072\u4ea4\u7684\u7f70\u6b3e\u53ca\u5229\u606f\u3002\u6211\u5011\u4e5f\u6703\u5728\u4e0b\u671f\u7bc0\u76ee\u4e2d\u89e3\u91cb\u4ec0\u9ebc\u662ftax free distribution. \u800cS \u578b\u516c\u53f8\u767c\u80a1\u6771\u5408\u7406\u85aa\u8cc7\u5916\uff0c\u540c\u6642\u4e5f\u61c9\u8a72\u5408\u4f75\u8003\u616e\u767c\u591a\u5c11\u85aa\u6c34\u624d\u80fd\u9054\u5230section 199A qualified business income deduction \u7684\u6975\u5927\u5316\u3002 \u6709\u8208\u8da3\u7684\u670b\u53cb\u53ef\u4ee5\u4e0a\u6211\u5011\u4e8b\u52d9\u6240\u7684\u5b98\u7db2www.agapecpa.com\u7372\u5f97\u66f4\u591a\u7684\u7a05\u52d9\u8cc7\u8a0a\u6216\u662f\u81f4\u96fb\u6211\u5011Cupertino\u7684\u8fa6\u516c\u5ba4408-725-1700. \u611f\u8b1d\u5927\u5bb6\u7684\u6536\u807d\uff0c\u6211\u5011\u4e0b\u671f\u518d\u6703\u3002\" \/>\n<meta property=\"og:url\" content=\"https:\/\/agapecpa.com\/7404.html\" \/>\n<meta property=\"og:site_name\" content=\"\u611b\u52a0\u500d\u6703\u8a08\u5e2b\u4e8b\u52d9\u6240 - AGAPE CPA FIRM\" \/>\n<meta property=\"article:published_time\" content=\"2023-01-08T20:03:03+00:00\" \/>\n<meta property=\"article:modified_time\" content=\"2025-01-10T18:02:55+00:00\" \/>\n<meta property=\"og:image\" content=\"https:\/\/agapecpa.com\/wp-content\/uploads\/sites\/10\/2023\/01\/corptax.jpg\" \/>\n\t<meta property=\"og:image:width\" content=\"600\" \/>\n\t<meta property=\"og:image:height\" content=\"348\" \/>\n\t<meta property=\"og:image:type\" content=\"image\/jpeg\" \/>\n<meta name=\"author\" content=\"jeel\" \/>\n<meta name=\"twitter:card\" content=\"summary_large_image\" \/>\n<meta name=\"twitter:label1\" content=\"Written by\" \/>\n\t<meta name=\"twitter:data1\" content=\"jeel\" \/>\n\t<meta name=\"twitter:label2\" content=\"Est. reading time\" \/>\n\t<meta name=\"twitter:data2\" content=\"1 minute\" \/>\n<script type=\"application\/ld+json\" class=\"yoast-schema-graph\">{\"@context\":\"https:\/\/schema.org\",\"@graph\":[{\"@type\":\"Article\",\"@id\":\"https:\/\/agapecpa.com\/7404.html#article\",\"isPartOf\":{\"@id\":\"https:\/\/agapecpa.com\/7404.html\"},\"author\":{\"name\":\"jeel\",\"@id\":\"https:\/\/agapecpa.com\/#\/schema\/person\/1eb0574c9dfb6061620972a4b4069934\"},\"headline\":\"\u7f8e\u570b\u4f01\u696d\u7d44\u7e54\u578b\u614b\u4e4bS\u578b\u516c\u53f8 II \u767c\u653e\u5408\u7406\u85aa\u6c34\",\"datePu