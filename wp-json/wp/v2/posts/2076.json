75ab\u60c5\u7684\u4e00\u9805\u806f\u90a6\u7dca\u6025\u8a08\u5283\uff0c 3\/27\/20\u7531\u5ddd\u666e\u7e3d\u7d71\u7c3d\u7f72\u6210\u70ba\u6cd5\u6848\u3002\u5176\u76ee\u7684\u662f\u70ba\u4e86\u5e6b\u52a9\u7d0d\u7a05\u4eba\u53ca\u4f01\u696d\uff0c\u80fd\u5920\u901a\u904e\u9019\u6cd5\u6848\u7684\u7d13\u56f0\uff0c\u6e21\u904e\u56e0\u70ba\u75ab\u60c5\u5e36\u4f86\u7684\u8ca1\u52d9\u56f0\u5883\u3002\u672c\u6587\u662f\u8981\u68b3\u7406\u672c\u6cd5\u6848\u5c0d\u65bc\u4e2d\u5c0f\u4f01\u696d\u6240\u5e36\u4f86\u7684\u5f71\u97ff\u3002\u4f46\u662f\u7e31\u89c0\u9019\u90e8\u4efd\u7684\u65b9\u6848\uff0c\u4e3b\u8981\u662f\u6e1b\u8f15\u50f1\u4e3b\u7684\u8ca0\u64d4\uff0c\u9054\u5230\u7559\u4efb\u54e1\u5de5\uff0c\u7a69\u5b9a\u7d93\u6fdf\u7684\u76ee\u7684\u3002\u4ee5\u4e0b\u662f\u6b64\u6cd5\u6848\u4f01\u696d\u90e8\u4efd\u7684\u6458\u8981\u3002 1\uff0c \u7559\u4efb\u54e1\u5de5\u7684\u7a05\u52d9\u88dc\u52a9Employee retention credit for employers \u7b26\u5408\u8cc7\u683c\u7684\u50f1\u4e3b\uff0c\u5c07\u53ef\u4ee5\u7372\u5f97\u90e8\u5206\u85aa\u8cc7\u7a05\u4e2d6.2%\u793e\u6703\u5b89\u5168\u91d1\u7684\u88dc\u52a9\u3002\u5408\u683c\u65f3\u516c\u53f8\uff0c\u5305\u62ec\u4e86\u975e\u71df\u5229\u7d44\u7e54\uff0c\u5fc5\u9808\u57282020\u5e74\u4ecd\u7136\u7dad\u6301\u71df\u904b\uff0c\u4f46\u662f\u5728\u67d0\u4e9b\u5b63\u5ea6\u4e2d\u53d7\u5230\u653f\u5e9c\u65c5\u904a\u7981\u4ee4\u6216\u662f\u7981\u8db3\u4ee4\u5f71\u97ff\u7684\u5546\u5bb6\u3002 \u5c0d\u65bc\u50f1\u7528\u5168\u8077\u54e1\u5de5\u5c11\u65bc\u4e00\u767e\u4eba\u8005\uff0c\u6240\u6709\u7684\u85aa\u6c34\u90fd\u662f\u5408\u683c\u85aa\u6c34\u3002\u9019\u500b\u85aa\u8cc7\u7a05\u88dc\u52a9\uff08credit) \u81f3\u591a\u53ef\u9054\u6bcf\u4f4d\u54e1\u5de5\u4e94\u5343\u7f8e\u5143\u3002\u5176\u4e2d\u6709\u4e00\u4e9b\u8a08\u7b97\u7684\u7d30\u7bc0\uff0c\u672c\u6587\u4e2d\u4e26\u6c92\u6709\u8a73\u8ff0\u3002 \u9019\u9805\u7a05\u52d9\u88dc\u52a9\u9069\u7528\u65bc3\/12\/20\u81f312\/31\/20\u767c\u653e\u85aa\u6c34\u7684\u5546\u5bb6\u3002\u4f46\u662f\u5df2\u7d93\u6536\u5230\u5c0f\u578b\u4f01\u696d\u8cb8\u6b3e\u88dc\u52a9\uff08Small Business Interruption Loans) \u7684\u4e0d\u9069\u7528\u3002 \u5ef6\u9072\u652f\u4ed8\u50f1\u4e3b\u90e8\u5206\u7684\u85aa\u8cc7\u7a05\u3002 \u7d0d\u7a05\u4eba\uff0c\u5305\u62ec\u81ea\u50f1\u4eba\u58eb\uff0c\u53ef\u4ee5\u905e\u5ef6\u50f1\u4e3b\u90e8\u5206\u7684\u85aa\u8cc7\u7a05\u52302020\u5e74\u5e74\u5e95\u3002\u800c\u905e\u5ef6\u7684\u6578\u984d\u53ef\u4ee5\u5747\u5206\u81f32021\u53ca2022 \u5e74\u5e95\u7e73\u4ea4\u3002\u4f46\u662f\u82e5\u662f\u4f01\u696d\u5df2\u7d93\u6536\u5230\u4e0d\u7528\u511f\u9084\u7684\u88dc\u52a9\uff0c\u5247\u5ef6\u9072\u652f\u4ed8\u85aa\u8cc7\u7a05\u7684\u689d\u4f8b\u4e0d\u9069\u7528\u3002 \u653e\u5bec\u71df\u696d\u6de8\u640d\uff08Net operating loss) \u7684\u62b5\u6e1b 2018\u5e74\u958b\u59cb\u7684\u7a05\u6539, \u9650\u5236\u4e86\u6bcf\u4e00\u5e74\u53ea\u80fd\u4f7f\u7528\u7576\u5e74\u767e\u5206\u4e4b\u516b\u5341\u8ab2\u7a05\u6240\u5f97\u7684\u524d\u671f\u71df\u696d\u6de8\u640d\u3002\u4f46\u662f\u9019\u500b\u7d13\u56f0\u689d\u6b3e\u653e\u5bec\u4e86NOL\u7684\u62b5\u6e1b\u3002\u57282021\u5e74\u524d\u6240\u7522\u751f\u7684\u71df\u696d\u6de8\u640d\uff0c\u53ef\u4ee5\u56de\u6eaf\u4e94\u5e74\uff0c\u4e0d\u53d7\u6b64\u767e\u5206\u4e4b\u516b\u5341\u62b5\u6e1b\u7684\u9650\u5236\u3002 \u52a0\u901f\u9000\u56de\u516c\u53f8AMT credit\u3002 \u7a05\u6539\u5df2\u7d93\u7648\u9664\u4e86\u516c\u53f8\u7684AMT\uff0c \u800c\u9019\u500b\u7d13\u56f0\u8a08\u5283\u52a0\u901f\u4e86AMT tax credit \u7684\u9000\u56de \u653e\u9b06\u5229\u606f\u8cbb\u7528\u7684\u62b5\u6e1b \u5ef6\u9072\u9000\u4f11\u91d1\u5e33\u6236\u7684\u5b58\u653e\u65e5\u671f\u3002\u5f9e\u539f\u5148\u7684\u622a\u6b62\u65e5\u671f\u5ef6\u81f31\/1\/2021. \u67d0\u4e9bSBA loan \u7684\u6e1b\u514d\u4e26\u4e0d\u7b97\u6210\u662f\u8ab2\u7a05\u6240\u5f97\u3002 \u5e0c\u671b\u4e0a\u8ff0\u7684\u8a0a\u606f\u5c0d\u5404\u4f4d\u6709\u6240\u52a9\u76ca\uff0c\u4e5f\u7948\u9858\u5404\u4f4d\u95a4\u5bb6\u5e73\u5b89\u5065\u5eb7\u3002 \u6797\u61ff\u00a0 \u6703\u8a08\u