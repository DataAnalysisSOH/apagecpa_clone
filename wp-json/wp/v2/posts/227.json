f0c\u4e26\u4e0d\u5305\u62ec\u6295\u8cc7\u6240\u5f97\uff0c\u4f8b\u5982\u8cc7\u672c\u5229\u5f97\uff0c\u80a1\u5229\u53ca\u5229\u606f\u6240\u5f97\u3002\u54e1\u5de5\u7684\u85aa\u8cc7\u53ca\u7531\u5408\u5925\u4f01\u696d\u800c\u4f86\u7684&#8221;\u4fdd\u969c\u6240\u5f97&#8221;(guaranteed payments) \u4ea6\u4e0d\u5728\u5408\u683c\u6240\u5f97\u6240\u5f97\u4e4b\u4e2d\u3002\u7531\u65bc\u5408\u683c\u6240\u5f97\u6392\u9664\u4e86\u7531\u5408\u5925\u800c\u4f86\u7684\u4fdd\u969c\u6240\u5f97\uff0c\u800c\u5408\u5925\u4eba\u672a\u5fc5\u8981\u9818\u53d6\u4fdd\u969c\u6240\u5f97\uff0c\u6240\u76f8\u8f03\u65bcS \u578b\u516c\u53f8\u7684\u80a1\u6771\u8981\u767c\u653e\u5408\u7406\u85aa\u8cc7\uff0c\u800c\u85aa\u8cc7\u53c8\u4e0d\u5217\u5165\u5408\u683c\u6240\u5f97\u4e4b\u4e2d\uff0c\u76f8\u8f03\u7701\u7a05\u7a7a\u9593\u8f03\u5927\uff0c\u6240\u4ee5\u6709\u4e00\u6d3e\u4eba\u58eb\u56e0\u70ba\u6b64\u539f\u56e0\u9f13\u5439\u5c07S \u578b\u516c\u53f8\u8f49\u70baLLC\u3002\u4f46\u662f\u540c\u6642\uff0c S \u578b\u516c\u53f8\u8f03\u5408\u5925\u5728pass -through income \u5c11\u4e86SE tax\uff08\u81ea\u50f1\u7a05), \u800c\u4e14\u6211\u5011\u5728\u524d\u6587\u4e2d\u63d0\u53ca\u5728\u52a0\u5dde\u6210\u7acbLLC\u9084\u6709LLC Fee\u3002\u56e0\u6b64\u7d0d\u7a05\u4eba\u8981\u7d9c\u5408\u8003\u91cf\u5404\u7a2e\u7a05\u52d9\u7684\u4ea4\u4e92\u5f71\u97ff\u3002 \u800c\u81ea\u50f1\u4eba\u58eb(sole proprietorship)\u65e2\u6c92\u6709\u5408\u5925\u7684\u4fdd\u969c\u6240\u5f97\uff0c\u4e5f\u6c92\u6709S \u578b\u516c\u53f8\u7684\u5408\u7406\u85aa\u6c34\uff0c\u6240\u4ee5\u7406\u8ad6\u4e0a\u800c\u8a00\uff0c\u5176\u5168\u90e8\u696d\u52d9\u6240\u5f97\u90fd\u53ef\u80fd\u6210\u70ba&#8221;\u5408\u683c\u6240\u5f97&#8221;\u3002\u53ea\u662f\u7d0d\u7a05\u4eba\u8003\u91cf\u6642\uff0c\u4e5f\u8981\u8003\u616e\u5230\u7531\u65bc\u81ea\u50f1\u672c\u8eab\u4e0d\u662f\u516c\u53f8\u7684\u7d44\u7e54\u578b\u5f0f\uff0c\u56e0\u6b64\u7f3a\u4e4f\u8cc7\u7522\u4fdd\u8b77\u9019\u4e00\u9ede\u3002 \u9019\u7a2e20%\u7684\u62b5\u6e1b\u4e5f\u5b58\u5728\u6240\u5f97\u4e0a\u7684\u9650\u5236\u3002\u57fa\u672c\u4e0a\u8aac\u4f86\uff0c\u6536\u5165\u662f\u9650\u5236\u5728\u500b\u4eba$157,000, \u592b\u59bb\u5408\u4f75\u7533\u5831\u70ba$315,000\u3002\u5982\u679c\u7d0d\u7a05\u4eba\u7684\u8ab2\u7a05\u6240\u5f97\u4f4e\u65bc\u6b64\u4e00\u6a19\u6e96\uff0c\u5927\u81f4\u4e0a\u8b1b\u62b5\u6e1b\u984d\u6703\u662fpass through income \u768420%\u3002\u4f46\u662f\u4ecd\u7136\u5b58\u5728\u4e00\u4e9b\u7d30\u7bc0\u53ca\u9650\u5236,\u8acb\u8207\u60a8\u7684\u6703\u8a08\u5e2b\u8a0e\u8ad6\u3002 \u9019\u7a2e\u6240\u5f97\u7684\u62b5\u6e1b\u662f\u5982\u4f55\u53cd\u61c9\u5728\u500b\u4eba\u7a05\u7684\u7a05\u8868\u4e4b\u4e0a\uff1f\u7406\u8ad6\u4e0a\u8aac\u4f86\uff0c\u9019\u662f\u6240\u8b02\u7684&#8221;below the line&#8221;\u5373\u500b\u4eba\u7a05\u7a05\u8868\u7b2c\u4e8c\u9801\u7684\u8abf\u6574\uff0c\u6e1b\u4f4e\u7684\u662ftaxable income \uff08\u8ab2\u7a05\u6240\u5f97\uff09\u800c\u975e\u50b3\u7d71\u7684&#8221;above the line&#8221; \u5373\u7a05\u8868\u7b2c\u4e00\u9801\u7684AGI \u8abf\u6574\u6240\u5f97\u7684\u8abf\u6574\u3002\u7d0d\u7a05\u4eba\u5373\u4fbf\u4e0d\u4f7f\u7528\u5217\u8209\u6263\u9664\u984d\u4e5f\u80fd\u904b\u7528\u3002\u4f46\u662f\u6b64\u4e00\u62b5\u6e1b\u53ea\u80fd\u7528\u4f86\u6e1b\u6240\u5f97\u7a05(income tax),\u5c0d\u65bc\u81ea\u50f1\u7a05(self employment tax\uff09\u53caAMT\u662f\u7121\u6548\u7684\u3002 \u800c\u8981\u5f97\u5230\u9019\u7a2e20%\u7684\u62b5\u6e1b\u9664\u4e86\u8981\u6709&#8221;\u5408\u683c\u6240\u5f97&#8221;\u4e4b\u5916\uff0c \u4e5f\u5fc5\u9808\u662f\u6240\u8b02\u7684&#8221;\u5408\u683c\u7684\u7522\u696d&#8221;\uff08qualified trade or business) \u3002\u800c\u4f55\u8b02\u662f&#8221;\u5408\u683c\u7684\u7522\u696d&#8221;? \u4e0d\u662f&#8221;\u7279\u5225\u7684\u670d\u52d9\u696d&#8221;(specified service trade or business)\u7684\u5c31\u662f\u6240\u8b02\u7684\u5408\u683c\u7684\u7522\u696d\u3002\u800c\u90a3\u4e9b\u7522\u696d\u662f\u5305\u62ec\u5728\u7279\u5225\u7684\u670d\u52d9\u696d\u7684\u7bc4\u570d\uff1f \u9019\u4e9b\u670d\u52d9\u696d\u6db5\u