u689d14\u5929\u7684\u898f\u5247\uff0814 days rule\uff09\uff08IRC Sec. 280A\uff08g\uff09.\uff09\uff0c\u82e5\u662f\u7b26\u5408\u8981\u6c42\uff0c\u5247\u9019\u500b\u90e8\u5206\u7684\u6240\u5f97\u53ef\u4ee5\u514d\u7a05\u3002\u800c14\u5929\u7684\u898f\u5247\u6307\u7684\u662f\u540c\u6642\u6eff\u8db3\u4ee5\u4e0b\uff1a 1. \u51fa\u79df\u7684\u5929\u6578\u4e0d\u8d85\u904e14\u5929\u3002 2. \u7d0d\u7a05\u4eba\u5fc5\u9808\u81ea\u5df1\u4f4f\u5728\u8a72\u5ea6\u5047\u5c0f\u5c4b14\u5929\u4ee5\u4e0a\uff0c\u6216\u662f\u7e3d\u51fa\u79df\u5929\u6578\u768410%\u4ee5\u4e0a\u3002\u82e5\u662f\u623f\u5b50\u662f\u5f88\u77ed\u671f\u7684\u51fa\u79df\uff0c\u53ef\u4ee5\u5229\u7528\u9019\u4e00\u689d\u898f\u5b9a\uff0c\u4f86\u9054\u5230\u7701\u7a05\u7684\u76ee\u7684\u3002 \u4f46\u662f\u8981\u7279\u5225\u6ce8\u610f\u7684\u662f\uff0c\u4e00\u65b9\u9762\u9019\u662f\u975e\u8ab2\u7a05\u6240\u5f97\uff0c\u53e6\u4e00\u65b9\u9762\u4e5f\u4e0d\u80fd\u6263\u9664\u5176\u6240\u7522\u751f\u7684\u76f8\u95dc\u8cbb\u7528\u3002 \u901a\u5e38Airbnb\u6703\u8981\u7d0d\u7a05\u4eba\u586b\u5bebW9\u7684\u8868\u683c\uff0c\u5176\u76ee\u7684\u662f\u70ba\u4e86\u8981\u6e96\u50991099 K\u7684\u8868\u683c\u3002\u56e0\u70ba\u6839\u64da\u570b\u7a05\u5c40\u7684\u898f\u5b9a\uff0c\u8209\u51e1\u8a72\u5e74\u5ea6\u6240\u5f97\u8d85\u904e2\u842c\u7f8e\u91d1\uff0c\u53ca\u4ea4\u6613200\u7b46\u4ee5\u4e0a\uff0c\u5c31\u8981\u5411\u570b\u7a05\u5c40\u7533\u58311099K\u7684\u8868\u683c\u3002\u82e5\u662f\u7d0d\u7a05\u4eba\u4e00\u958b\u59cb\u5c31\u62d2\u7d55\u905e\u4ea4W9\u8868\u683c\uff0c\u5247Airbnb\u6709\u6b0a\u529b\u5148\u9810\u6263\u4ea4\u6613\u6b3e\u9805\u768424%\u4ea4\u7d66\u570b\u7a05\u5c40\uff08Backup Withholding \uff09\u3002 \u56e0\u6b64\uff0c\u70ba\u4e86\u907f\u514d\u88ab\u9810\u6263\u7a05\u6b3e\uff0c\u6700\u597d\u80fd\u4e0a\u4ea4W9\u8868\u683c\u3002\u82e5\u623f\u5730\u7522\u7684\u64c1\u6709\u8005\u70ba\u5916\u570b\u4eba\uff0c\u5247\u4e0d\u662f\u586b\u5bebW9\u8868\u683c\uff0c\u800c\u662f\u586b\u5bebW8\u8868\u683c\uff0c\u800c\u6700\u7d42\u6703\u6536\u5230\u8868\u683c1042\u3002 \u6240\u4ee5\uff0c\u82e5\u662f\u623f\u5b50\u51fa\u79df\u7684\u5929\u6578\u8d85\u904e14\u5929\uff0c\u90a3\u5c31\u662f\u61c9\u8a72\u7533\u5831\u7684\u8ab2\u7a05\u6240\u5f97\u3002\u518d\u8005\uff0c\u82e5\u662f\u570b\u7a05\u5c40\u5df2\u7d93\u6709\u4e861099 K\u7684\u6578\u5b57\uff0c\u800c\u7d0d\u7a05\u4eba\u82e5\u662f\u6c92\u6709\u7533\u5831\u76f8\u5c0d\u61c9\u7684\u6578\u5b57\uff0c\u5c31\u6703\u6536\u5230\u570b\u7a05\u5c40\u7684\u901a\u77e5\u3002 \u5728\u4e00\u822c\u7684\u72c0\u6cc1\u4e0b\uff0c\u51fa\u79df\u623f\u5c4b\u662f\u7533\u5831\u6240\u5f97\u5728\u500b\u4eba\u7a05\u7684Schedule E\u4e2d\uff0c\u4e26\u4e14\u7d0d\u7a05\u4eba\u53ef\u4ee5\u7533\u5831\u62b5\u6e1b\u8207\u6b64\u76f8\u95dc\u7684\u8cbb\u7528\u3002\u7136\u800c\uff0c\u82e5\u662f\u60a8\u5728\u623f\u5ba2\u505c\u7559\u7684\u6642\u9593\u5167\u63d0\u4f9b\u65e9\u9910\uff0c\u5b9a\u671f\u6e05\u6383\u53ca\u66f4\u63db\u5e8a\u55ae\u7b49\u7b49\u7684\u670d\u52d9\uff0c\u5247\u6703\u88ab\u5b9a\u7fa9\u6210\u70ba\u65c5\u9928\u670d\u52d9\u696d\u3002 \u82e5\u662f\u88ab\u5b9a\u4f4d\u6210\u65c5\u9928\u696d\u7684\u8a71\uff0c\u5247\u662f\u8981\u7533\u5831Schedule C\uff0c\u800cSchedule C\u7684\u6240\u5f97\u4e0d\u50c5\u50c5\u8981\u7e73\u4ea4\u6240\u5f97\u7a05\uff0c\u4e5f\u8981\u540c\u6642\u7e73\u4ea4SE tax\uff08\u793e\u6703\u5b89\u5168\u91d1\u53ca\u91ab\u7642\u4fdd\u96aa\uff09\u3002\u6240\u4ee5\u5728\u7533\u5831\u6642\u8981\u7279\u5225\u7559\u5fc3\u5206\u985e\u7684\u554f\u984c\u3002\" \/>\n<meta property=\"og:url\" content=\"https:\/\/agapecpa.com\/1710.html\" \/>\n<meta property=\"og:site_name\" content=\"\u611b\u52a0\u500d\u6703\u8a08\u5e2b\u4e8b\u52d9\u6240 - AGAPE CPA FIRM\" \/>\n<meta property=\"article:published_time\" content=\"2019-10-02T15:41:43+00:00\" \/>\n<meta property=\"article:modified_time\" content=\"2022-12-24T02:49:32+00:00\" \/>\n<meta property=\"og:image\" content=\"https:\/\/agapecpa.com\/wp-content\/uploads\/sites\/10\/2019\/10\/room-2724235_640.jpg\" \/>\n\t<meta property=\"og:i