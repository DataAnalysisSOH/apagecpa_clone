{"id":7676,"date":"2025-11-14T08:32:27","date_gmt":"2025-11-14T16:32:27","guid":{"rendered":"https:\/\/agapecpa.com\/?p=7676"},"modified":"2025-11-14T08:39:32","modified_gmt":"2025-11-14T16:39:32","slug":"%e9%87%9d%e5%b0%8d%e5%a4%a7%e7%be%8e%e9%ba%97%e6%b3%95%e6%a1%88%e4%b8%8b%e7%9a%84%e5%b9%b4%e5%ba%95%e7%9a%84%e7%a8%85%e5%8b%99%e8%a6%8f%e5%8a%83-%e5%80%8b%e4%ba%ba%e7%a8%85%e7%af%87","status":"publish","type":"post","link":"https:\/\/agapecpa.com\/7676.html","title":{"rendered":"\u91dd\u5c0d\u5927\u7f8e\u9e97\u6cd5\u6848\u4e0b\u7684\u5e74\u5e95\u7684\u7a05\u52d9\u898f\u5283 (\u500b\u4eba\u7a05\u7bc7)"},"content":{"rendered":"<p class=\"p1\">\u6b61\u8fce\u4f86\u5230\u6797\u61ff\u7a05\u52d9\u8b1b\u5802\uff0c\u6211\u662f\u6703\u8a08\u5e2b\u6797\u61ff\u3002\u6642\u5149\u5982\u98db\u800c\u901d\uff0c\u8f49\u773c\u9593\u53c8\u5230\u4e86\u5e74\u672b\u3002\u4e00\u822c\u5728\u9019\u500b\u6642\u5019\uff0c\u5c31\u662f\u500b\u4eba\u53ca\u4e2d\u5c0f\u4f01\u696d\u4e3b\u9032\u884c\u7a05\u52d9\u898f\u5283\u7684\u6642\u5019\u3002\u4f46\u662f\u4eca\u5e74\u9069\u9022\u8b8a\u5c40\uff0c\u56e0\u70ba\u5ddd\u666e\u7e3d\u7d71\u5728\u4eca\u5e74\u7684\u7f8e\u570b\u570b\u6176\u65e5\u7c3d\u7f72\u4e86\u5927\u7f8e\u9e97\u6cd5\u6848\uff0c\u800c\u751f\u6548\u7684\u65e5\u671f\u662f\u57282026\u5e74\u7533\u5831\u76842025\u5e74\u7a05\u8868\uff0c\u6240\u4ee5\u7d0d\u7a05\u4eba\u61c9\u8a72\u5728\u50b3\u7d71\u7684\u5e74\u5e95\u7684\u7a05\u52d9\u898f\u5283\u6280\u5de7\u4e4b\u5916\uff0c\u8003\u616e\u5230\u5927\u7f8e\u9e97\u6cd5\u6848\u6240\u5e36\u4f86\u7684\u885d\u64ca\u53ca\u660e\u767d\u8f49\u6298\u8655\u6240\u5e36\u4f86\u7684\u5f71\u97ff\u3002<\/p>\n<p class=\"p1\">1\u3002 \u6148\u5584\u6350\u6b3e\u3002\u6148\u5584\u6350\u6b3e\u4e00\u76f4\u662f\u5217\u8209\u6263\u9664\u984d\u4e2d\u5f88\u91cd\u8981\u7684\u4e00\u74b0\u3002\u5c0d\u65bc\u9ad8\u6240\u5f97\u7684\u4eba\u7fa4\u800c\u8a00\uff0c\u57282017\u5e74\u5ddd\u666e\u7a05\u6539\u4e4b\u5f8c\uff0c\u6350\u7d66\u516c\u773e\u6148\u5584\u4e8b\u696d\u7684\u62b5\u6e1b\u9650\u5236\u70baAGI\u768460%. \u5728\u5927\u7f8e\u9e97\u6cd5\u6848\u4e0b\u4ecd\u7136\u4fdd\u670960%\u6240\u5f97\u7684\u9650\u5236\uff0c\u53ea\u662f\u81f32026\u5e74\u958b\u59cb\uff0c\u53ea\u80fd\u62b5\u6e1b\u8d85\u904e\u7eb3\u7a05\u4ebaAGI\u76840.5%\u7684\u90e8\u5206\u3002\u4f8b\u5982\uff0c\u5982\u679c\u7d0d\u7a05\u4eba\u7684\u6240\u5f97\u70ba\u4e94\u5341\u842c\u7f8e\u5143\uff0c\u5247\u6350\u6b3e\u8981\u8d85\u904e\u4e8c\u5343\u4e94\u767e\u7f8e\u5143\u624d\u958b\u59cb\u62b5\u6e1b\u3002\u6240\u4ee5\u8003\u616e\u8f03\u5927\u984d\u5ea6\u6350\u6b3e\u7684\u9ad8\u6240\u5f97\u4eba\u58eb\uff0c\u61c9\u8a72\u8003\u616e\u5728\u4eca\u5e74\u5e74\u672b\u4e4b\u524d\u6350\u8d08\uff0c\u5c31\u9084\u672a\u53d7\u5230\u6b64\u9805\u8abf\u6574\u7684\u9650\u5236\u3002\u53ef\u4ee5\u5f97\u5230\u8f03\u9ad8\u984d\u7684\u6e1b\u7a05\u529b\u5ea6\u3002<\/p>\n<p class=\"p1\">2\u3002AMT. Alternative Minimum Tax. \u5728\u7845\u8c37\uff0c\u6709\u5f88\u591a\u7684\u4eba\u9664\u4e86\u56fa\u5b9a\u7684\u85aa\u6c34\u4e4b\u5916\uff0c\u80a1\u7968\u662f\u5f88\u91cd\u8981\u7684\u6536\u5165\u4f86\u6e90\u3002\u800c\u80a1\u7968\u7576\u4e2d\u7684ISO, incentivize stock options \u4e5f\u4f54\u4e86\u76f8\u7576\u91cd\u8981\u7684\u4e00\u74b0.\u56e0\u70ba\u5728exercise ISO\u7684\u6642\u5019\u6703\u7522\u751fAMT\u7684\u8a08\u7b97\u3002\u57282017\u5e74\u5ddd\u666e\u7a05\u6539\u6642\u5927\u5e45\u5ea6\u7684\u63d0\u9ad8AMT\u7684\u514d\u7a05\u984d\u3002\u96d9\u85aa\u5bb6\u5ead\u7d04\u70ba\u4e00\u767e\u4e8c\u5341\u4e94\u842c\u7f8e\u5143\u5de6\u53f3\u3002\u5927\u7f8e\u9e97\u6cd5\u6848\u5728AMT\u514d\u7a05\u984d\u7684\u984d\u5ea6\u4e0a\u4fee\u6539\uff0c\u6539\u6210\u55ae\u8eab\u4e94\u5341\u842c\uff0c\u592b\u59bb\u5408\u4f75\u7533\u5831\u4e00\u767e\u842c\u3002\u751f\u6548\u65e5\u671f\u70ba2026\u5e74\u3002\u610f\u601d\u662f\u82e5\u662f\u624b\u4e0a\u63e1\u6709\u8f03\u591aISO\u7684\u7d0d\u7a05\u4eba\uff0c\u53ef\u4ee5\u628a\u63e12025\u5e74\u8f03\u9ad8AMT\u7684\u514d\u7a05\u984d\u5ea6\u9032\u884cexercise.<\/p>\n<p class=\"p1\">\u8eca\u8cb8\u5229\u606f\u7684\u62b5\u6e1b\u3002\u5c0d\u65bc\u55ae\u8eab\u6240\u5f97\u4e0d\u8d85\u904e\u5341\u842c\u7f8e\u5143\u6216\u592b\u59bb\u5408\u4f75\u7533\u5831\u6240\u5f97\u4e0d\u8d85\u904e\u4e8c\u5341\u842c\u7684\u7d0d\u7a05\u4eba\uff0c\u53ef\u4ee5\u8003\u616e\u62b5\u8eca\u8cb8\u5229\u606f\u3002\u62b5\u6e1b\u984d\u81f3\u591a\u70ba\u4e00\u842c\u7f8e\u5143\u3002\u4f46\u662f\u5408\u683c\u7684\u8eca\u8f1b\u5fc5\u9700\u6700\u7d42\u5728\u7f8e\u570b\u88dd\u914d\u3002<\/p>\n<p class=\"p1\">\u5c45\u5bb6\u6e05\u6f54\u80fd\u6e90\u7684\u7a05\u52d9\u88dc\u8cbc\uff0c\u81f312\/31\/25\u5e74\u6b62\u3002\u6240\u4ee5\u8981\u62ff\u5230\u592a\u967d\u80fd\u677f\u7b49\u7b49\u7684\u6e05\u6f54\u80fd\u6e90\u7684\u7a05\u52d9\u88dc\u8cbc\uff0c\u8981\u5728\u5e74\u5e95\u524d\u884c\u52d5\u5594\uff01<\/p>\n<p class=\"p1\">\u5229\u7528\u589e\u52a0\u7684\u7a05\u52d9\u62b5\u6e1b\u9805\u589e\u52a0Roth IRA conversation \u7684\u7a7a\u9593\u3002<\/p>\n<p class=\"p1\">\u4ee5\u4e0a\u4fbf\u662f\u672c\u671f\u7bc0\u76ee\u7684\u5168\u90e8\u5167\u5bb9\uff0c\u611f\u8b1d\u5927\u5bb6\u7684\u6536\u807d\uff0c\u6211\u5011\u4e0b\u671f\u7bc0\u76ee\u518d\u6703\u3002<\/p>\n","protected":false},"excerpt":{"rendered":"\u6b61\u8fce\u4f86\u5230\u6797\u61ff\u7a05\u52d9\u8b1b\u5802\uff0c\u6211\u662f\u6703\u8a08\u5e2b\u6797\u61ff\u3002\u6642\u5149\u5982\u98db\u800c\u901d\uff0c\u8f49\u773c\u9593\u53c8\u5230\u4e86\u5e74\u672b\u3002\u4e00\u822c\u5728\u9019\u500b\u6642\u5019\uff0c\u5c31\u662f\u500b\u4eba\u53ca\u4e2d\u5c0f\u4f01\u696d\u4e3b\u9032\u884c\u7a05\u52d9\u898f\u5283\u7684\u6642\u5019\u3002\u4f46\u662f\u4eca\u5e74\u9069\u9022\u8b8a\u5c40\uff0c\u56e0\u70ba\u5ddd\u666e\u7e3d\u7d71\u5728\u4eca\u5e74\u7684\u7f8e\u570b\u570b\u6176\u65e5\u7c3d\u7f72\u4e86\u5927\u7f8e\u9e97\u6cd5\u6848\uff0c\u800c\u751f\u6548\u7684\u65e5\u671f\u662f\u57282026\u5e74\u7533\u5831\u76842025\u5e74\u7a05\u8868\uff0c\u6240\u4ee5\u7d0d\u7a05\u4eba\u61c9\u8a72\u5728\u50b3\u7d71\u7684\u5e74\u5e95\u7684\u7a05\u52d9\u898f\u5283\u6280\u5de7\u4e4b\u5916\uff0c\u8003\u616e\u5230\u5927\u7f8e\u9e97\u6cd5\u6848\u6240\u5e36\u4f86\u7684\u885d\u64ca\u53ca\u660e\u767d\u8f49\u6298\u8655\u6240\u5e36\u4f86\u7684\u5f71\u97ff\u3002 1\u3002 \u6148\u5584\u6350\u6b3e\u3002\u6148\u5584\u6350\u6b3e\u4e00\u76f4\u662f\u5217\u8209\u6263\u9664\u984d\u4e2d\u5f88\u91cd\u8981\u7684\u4e00\u74b0\u3002\u5c0d\u65bc\u9ad8\u6240\u5f97\u7684\u4eba\u7fa4\u800c\u8a00\uff0c\u57282017\u5e74\u5ddd\u666e\u7a05\u6539\u4e4b\u5f8c\uff0c\u6350\u7d66\u516c\u773e\u6148\u5584\u4e8b\u696d\u7684\u62b5\u6e1b\u9650\u5236\u70baAGI\u768460%. \u5728\u5927\u7f8e\u9e97\u6cd5\u6848\u4e0b\u4ecd\u7136\u4fdd\u670960%\u6240\u5f97\u7684\u9650\u5236\uff0c\u53ea\u662f\u81f32026\u5e74\u958b\u59cb\uff0c\u53ea\u80fd\u62b5\u6e1b\u8d85\u904e\u7eb3\u7a05\u4ebaAGI\u76840.5%\u7684\u90e8\u5206\u3002\u4f8b\u5982\uff0c\u5982\u679c\u7d0d\u7a05\u4eba\u7684\u6240\u5f97\u70ba\u4e94\u5341\u842c\u7f8e\u5143\uff0c\u5247\u6350\u6b3e\u8981\u8d85\u904e\u4e8c\u5343\u4e94\u767e\u7f8e\u5143\u624d\u958b\u59cb\u62b5\u6e1b\u3002\u6240\u4ee5\u8003\u616e\u8f03\u5927\u984d\u5ea6\u6350\u6b3e\u7684\u9ad8\u6240\u5f97\u4eba\u58eb\uff0c\u61c9\u8a72\u8003\u616e\u5728\u4eca\u5e74\u5e74\u672b\u4e4b\u524d\u6350\u8d08\uff0c\u5c31\u9084\u672a\u53d7\u5230\u6b64\u9805\u8abf\u6574\u7684\u9650\u5236\u3002\u53ef\u4ee5\u5f97\u5230\u8f03\u9ad8\u984d\u7684\u6e1b\u7a05\u529b\u5ea6\u3002 2\u3002AMT. Alternative Minimum Tax. \u5728\u7845\u8c37\uff0c\u6709\u5f88\u591a\u7684\u4eba\u9664\u4e86\u56fa\u5b9a\u7684\u85aa\u6c34\u4e4b\u5916\uff0c\u80a1\u7968\u662f\u5f88\u91cd\u8981\u7684\u6536\u5165\u4f86\u6e90\u3002\u800c\u80a1\u7968\u7576\u4e2d\u7684ISO, incentivize stock options \u4e5f\u4f54\u4e86\u76f8\u7576\u91cd\u8981\u7684\u4e00\u74b0.\u56e0\u70ba\u5728exercise ISO\u7684\u6642\u5019\u6703\u7522\u751fAMT\u7684\u8a08\u7b97\u3002\u57282017\u5e74\u5ddd\u666e\u7a05\u6539\u6642\u5927\u5e45\u5ea6\u7684\u63d0\u9ad8AMT\u7684\u514d\u7a05\u984d\u3002\u96d9\u85aa\u5bb6\u5ead\u7d04\u70ba\u4e00\u767e\u4e8c\u5341\u4e94\u842c\u7f8e\u5143\u5de6\u53f3\u3002\u5927\u7f8e\u9e97\u6cd5\u6848\u5728AMT\u514d\u7a05\u984d\u7684\u984d\u5ea6\u4e0a\u4fee\u6539\uff0c\u6539\u6210\u55ae\u8eab\u4e94\u5341\u842c\uff0c\u592b\u59bb\u5408\u4f75\u7533\u5831\u4e00\u767e\u842c\u3002\u751f\u6548\u65e5\u671f\u70ba2026\u5e74\u3002\u610f\u601d\u662f\u82e5\u662f\u624b\u4e0a\u63e1\u6709\u8f03\u591aISO\u7684\u7d0d\u7a05\u4eba\uff0c\u53ef\u4ee5\u628a\u63e12025\u5e74\u8f03\u9ad8AMT\u7684\u514d\u7a05\u984d\u5ea6\u9032\u884cexercise. \u8eca\u8cb8\u5229\u606f\u7684\u62b5\u6e1b\u3002\u5c0d\u65bc\u55ae\u8eab\u6240\u5f97\u4e0d\u8d85\u904e\u5341\u842c\u7f8e\u5143\u6216\u592b\u59bb\u5408\u4f75\u7533\u5831\u6240\u5f97\u4e0d\u8d85\u904e\u4e8c\u5341\u842c\u7684\u7d0d\u7a05\u4eba\uff0c\u53ef\u4ee5\u8003\u616e\u62b5\u8eca\u8cb8\u5229\u606f\u3002\u62b5\u6e1b\u984d\u81f3\u591a\u70ba\u4e00\u842c\u7f8e\u5143\u3002\u4f46\u662f\u5408\u683c\u7684\u8eca\u8f1b\u5fc5\u9700\u6700\u7d42\u5728\u7f8e\u570b\u88dd\u914d\u3002 \u5c45\u5bb6\u6e05\u6f54\u80fd\u6e90\u7684\u7a05\u52d9\u88dc\u8cbc\uff0c\u81f312\/31\/25\u5e74\u6b62\u3002\u6240\u4ee5\u8981\u62ff\u5230\u592a\u967d\u80fd\u677f\u7b49\u7b49\u7684\u6e05\u6f54\u80fd\u6e90\u7684\u7a05\u52d9\u88dc\u8cbc\uff0c\u8981\u5728\u5e74\u5e95\u524d\u884c\u52d5\u5594\uff01 \u5229\u7528\u589e\u52a0\u7684\u7a05\u52d9\u62b5\u6e1b\u9805\u589e\u52a0Roth IRA conversation \u7684\u7a7a\u9593\u3002 \u4ee5\u4e0a\u4fbf\u662f\u672c\u671f\u7bc0\u76ee\u7684\u5168\u90e8\u5167\u5bb9\uff0c\u611f\u8b1d\u5927\u5bb6\u7684\u6536\u807d\uff0c\u6211\u5011\u4e0b\u671f\u7bc0\u76ee\u518d\u6703\u3002","protected":false},"author":1,"featured_media":7679,"comment_status":"closed","ping_status":"closed","sticky":false,"template":"","format":"audio","meta":{"episode_type":"audio","audio_file":"https:\/\/episodes.castos.com\/61a3c155ea7bb4-99654116\/2210131\/c1e-9q44ntd5897f4wvqr-pkvrx9pnf7z-761kve.mp3","cover_image":"","cover_image_id":"","duration":"00:03:19","filesize":"7.6 mb","filesize_raw":"","date_recorded":"2025-11-14","explicit":"","block":"","ocean_post_l