684\u7a05\u52d9\u898f\u5283\u6280\u5de7\u4e4b\u5916\uff0c\u8003\u616e\u5230\u5927\u7f8e\u9e97\u6cd5\u6848\u6240\u5e36\u4f86\u7684\u885d\u64ca\u53ca\u660e\u767d\u8f49\u6298\u8655\u6240\u5e36\u4f86\u7684\u5f71\u97ff\u3002 1\u3002 \u6148\u5584\u6350\u6b3e\u3002\u6148\u5584\u6350\u6b3e\u4e00\u76f4\u662f\u5217\u8209\u6263\u9664\u984d\u4e2d\u5f88\u91cd\u8981\u7684\u4e00\u74b0\u3002\u5c0d\u65bc\u9ad8\u6240\u5f97\u7684\u4eba\u7fa4\u800c\u8a00\uff0c\u57282017\u5e74\u5ddd\u666e\u7a05\u6539\u4e4b\u5f8c\uff0c\u6350\u7d66\u516c\u773e\u6148\u5584\u4e8b\u696d\u7684\u62b5\u6e1b\u9650\u5236\u70baAGI\u768460%. \u5728\u5927\u7f8e\u9e97\u6cd5\u6848\u4e0b\u4ecd\u7136\u4fdd\u670960%\u6240\u5f97\u7684\u9650\u5236\uff0c\u53ea\u662f\u81f32026\u5e74\u958b\u59cb\uff0c\u53ea\u80fd\u62b5\u6e1b\u8d85\u904e\u7eb3\u7a05\u4ebaAGI\u76840.5%\u7684\u90e8\u5206\u3002\u4f8b\u5982\uff0c\u5982\u679c\u7d0d\u7a05\u4eba\u7684\u6240\u5f97\u70ba\u4e94\u5341\u842c\u7f8e\u5143\uff0c\u5247\u6350\u6b3e\u8981\u8d85\u904e\u4e8c\u5343\u4e94\u767e\u7f8e\u5143\u624d\u958b\u59cb\u62b5\u6e1b\u3002\u6240\u4ee5\u8003\u616e\u8f03\u5927\u984d\u5ea6\u6350\u6b3e\u7684\u9ad8\u6240\u5f97\u4eba\u58eb\uff0c\u61c9\u8a72\u8003\u616e\u5728\u4eca\u5e74\u5e74\u672b\u4e4b\u524d\u6350\u8d08\uff0c\u5c31\u9084\u672a\u53d7\u5230\u6b64\u9805\u8abf\u6574\u7684\u9650\u5236\u3002\u53ef\u4ee5\u5f97\u5230\u8f03\u9ad8\u984d\u7684\u6e1b\u7a05\u529b\u5ea6\u3002 2\u3002AMT. Alternative Minimum Tax. \u5728\u7845\u8c37\uff0c\u6709\u5f88\u591a\u7684\u4eba\u9664\u4e86\u56fa\u5b9a\u7684\u85aa\u6c34\u4e4b\u5916\uff0c\u80a1\u7968\u662f\u5f88\u91cd\u8981\u7684\u6536\u5165\u4f86\u6e90\u3002\u800c\u80a1\u7968\u7576\u4e2d\u7684ISO, incentivize stock options \u4e5f\u4f54\u4e86\u76f8\u7576\u91cd\u8981\u7684\u4e00\u74b0.\u56e0\u70ba\u5728exercise ISO\u7684\u6642\u5019\u6703\u7522\u751fAMT\u7684\u8a08\u7b97\u3002\u57282017\u5e74\u5ddd\u666e\u7a05\u6539\u6642\u5927\u5e45\u5ea6\u7684\u63d0\u9ad8AMT\u7684\u514d\u7a05\u984d\u3002\u96d9\u85aa\u5bb6\u5ead\u7d04\u70ba\u4e