7684\u80a1\u6771,\u8981\u8ab2\u5fb5\u6240\u8b02\u7684GILTI tax\u3002\u610f\u601d\u662f\u8aac,\u82e5\u662f\u9019\u500b\u5883\u5916\u516c\u53f8\u8cfa\u9322\uff0c\u5247\u9019\u500b\u7f8e\u570b\u80a1\u6771\u8981\u6309\u7167\u6301\u80a1\u7684\u6bd4\u4f8b,\u5728\u81ea\u5df1\u7684\u500b\u4eba\u7a05\u7a05\u8868\u4e0a\u8a8d\u5217\u6536\u76ca\u3002\u4f46\u662f\u6b64\u8209\u7684\u597d\u8655\u662f, \u904b\u56de\u7f8e\u570b\u7684\u5408\u683c\u7684\u80a1\u5229\u514d\u7a05\u3002<\/p>\n<p>\u8207\u6b64\u540c\u6642\uff0c\u82e5\u662f\u5408\u683c\u7684C \u578b\u516c\u53f8\uff0c\u7a05\u7387\u5728\u7a05\u6539\u5f8c\u964d\u81f321%\uff0c\u6709\u53ef\u80fd\u53ef\u4ee5\u62ff\u5230\u767e\u5206\u4e4b\u4e94\u5341\u7684GILTI tax\u7684\u62b5\u6e1b\uff0c\u4e26\u53ef\u4ee5\u4eab\u53d7\u5230\u6700\u591a\u5230\u767e\u5206\u4e4b\u516b\u5341\u7684foreign tax credit\u3002\u800c\u500b\u4eba\u7a05\u7684\u7533\u5831\u8005\uff0c\u5247\u53ef\u4ee5\u5229\u7528section 962\u5728\u500b\u4eba\u7a05\u4e0a\u7533\u8acb\u6bd4\u7167C \u578b\u516c\u53f8\u7684\u65b9\u5f0f\u7533\u5831\u3002\u5982\u6b64\u4e00\u4f86\uff0c\u5c07\u53ef\u4ee5\u5927\u5e45\u964d\u4f4e\u56e0\u70baGILTI tax\u6240\u9020\u6210\u7684\u7a05\u52d9\u8ca0\u64d4\u3002\u4f46\u662f\u5176\u7f3a\u9ede\u662f\u65e5\u5f8c\u8cc7\u91d1\u56de\u6d41\u7f8e\u570b\uff0c\u5c07\u6703\u9762\u81e8\u91cd\u4a31\u8ab2\u7a05\u7684\u554f\u984c\u3002<\/p>\n<p>\u65bc\u662f\u9019\u7576\u4e2d\u5c31\u7522\u751f\u4e86\u7a05\u52d9\u898f\u5283\u7684\u7a7a\u9593\u3002\u56e0\u70ba\u50b3\u7d71\u7684\u570b\u969b\u79df\u7a05\u898f\u5283\u662f\u5074\u91cd\u65bc\u79df\u7a05\u905e\u5ef6\u53ca\u6d77\u5916\u672c\u5730\u7684\u79df\u7a05\u3002\u4f8b\u5982\u7a0e\u6539\u524d\u860b\u679c\u516c\u53f8\u5c07\u6d77\u5916\u7e3d\u90e8\u7f6e\u65bc\u611b\u723e\u862d\uff0c\u662f\u76f8\u4e2d\u5176\u76f8\u7576\u4f4e\u7684\u516c\u53f8\u7a05\u7a05\u7387\u53ca\u73fe\u91d1\u82e5\u4e0d\u904b\u56de\u7f8e\u570b\u5247\u53ef\u4ee5\u905e\u5ef6\u8ab2\u7a05\u7684\u512a\u52e2\u3002\u7136\u800cGILTI tax\u7684\u51fa\u73fe\uf