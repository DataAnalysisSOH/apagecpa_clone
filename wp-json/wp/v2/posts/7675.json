\u570b\u7e3d\u7d71\u5ddd\u666e\u7c3d\u7f72\u4e86\u5927\u7f8e\u9e97\u6cd5\u6848\uff0c\u5176\u4e2d\u8a31\u591a\u689d\u6b3e\u7684\u751f\u6548\u65e5\u671f\u70ba2025\u5e74\uff0c\u610f\u5473\u84572026\u5e74\u7533\u5831\u7684\u7a05\u8868\u7576\u4e2d\uff0c\u5c31\u6709\u5927\u7f8e\u9e97\u6cd5\u6848\u6240\u5f71\u97ff\u7684\u8eab\u5f71\uff0c\u672c\u671f\u7bc0\u76ee\u5c31\u8b93\u6211\u5011\u672c\u770b\u4e00\u4e0b\u5927\u7f8e\u9e97\u6cd5\u6848\u7684\u7c3d\u7f72\u5c0d\u4f01\u696d\u7684\u5f71\u97ff\u3002 1\u3002 Bonus depreciation. \u6298\u820a\u7d05\u5229\u3002\u5728\u73fe\u884c\u7684\u7a05\u6cd5\u4e0b\uff0c2024\u5e74\u5ea6\u7b2c\u4e00\u5e74\u7684\u6298\u820a\u7d05\u5229\u70ba\u539f\u8cfc\u50f9\u768460%\u3002\u7136\u800c\u5728\u5927\u7f8e\u9e97\u6cd5\u6848\u4e0b\uff0c \u57281\/19\/25\u81f31\/1\/2030\u7b2c\u4e00\u5e74\u7684\u6298\u820a\u7d05\u5229\u70ba\u539f\u8cfc\u50f9\u7684100%\u3002 2\u3002 Sec 179\u6298\u820a\u3002\u5728\u73fe\u884c\u7a05\u6cd5\u4e0b\uff0c2024\u5e74sec 179\u7684\u8cbb\u7528\u9650\u5236\u70ba1.22M. \u800c\u5728\u5927\u7f8e\u9e97\u6cd5\u6848\u4e0b\uff0c\u9019\u500b\u91d1\u984d\u7684\u9650\u5236\u63d0\u9ad8\u81f32.5M. \u7e31\u89c0\u4e0a\u8ff0\u5169\u9ede\u5c0d\u65bc\u52a0\u901f\u6298\u820a\u7684\u653e\u5bec\uff0c\u770b\u7684\u51fa\u6b64\u6cd5\u6848\u610f\u6b32\u4fc3\u9032\u6d88\u8cbb\uff0c\u52a0\u901f\u4f01\u696d\u7684\u73fe\u91d1\u6d41\u3002\u6240\u4ee5\uff0c\u82e5\u662f\u672c\u5e74\u5ea6\u6709\u76c8\u9918\u7684\u4f01\u696d\uff0c\u4e0d\u59a8\u8003\u616e\u5728\u5e74\u5e95\u4e4b\u524d\u52a0\u8cfc\u6a5f\u5668\u8a2d\u5099\uff0c\u53ef\u4ee5\u5168\u90e8\u8cbb\u7528\u5316\u3002 3\u3002 199A. Qualified business income deduction. \u57282017\u5e74\u5ddd\u666e\u7a05\u6539\u4e4b\u5f8c\uff0cpass through entities\u53ef\u4ee5\u4eab\u53d7QBI deduction. \u672c\u4f86\u662f\u572812\/31\/2025\u6709\u65e5\u843d\u689d\u6b3e\u7684\u9650\u5236\uff0c\u4f46\u662f\u5927\u7f8e\u9e97\u6cd5\u6848\u5ef6\u7e8c\u4e86\u9019\u500b\u512a\u60e0\u689d\u6b3e\uff0c\u6240\u4ee5\u7d0d\u7a05\u4eba\u6700\u597d\u5728\u5e74\u5e95\u524d\u548c\u6703\u8a08\u5e2b\u8a0e\u8ad6\uff0c\u5982\u4f55\u80fd\u6975\u5927\u5316\u516c\u53f8\u7684QBI deduction. R &amp; D expense. \u572812\/31\/2021\u5e74\u5f8c\uff0c\u7d0d\u7a05\u4eba\u88ab\u8981\u6c42\u8cc7\u672c\u5316\u7814\u767c\u8cbb\u7528\uff0c\u4e26\u5206\u6210\u4e94\u5e74\u6216\u662f\u5341\u4e94\u5e74\u6524\u6d88\u3002\u800c\u5728\u5927\u7f8e\u9e97\u6cd5\u6848\u4e0b\uff0c12\/31\/2024\u5f8c\u5728\u7f8e\u570b\u5883\u5167\u7684\u7814\u767c\u8cbb\u7528\u53ef\u4ee5\u5728\u7576\u5e74\u8cbb\u7528\u5316\uff0c\u53ea\u662f\u5728\u7f8e\u570b\u5883\u5916\u767c\u751f\u7684\u7814\u767c\u8cbb\u7528\uff0c\u4ecd\u9700\u7528\u5341\u4e94\u5e74\u76f4\u7dda\u6cd5\u4f86\u6524\u92b7\u8cbb\u7528\u3002 \u4ee5\u4e0a\u4fbf\u662f\u672c\u671f\u7bc0\u76ee\u7684\u5168\u90e8\u5167\u5bb9\uff0c\u611f\u8b1d\u5927\u5bb6\u7684\u6536\u807d\uff0c\u6211\u5011\u4e0b\u671f\u7bc0\u76ee\u518d\u6703\u3002\" \/>\n<meta property=\"og:url\" content=\"https:\/\/agapecpa.com\/7675.html\" \/>\n<meta property=\"og:site_name\" content=\"\u611b\u52a0\u500d\u6703\u8a08\u5e2b\u4e8b\u52d9\u6240 - AGAPE CPA FIRM\" \/>\n<meta property=\"article:published_time\" content=\"2025-11-14T16:30:32+00:00\" \/>\n<meta property=\"article:modified_time\" content=\"2025-11-14T16:40:04+00:00\" \/>\n<meta property=\"og:image\" content=\"https:\/\/agapecpa.com\/wp-content\/uploads\/sites\/10\/2025\/11\/new-us-tax.webp\" \/>\n\t<meta property=\"og:image:width\" content=\"800\" \/>\n\t<meta property=\"og:image:height\" content=\"533\" \/>\n\t<meta property=\"og:image:type\" content=\"image\/webp\" \/>\n<meta name=\"author\" content=\"jeel\" \/>\n<meta name=\"twitter:card\" content=\"summary_large_image\" \/>\n<meta name=\"twitter:label1\" content=\"Written by\" \/>\n\t<meta name=\"twitter:data1\" content=\"jeel\" \/>\n\t<meta name=\"twitter:label2\" content=\"Est. reading time\" \/>\n\t<meta name=\"twitter:data2\" content=\"1 minute\" \/>\n<script type=\"application\/ld+json\" class=\"yoast-schema-graph